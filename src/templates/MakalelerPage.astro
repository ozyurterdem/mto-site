---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getMakaleler, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/makaleler';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

// Fetch from Panel API
const { items: makaleler, total } = await getMakaleler(1, 50);

// Group by year
const byYear = new Map<number, typeof makaleler>();
for (const m of makaleler) {
  const year = m.yayin_tarihi ? new Date(m.yayin_tarihi).getFullYear() : new Date(m.created_at).getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(m);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
const activeYear = years[0] ?? new Date().getFullYear();

// Placeholder data if no articles yet
const hasArticles = makaleler.length > 0;

const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.makaleler') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.makaleler')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.makaleler')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="mavi"
>
  {hasArticles ? (
    <>
      <!-- Yıl Navigasyon -->
      <div class="flex flex-wrap gap-2 mb-8 not-prose">
        {years.map((year) => (
          <a
            href={`${localePath(locale, pagePath)}?yil=${year}`}
            class:list={[
              'px-5 py-2 rounded-full text-sm font-heading font-bold uppercase tracking-wider transition-all duration-300 no-underline',
              year === activeYear
                ? 'bg-turkuaz text-white shadow-lg shadow-turkuaz/30'
                : 'bg-gray-100 text-body hover:bg-gray-200',
            ]}
          >
            {year}
          </a>
        ))}
      </div>

      <!-- Başlık -->
      <h2 class="font-heading text-2xl md:text-3xl text-lacivert font-black uppercase tracking-wide mb-8 not-prose">
        {activeYear} MTO AKADEMİK MAKALELERİ
      </h2>

      <!-- Makale Listesi -->
      <div class="space-y-0 not-prose">
        {(byYear.get(activeYear) ?? []).map((makale, index) => {
          const tr = getTranslation(makale.translations, locale);
          return (
            <a
              href={localePath(locale, `/hikmet-olma/makaleler/${makale.slug}`)}
              class="flex items-start gap-4 px-5 py-4 border-b border-gray-100 transition-all duration-200 rounded-lg hover:bg-gray-50 no-underline"
            >
              <span class="font-heading font-bold text-sm mt-0.5 flex-shrink-0 min-w-[1.5rem] text-vizon">
                {index + 1}.
              </span>
              <div class="flex-1">
                <p class="font-body text-[0.95rem] leading-snug mb-1 text-lacivert">
                  {tr?.baslik ?? 'Başlıksız'}
                </p>
                {tr?.ozet && (
                  <p class="text-body/60 text-xs line-clamp-2">{tr.ozet}</p>
                )}
                <p class="text-body/40 text-xs mt-1">
                  {makale.yayin_tarihi ? new Date(makale.yayin_tarihi).toLocaleDateString(locale === 'tr' ? 'tr-TR' : locale === 'ar' ? 'ar-SA' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}
                  {makale.goruntulenme > 0 && ` · ${makale.goruntulenme} görüntülenme`}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    </>
  ) : (
    <!-- Henüz makale yok -->
    <div class="text-center py-16 not-prose">
      <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-turkuaz/10 flex items-center justify-center">
        <svg class="w-8 h-8 text-turkuaz" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
      </div>
      <h3 class="font-heading text-xl text-lacivert font-bold mb-2">Makaleler Hazırlanıyor</h3>
      <p class="font-body text-body/60 text-sm max-w-md mx-auto">
        MTO akademik makaleleri yakında burada yayınlanacak. Talebelerin hazırladığı çalışmalar derleniyor.
      </p>
    </div>
  )}

  <!-- Bilgi Notu -->
  <div class="mt-8 px-6 py-4 bg-turkuaz/5 border border-turkuaz/20 rounded-xl not-prose">
    <p class="text-body text-sm leading-relaxed">
      <strong class="text-turkuaz">Not:</strong> Makaleler, MTO akademik yaz kamplarında talebelerin hazırladığı çalışmaların derlenip yayımlanmış halidir.
    </p>
  </div>
</InnerPageLayout>
