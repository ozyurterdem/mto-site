---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import FaaliyetGaleri from '../components/FaaliyetGaleri.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/faaliyetler/halkalar';
const sidebarItems = nav.items.map(item => ({ ...item, active: item.href === localePath(locale, pagePath) }));
const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.halkalar') }
];
---

<InnerPageLayout locale={locale} title={`${t(locale, 'nav.sub.halkalar')} — MTO`} description={t(locale, 'meta.siteDescription')} pageTitle={t(locale, 'nav.sub.halkalar')} sidebarTitle={nav.title} sidebarItems={sidebarItems} breadcrumbs={breadcrumbs} currentPath={localePath(locale, pagePath)} accentColor="mavi">
  <div class="mb-10 text-body text-[1.05rem] leading-[2]">
    <p>Halkalar, MTO talebelerinin düzenli olarak bir araya geldiği okuma ve tartışma buluşmalarıdır. Her halka, belirli bir kitap veya konu etrafında şekillenir.</p>
  </div>
  <FaaliyetGaleri tur="halka" locale={locale} placeholderCount={16} placeholderLabel="Halka" />
</InnerPageLayout>
