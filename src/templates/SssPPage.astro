---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getIlimBilmeNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getSSS, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getIlimBilmeNav(locale);
const pagePath = '/ilim-bilme/sss';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

// Panel API — fallback to i18n
const apiSSS = await getSSS();
const sorular = apiSSS.length > 0
  ? apiSSS.map(s => {
      const tr = getTranslation(s.translations, locale);
      return { q: tr?.soru || '', a: tr?.cevap || '' };
    })
  : [
      { q: t(locale, 'sss.questions.0.q'), a: t(locale, 'sss.questions.0.a') },
      { q: t(locale, 'sss.questions.1.q'), a: t(locale, 'sss.questions.1.a') },
      { q: t(locale, 'sss.questions.2.q'), a: t(locale, 'sss.questions.2.a') },
    ];

const breadcrumbs = [
  { label: t(locale, 'nav.ilimBilme'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'nav.sub.sss') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.sss')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.sss')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="vizon"
>
  <div class="space-y-4 not-prose">
    {sorular.map((s, i) => (
      <details class="group bg-white rounded-xl border border-gray-100 overflow-hidden">
        <summary class="flex items-center gap-4 px-6 py-4 cursor-pointer hover:bg-gray-50 transition-colors">
          <span class="font-heading font-bold text-turkuaz text-lg flex-shrink-0">{i + 1}.</span>
          <span class="font-heading text-base font-semibold text-lacivert">{s.q}</span>
          <svg class="w-4 h-4 text-vizon ml-auto flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-5 pt-1 ml-10">
          <p class="text-sm text-body/80 leading-relaxed">{s.a}</p>
        </div>
      </details>
    ))}
  </div>
</InnerPageLayout>
