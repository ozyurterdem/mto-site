---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import FaaliyetGaleri from '../components/FaaliyetGaleri.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/kamplar';
const sidebarItems = nav.items.map(item => ({ ...item, active: item.href === localePath(locale, pagePath) }));
const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.kamplar') }
];
---

<InnerPageLayout locale={locale} title={`${t(locale, 'nav.sub.kamplar')} — MTO`} description={t(locale, 'meta.siteDescription')} pageTitle={t(locale, 'nav.sub.kamplar')} sidebarTitle={nav.title} sidebarItems={sidebarItems} breadcrumbs={breadcrumbs} currentPath={localePath(locale, pagePath)} accentColor="mavi">
  <div class="mb-10 text-body text-[1.05rem] leading-[2]">
    <p>MTO yaz kampları, talebelerin yoğun bir akademik program eşliğinde doğayla iç içe vakit geçirdiği, hem ilmi hem irfani derinleşme fırsatı sunan özel programlardır.</p>
  </div>
  <FaaliyetGaleri tur="kamp" locale={locale} placeholderCount={9} placeholderLabel="Kamp" />
</InnerPageLayout>
