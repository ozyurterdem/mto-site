---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getIlimBilmeNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getTakvim, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getIlimBilmeNav(locale);
const pagePath = '/ilim-bilme/akademik-takvim';
const sidebarItems = nav.items.map(item => ({ ...item, active: item.href === localePath(locale, pagePath) }));

const apiTakvim = await getTakvim();

const breadcrumbs = [
  { label: t(locale, 'nav.ilimBilme'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'nav.sub.akademikTakvim') }
];
---

<InnerPageLayout locale={locale} title={`${t(locale, 'nav.sub.akademikTakvim')} — MTO`} description={t(locale, 'meta.siteDescription')} pageTitle={t(locale, 'nav.sub.akademikTakvim')} sidebarTitle={nav.title} sidebarItems={sidebarItems} breadcrumbs={breadcrumbs} currentPath={localePath(locale, pagePath)} accentColor="vizon">
  <div class="space-y-8">
    <div class="prose prose-lg max-w-none font-body text-lacivert/80">
      <p>Medeniyet Tasavvuru Okulu, <strong>Güz Dönemi</strong> ve <strong>Bahar Dönemi</strong> olarak iki dönemden oluşmaktadır.</p>
    </div>

    {apiTakvim.length > 0 ? (
      <div class="space-y-4 not-prose">
        {apiTakvim.map(item => {
          const tr = getTranslation(item.translations, locale);
          return (
            <div class="bg-white rounded-xl border border-gray-100 p-6">
              <div class="flex items-start gap-4">
                {item.donem && <span class="text-xs font-mono font-bold text-turkuaz bg-turkuaz/10 px-3 py-1 rounded-full">{item.donem}</span>}
                <div>
                  <h3 class="font-heading text-lg font-bold text-lacivert">{tr?.baslik || ''}</h3>
                  {tr?.aciklama && <p class="text-sm text-body/70 mt-1">{tr.aciklama}</p>}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="not-prose bg-turkuaz/5 border border-turkuaz/20 rounded-xl p-6 text-center">
        <p class="text-sm text-body/60">Akademik takvim yakında güncellenecektir.</p>
      </div>
    )}
  </div>
</InnerPageLayout>
