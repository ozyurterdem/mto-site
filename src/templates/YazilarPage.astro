---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/yazilar';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

const writings = [
  { title: 'Medeniyetin Yeniden İnşası Üzerine Düşünceler', author: 'Yusuf Kaplan' },
  { title: 'Bilgi, İrfan ve Hikmet: Üç Basamaklı Yükseliş', author: 'Yusuf Kaplan' },
  { title: 'Geleneğin İhyası ve Modern Dünyanın Meydan Okuması', author: 'Yusuf Kaplan' },
  { title: 'Kavramlarla Düşünmek: Zihinsel İnşanın Temelleri', author: 'Yusuf Kaplan' },
  { title: 'Doğu ve Batı Arasında Bir Köprü: İslam Düşüncesi', author: 'Yusuf Kaplan' },
  { title: 'Talebelik Ahlakı ve Bilgi Yolculuğu', author: 'Yusuf Kaplan' },
  { title: 'İnsanın Özleşme Serüveni', author: 'Yusuf Kaplan' },
  { title: 'Modernite Karşısında Geleneğin Direnci', author: 'Yusuf Kaplan' },
  { title: 'Okuma Sanatı ve Derinleşme Yöntemi', author: 'Yusuf Kaplan' },
  { title: 'Küreselleşme ve Medeniyet Krizi', author: 'Yusuf Kaplan' },
  { title: 'Sessiz Devrim: Düşüncenin Gücü', author: 'Yusuf Kaplan' },
  { title: 'Hakikat Arayışında İnsan', author: 'Yusuf Kaplan' },
];

const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.yazilar') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.yazilar')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.yazilar')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="mavi"
>
  <!-- Yazi Listesi -->
  <div class="space-y-0 not-prose">
    {writings.map((writing, index) => (
      <div class="flex items-start gap-4 px-5 py-4 border-b border-gray-100 hover:bg-gray-50 transition-all duration-200 rounded-lg group">
        <span class="w-1.5 h-1.5 rounded-full bg-turkuaz mt-2.5 flex-shrink-0 group-hover:scale-150 transition-transform"></span>
        <div class="flex-1">
          <p class="font-body text-[0.95rem] text-lacivert leading-snug mb-1 group-hover:text-turkuaz transition-colors">
            {writing.title}
          </p>
          <p class="text-body/50 text-xs">{writing.author}</p>
        </div>
      </div>
    ))}
  </div>
</InnerPageLayout>
