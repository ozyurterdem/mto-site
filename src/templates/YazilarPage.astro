---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getMakaleler, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/yazilar';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

// Yazılar = makaleler (same API, could filter by tag in future)
// For now, show all published articles on this page too
const { items: yazilar } = await getMakaleler(1, 50);
const hasYazilar = yazilar.length > 0;

const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.yazilar') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.yazilar')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.yazilar')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="mavi"
>
  {hasYazilar ? (
    <div class="space-y-0 not-prose">
      {yazilar.map((yazi, index) => {
        const tr = getTranslation(yazi.translations, locale);
        return (
          <a
            href={localePath(locale, `/hikmet-olma/makaleler/${yazi.slug}`)}
            class="flex items-start gap-4 px-5 py-5 border-b border-gray-100 transition-all duration-200 rounded-lg hover:bg-turkuaz/5 no-underline group"
          >
            <span class="font-heading font-bold text-sm mt-0.5 flex-shrink-0 min-w-[1.5rem] text-vizon group-hover:text-turkuaz transition-colors">
              {index + 1}.
            </span>
            <div class="flex-1">
              <p class="font-body text-[0.95rem] leading-snug mb-1 text-lacivert group-hover:text-turkuaz transition-colors font-medium">
                {tr?.baslik ?? 'Başlıksız'}
              </p>
              {tr?.ozet && (
                <p class="text-body/50 text-sm line-clamp-2 mt-1">{tr.ozet}</p>
              )}
            </div>
            <svg class="w-4 h-4 text-lacivert/30 group-hover:text-turkuaz transition-colors mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        );
      })}
    </div>
  ) : (
    <div class="text-center py-16 not-prose">
      <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-turkuaz/10 flex items-center justify-center">
        <svg class="w-8 h-8 text-turkuaz" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </div>
      <h3 class="font-heading text-xl text-lacivert font-bold mb-2">Yazılar Hazırlanıyor</h3>
      <p class="font-body text-body/60 text-sm max-w-md mx-auto">
        MTO yazı arşivi yakında burada yayınlanacak.
      </p>
    </div>
  )}
</InnerPageLayout>
