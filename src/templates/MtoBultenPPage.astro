---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getIlimBilmeNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getBultenler, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getIlimBilmeNav(locale);
const pagePath = '/ilim-bilme/mto-bulten';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

// Fetch from Panel API
const bultenler = await getBultenler();
const hasBulten = bultenler.length > 0;

const breadcrumbs = [
  { label: t(locale, 'nav.ilimBilme'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'nav.sub.mtoBulten') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.mtoBulten')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.mtoBulten')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="vizon"
>
  <div class="space-y-8">
    {hasBulten ? (
      <>
        <!-- Bülten Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 not-prose">
          {bultenler.map((bulten) => {
            const tr = getTranslation(bulten.translations, locale);
            return (
              <article class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-lacivert/5">
                <!-- Sayı Badge -->
                <div class="aspect-video bg-gradient-to-br from-lacivert/10 to-turkuaz/10 relative overflow-hidden flex items-center justify-center">
                  <div class="text-center">
                    <span class="font-heading text-5xl font-black text-lacivert/20">{bulten.sayi_no}</span>
                    <p class="font-heading text-xs uppercase tracking-widest text-lacivert/30 mt-1">Sayı</p>
                  </div>
                </div>

                <!-- Content -->
                <div class="p-5">
                  {bulten.yayin_tarihi && (
                    <time class="text-xs font-body text-turuncu font-semibold uppercase tracking-wide">
                      {new Date(bulten.yayin_tarihi).toLocaleDateString(locale === 'tr' ? 'tr-TR' : locale === 'ar' ? 'ar-SA' : 'en-US', { year: 'numeric', month: 'long' })}
                    </time>
                  )}
                  <h3 class="font-heading text-lg font-bold text-lacivert mt-2 mb-2 group-hover:text-turkuaz transition-colors line-clamp-2">
                    {tr?.baslik ?? `Bülten #${bulten.sayi_no}`}
                  </h3>
                  <div class="font-body text-sm text-lacivert/60 line-clamp-3" set:html={tr?.icerik?.slice(0, 200) + '...'} />
                </div>
              </article>
            );
          })}
        </div>
      </>
    ) : (
      <!-- Henüz bülten yok -->
      <div class="text-center py-16 not-prose">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-vizon/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-vizon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <h3 class="font-heading text-xl text-lacivert font-bold mb-2">Bültenler Hazırlanıyor</h3>
        <p class="font-body text-body/60 text-sm max-w-md mx-auto">
          MTO bülten arşivi yakında burada yayınlanacak. Haberler, duyurular ve etkinlik özetleri derlenecek.
        </p>
      </div>
    )}
  </div>
</InnerPageLayout>
