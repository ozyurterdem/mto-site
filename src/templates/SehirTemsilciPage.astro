---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getIlimBilmeNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getTemsilciler, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getIlimBilmeNav(locale);
const pagePath = '/ilim-bilme/sehir-temsilcilikleri';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

const apiTemsilciler = await getTemsilciler();
const sehirler = apiTemsilciler.length > 0
  ? apiTemsilciler.map(t => {
      const tr = getTranslation(t.translations, locale);
      return { sehir: tr?.sehir || '', temsilci: tr?.temsilci_adi || '', iletisim: tr?.iletisim || '' };
    })
  : [
      { sehir: 'İstanbul', temsilci: '', iletisim: '' },
      { sehir: 'Bursa', temsilci: '', iletisim: '' },
      { sehir: 'Ankara', temsilci: '', iletisim: '' },
      { sehir: 'Diyarbakır', temsilci: '', iletisim: '' },
      { sehir: 'Erzurum', temsilci: '', iletisim: '' },
      { sehir: 'Trabzon', temsilci: '', iletisim: '' },
    ];

const breadcrumbs = [
  { label: t(locale, 'nav.ilimBilme'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'nav.sub.sehirTemsilcilikleri') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.sehirTemsilcilikleri')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.sehirTemsilcilikleri')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="vizon"
>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 not-prose">
    {sehirler.map(s => (
      <div class="bg-white rounded-xl border border-gray-100 p-5 hover:shadow-md transition-shadow">
        <h3 class="font-heading text-lg font-bold text-lacivert">{s.sehir}</h3>
        {s.temsilci && <p class="text-sm text-body/80 mt-1">{s.temsilci}</p>}
        {s.iletisim && <p class="text-xs text-turkuaz mt-1">{s.iletisim}</p>}
      </div>
    ))}
  </div>
</InnerPageLayout>
