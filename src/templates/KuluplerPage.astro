---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getFaaliyetler, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/kulupler';
const sidebarItems = nav.items.map(item => ({ ...item, active: item.href === localePath(locale, pagePath) }));

const apiFaaliyetler = await getFaaliyetler('kulup');
const kulupler = apiFaaliyetler.length > 0
  ? apiFaaliyetler.map(f => { const tr = getTranslation(f.translations, locale); return { baslik: tr?.baslik || '', aciklama: tr?.aciklama || '' }; })
  : [
      { baslik: 'Marmara Üniversitesi', aciklama: '' },
      { baslik: 'İstanbul Üniversitesi', aciklama: '' },
      { baslik: 'Sakarya Üniversitesi', aciklama: '' },
      { baslik: 'Uludağ Üniversitesi', aciklama: '' },
    ];

const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.kulupler') }
];
---

<InnerPageLayout locale={locale} title={`${t(locale, 'nav.sub.kulupler')} — MTO`} description={t(locale, 'meta.siteDescription')} pageTitle={t(locale, 'nav.sub.kulupler')} sidebarTitle={nav.title} sidebarItems={sidebarItems} breadcrumbs={breadcrumbs} currentPath={localePath(locale, pagePath)} accentColor="mavi">
  <div class="mb-10 text-body text-[1.05rem] leading-[2]">
    <p>MTO kulüpleri, üniversite bünyesinde faaliyet gösteren ve talebelerin akademik ve sosyal gelişimlerine katkı sağlayan yapılardır.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 not-prose">
    {kulupler.map(k => (
      <div class="bg-white rounded-xl border border-gray-100 p-6 hover:shadow-md transition-shadow">
        <h3 class="font-heading text-lg font-bold text-lacivert">{k.baslik}</h3>
        {k.aciklama && <p class="text-sm text-body/70 mt-2">{k.aciklama}</p>}
      </div>
    ))}
  </div>
</InnerPageLayout>
