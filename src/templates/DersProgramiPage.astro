---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getIlimBilmeNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getDersProgram } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getIlimBilmeNav(locale);

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, '/ders-programi')
}));

const breadcrumbs = [
  { label: t(locale, 'nav.ilimBilme'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'nav.sub.dersProgramlari') }
];

const program = await getDersProgram();
const dersProgramlari = program.kademeler;

const kademeColors = ['#D4C5AD', '#C4B394', '#B7A78F', '#A08E74', '#8A7A64'];
const kademeStats = dersProgramlari.map(kp => {
  const hocalar = new Set<string>();
  let toplamDers = 0;
  for (const gp of kp.programlar) {
    for (const d of gp.dersler) {
      toplamDers++;
      if (d.hoca !== '-') hocalar.add(d.hoca);
    }
  }
  return { hocaSayisi: hocalar.size, dersSayisi: toplamDers };
});
---

<InnerPageLayout
  accentColor="vizon"
  title="Ders Programı - İLİM·BİLME"
  description="Medeniyet Tasavvuru Okulu 2025-2026 Bahar Dönemi ders programları."
  pageTitle="Ders Programı"
  sidebarTitle={nav.title}
  
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath="/ders-programi"
  showBulten={false}
>

  <p class="text-lacivert/70 font-body text-lg mb-8 leading-relaxed">
    Medeniyet Tasavvuru Okulu 2025–2026 Bahar Dönemi ders programları. 5 kademe, haftanın 7 günü devam eden kapsamlı eğitim programı.
  </p>

  <!-- Sticky Kademe Nav -->
  <div class="sticky top-20 z-30 mb-12">
    <div class="flex flex-wrap justify-center gap-2 bg-white/95 backdrop-blur-md border border-gray-200/80 rounded-xl shadow-sm py-2.5 px-3">
      {dersProgramlari.map((kp, i) => (
        <a
          href={`#kademe-${i + 1}`}
          class="kademe-nav group flex-1 flex items-center justify-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-all hover:shadow-md no-underline"
          data-kademe={i + 1}
          style={`color: ${kademeColors[i]};`}
        >
          <div class="w-6 h-6 rounded-md grid place-items-center text-white text-[10px] font-bold transition-all group-hover:scale-110" style={`background: ${kademeColors[i]}`}>
            {i + 1}
          </div>
          <span class="hidden md:inline font-heading font-bold text-lacivert text-[0.75rem]">{kp.kisa}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Kademe Bölümleri -->
  {dersProgramlari.map((kp, ki) => {
    const color = kademeColors[ki];
    const stats = kademeStats[ki];

    return (
      <section id={`kademe-${ki + 1}`} class="mb-24 last:mb-0 scroll-mt-24">

        {/* Kademe Header */}
        <div class="mb-10">
          <div class="flex items-center gap-3 mb-2">
            <div class="h-px flex-1 max-w-[40px]" style={`background: ${color}50`}></div>
          </div>

          <h2 class="font-heading text-2xl md:text-[2rem] text-lacivert font-black leading-tight mb-1">{kp.kademe}</h2>
          <p class="text-sm font-medium mb-5" style={`color: ${color}`}>Haftalık Ders Programı</p>

          {/* İstatistik çipleri */}
          <div class="flex flex-wrap items-center gap-2">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.7rem] font-bold border" style={`color: ${color}; background: ${color}08; border-color: ${color}18`}>
              <span class="w-1.5 h-1.5 rounded-full" style={`background: ${color}`}></span>
              {kp.makaleSayisi} makale
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.7rem] font-bold border" style={`color: ${color}; background: ${color}08; border-color: ${color}18`}>
              <span class="w-1.5 h-1.5 rounded-full" style={`background: ${color}`}></span>
              {stats.dersSayisi} ders
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.7rem] font-bold text-vizon/70 bg-vizon/5 border border-vizon/15">
              <span class="w-1.5 h-1.5 rounded-full bg-vizon/50"></span>
              {stats.hocaSayisi} hoca
            </span>
          </div>
        </div>

        {/* Gün kartları */}
        <div class="space-y-1.5">
          {kp.programlar.map((gp) => (
            <div class="group relative rounded-xl transition-all duration-300 hover:shadow-[0_4px_24px_rgba(183,167,143,0.15)]">
              <div class="relative bg-white border border-gray-100/80 group-hover:border-vizon/30 rounded-xl overflow-hidden transition-all duration-300">

                {/* Sol accent */}
                <div class="absolute left-0 top-0 bottom-0 w-[3px] opacity-40 group-hover:opacity-100 transition-opacity duration-300" style={`background: ${color}`}></div>

                {/* Gün başlığı */}
                <div class="flex items-center gap-3 px-5 py-3 border-b border-gray-200" style={`background: ${color}20`}>
                  <div class="flex-1">
                    <span class="font-heading font-bold text-lacivert text-sm">{gp.gun}</span>
                    <span class="text-lacivert/30 text-xs ml-2">{gp.dersler.length} ders</span>
                  </div>
                  <span class="text-xs text-lacivert/30 hidden sm:block">
                    {gp.dersler[0].saat} – {gp.dersler[gp.dersler.length - 1].saat}
                  </span>
                </div>

                {/* Dersler */}
                <div class="divide-y divide-gray-50">
                  {gp.dersler.map((d) => (
                    <div class="flex items-center gap-4 px-5 py-3 hover:bg-gray-50/50 transition-colors">
                      <div class="flex-shrink-0 w-[55px]">
                        <span class="font-heading font-bold text-lacivert text-sm">{d.saat}</span>
                      </div>
                      <div class="hidden sm:block w-px h-6 bg-gray-100 flex-shrink-0"></div>
                      <div class="flex-1 min-w-0">
                        <span class="text-lacivert text-[0.9rem] font-medium leading-snug">{d.ders}</span>
                        {d.hoca !== '-' && (
                          <span class="text-lacivert font-light text-[0.78rem] ml-2">— {d.hoca}</span>
                        )}
                      </div>
                      <span class="text-xs font-medium text-lacivert/30 bg-gray-50 rounded-full px-2.5 py-0.5 hidden sm:block flex-shrink-0">{d.sure}</span>
                    </div>
                  ))}
                </div>

              </div>
            </div>
          ))}
        </div>

      </section>
    );
  })}

</InnerPageLayout>
