---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getIlimBilmeNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getKadro, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getIlimBilmeNav(locale);
const pagePath = '/ilim-bilme/akademik-kadro';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

// Panel API — fallback to hardcoded
const apiKadro = await getKadro();
const kadro = apiKadro.length > 0
  ? apiKadro.map(k => {
      const tr = getTranslation(k.translations, locale);
      return { name: tr?.ad_soyad || '', ders: tr?.brans || '', image: k.foto_url || '', bio: tr?.bio || '' };
    })
  : [
      { name: 'YUSUF KAPLAN', ders: 'Fütûhât-ı Medeniyye', image: '', bio: '' },
      { name: 'SAADETTİN ACAR', ders: 'Öncüler', image: '/images/kadro/akademik-kadro-01.jpg', bio: '' },
      { name: 'KASIM KÜÇÜKALP', ders: 'Klasikten Çağdaşa Batı Düşüncesinin Serüveni', image: '/images/kadro/akademik-kadro-02.jpg', bio: '' },
      { name: 'TAHSİN GÖRGÜN', ders: 'Düşünce Tarihi', image: '', bio: '' },
      { name: 'YÜCEL ARZEN', ders: 'Sesin Nefesi: Nefesin Sesi', image: '', bio: '' },
      { name: 'AHMET DAĞ', ders: 'Yapay Zekâ, İslâm ve Etik', image: '', bio: '' },
    ];

const breadcrumbs = [
  { label: t(locale, 'nav.ilimBilme'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'nav.sub.akademikKadro') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.akademikKadro')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.akademikKadro')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="vizon"
>
  <div class="space-y-10">
    <div class="space-y-5 text-body leading-relaxed">
      <p>Medeniyet Tasavvuru Okulu'nun akademik kadrosu, sadece bilgi aktaran değil; enfüsi derinlik ile âfaki ufku merkeze alan ve bu birliktelikle hakikatin izini süren öncülerden oluşmaktadır.</p>
      <p>Disiplinler arası düşünceye açık, farklı alanlarda uzmanlaşmış ilim insanlarından oluşan MTO akademik kadrosu, bilgi aktarmaktan öte, talebelerine ilmî karakter ve düşünme disiplini kazandıran öncülerdir.</p>
    </div>

    <p class="text-center font-heading text-lg font-bold text-lacivert py-4">
      Medeniyet Tasavvuru Okulu | <span class="text-turkuaz">İlim</span> ile Derinleş, <span class="text-vizon">İrfan</span> ile Keşfet, <span class="text-turuncu">Hikmet</span> ile İnşâ Et!
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {kadro.map(hoca => (
        <div class="group overflow-hidden">
          <div class="aspect-[3/4] bg-gray-300 relative">
            {hoca.image && <img src={hoca.image} alt={hoca.name} class="w-full h-full object-cover" />}
            <div class="absolute bottom-0 left-0 bg-turuncu px-4 py-2">
              <span class="text-white text-xs font-bold tracking-wider">{hoca.name}</span>
            </div>
          </div>
          <div class="bg-white py-3">
            <p class="text-sm text-body"><span class="font-semibold">Ders:</span> <strong>{hoca.ders}</strong></p>
          </div>
        </div>
      ))}
    </div>
  </div>
</InnerPageLayout>
