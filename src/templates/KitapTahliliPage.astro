---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';
import { getFaaliyetler, getTranslation } from '../lib/panel';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/faaliyetler/kitap-tahlili';
const sidebarItems = nav.items.map(item => ({ ...item, active: item.href === localePath(locale, pagePath) }));

const apiFaaliyetler = await getFaaliyetler('kitap_tahlili');
const adimlar = apiFaaliyetler.length > 0
  ? apiFaaliyetler.map(f => { const tr = getTranslation(f.translations, locale); return { baslik: tr?.baslik || '', aciklama: tr?.aciklama || '' }; })
  : [
      { baslik: 'Okuma', aciklama: '4 Kalem Tekniği ile derinlikli okuma' },
      { baslik: 'Tahlil', aciklama: 'Kavram haritası ve argüman analizi' },
      { baslik: 'Tartışma', aciklama: 'Halka içi soru-cevap ve müzakere' },
      { baslik: 'Yazma', aciklama: 'Kitap eleştirisi veya makale kaleme alma' },
    ];

const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.kitapTahlili') }
];
---

<InnerPageLayout locale={locale} title={`${t(locale, 'nav.sub.kitapTahlili')} — MTO`} description={t(locale, 'meta.siteDescription')} pageTitle={t(locale, 'nav.sub.kitapTahlili')} sidebarTitle={nav.title} sidebarItems={sidebarItems} breadcrumbs={breadcrumbs} currentPath={localePath(locale, pagePath)} accentColor="mavi">
  <div class="mb-10 text-body text-[1.05rem] leading-[2]">
    <p>Kitap tahlili, MTO'nun eğitim metodolojisinin temel taşlarından biridir. Talebeler, seçilen eserleri sistematik bir şekilde okur, çözümler ve yorumlar.</p>
  </div>

  <div class="space-y-4 not-prose">
    {adimlar.map((adim, i) => (
      <div class="flex gap-5 items-start bg-white rounded-xl border border-gray-100 p-6">
        <div class="w-10 h-10 rounded-full bg-turkuaz/10 flex items-center justify-center flex-shrink-0">
          <span class="font-heading font-bold text-turkuaz">{i + 1}</span>
        </div>
        <div>
          <h3 class="font-heading text-lg font-bold text-lacivert">{adim.baslik}</h3>
          <p class="text-sm text-body/70 mt-1">{adim.aciklama}</p>
        </div>
      </div>
    ))}
  </div>
</InnerPageLayout>
