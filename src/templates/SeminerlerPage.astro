---
import InnerPageLayout from '../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../i18n/index';

interface Props { locale?: Locale; }
const { locale = defaultLocale } = Astro.props;
const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/seminerler';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

const slides = [
  { id: 1, alt: 'MTO Seminer 1' },
  { id: 2, alt: 'MTO Seminer 2' },
  { id: 3, alt: 'MTO Seminer 3' },
  { id: 4, alt: 'MTO Seminer 4' },
  { id: 5, alt: 'MTO Seminer 5' },
];

const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.seminerler') }
];
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'nav.sub.seminerler')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'nav.sub.seminerler')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="mavi"
>
  <!-- Aciklama -->
  <div class="mb-10 text-body text-[1.05rem] leading-[2]">
    <p>
      MTO seminerleri, talebelerin akademik gelişimlerini desteklemek, düşünce ufuklarını genişletmek ve entelektüel derinlik kazandırmak amacıyla düzenlenen periyodik buluşmalardır. Seminerler; tarih felsefesi, medeniyet düşüncesi, İslam ilim geleneği, modernite eleştirisi ve güncel meseleler gibi geniş bir yelpazede gerçekleştirilir.
    </p>
    <p class="mt-4">
      <strong class="text-turkuaz">Genç Kürsü</strong> programı, talebelerin hazırladıkları tebliğleri sundukları, akademik sunum tecrübesi kazandıkları özel bir seminer formatıdır. Bu program, talebelerin araştırma yapma, düşüncelerini yazıya dökme ve sözlü sunuş becerilerini geliştirmelerine katkı sağlar.
    </p>
    <p class="mt-4">
      Seminerler, şehir temsilcilikleri aracılığıyla farklı illerde de düzenlenmekte; böylece MTO'nun düşünce iklimi Türkiye geneline yayılmaktadır.
    </p>
  </div>

  <!-- Gorsel Slider / Carousel -->
  <div class="not-prose">
    <div class="relative overflow-hidden rounded-2xl bg-lacivert" id="seminer-carousel">
      <!-- Slides Container -->
      <div class="flex transition-transform duration-500 ease-in-out" id="slides-container">
        {slides.map((slide) => (
          <div class="w-full flex-shrink-0 aspect-[16/9] bg-lacivert/90 relative">
            <div class="absolute inset-0 bg-gradient-to-br from-turkuaz/20 via-lacivert to-mavi/20 flex items-center justify-center">
              <div class="text-center">
                <div class="w-20 h-20 rounded-full bg-white/10 grid place-items-center mx-auto mb-4">
                  <svg class="w-10 h-10 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
                <p class="text-white/50 text-sm font-heading uppercase tracking-widest">{slide.alt}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation Arrows -->
      <button
        id="prev-btn"
        class="absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm grid place-items-center text-white hover:bg-white/30 transition-all z-10"
        aria-label="Onceki"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="next-btn"
        class="absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm grid place-items-center text-white hover:bg-white/30 transition-all z-10"
        aria-label="Sonraki"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Dot Pagination -->
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
        {slides.map((_, index) => (
          <button
            class:list={[
              'carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300',
              index === 0 ? 'bg-turkuaz w-8' : 'bg-white/40 hover:bg-white/60',
            ]}
            data-index={index}
            aria-label={`Slide ${index + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</InnerPageLayout>
