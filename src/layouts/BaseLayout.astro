---
import '../styles/global.css';
import { getConfig, getAlternateURLs, type Locale, defaultLocale } from '../i18n/index';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  locale?: Locale;
  basePath?: string;
}

const {
  title = 'Medeniyet Tasavvuru Okulu — MTO',
  description = 'İslâm medeniyetini yeniden inşa ve ihya sürecinin kavramsal çerçevesi. Bilgi, irfan ve hikmet merkezli eğitim programı.',
  ogImage = '/images/mto-web-logo.png',
  locale = defaultLocale,
  basePath,
} = Astro.props;

const config = getConfig(locale);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const alternates = basePath ? getAlternateURLs(basePath) : null;
---
<!DOCTYPE html>
<html lang={config.lang} dir={config.dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- Hreflang -->
  {alternates && alternates.map(a => (
    <link rel="alternate" hreflang={a.locale} href={a.href} />
  ))}
  {alternates && <link rel="alternate" hreflang="x-default" href={`https://mto.siberkale.com${basePath}`} />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content={config.ogLocale} />
  <meta property="og:site_name" content="Medeniyet Tasavvuru Okulu" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/mto-logo.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
