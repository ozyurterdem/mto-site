---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Medeniyet Tasavvuru Okulu — MTO', description = 'İslâm medeniyetini yeniden inşa ve ihya sürecinin kavramsal çerçevesi' } = Astro.props;
---
<!DOCTYPE html>
<html lang="tr" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/images/mto-logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700;800;900&family=Roboto:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
