---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollTop from '../components/ScrollTop.astro';
import SidebarNav from '../components/SidebarNav.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import MtoBultenWidget from '../components/MtoBultenWidget.astro';

interface NavItem {
  label: string;
  href: string;
  active?: boolean;
  children?: NavItem[];
}

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title?: string;
  description?: string;
  pageTitle: string;
  sidebarTitle: string;
  sidebarItems: NavItem[];
  breadcrumbs: BreadcrumbItem[];
  showBulten?: boolean;
  currentPath?: string;
  accentColor?: 'vizon' | 'turuncu' | 'mavi';
}

const {
  title,
  description,
  pageTitle,
  sidebarTitle,
  sidebarItems,
  breadcrumbs,
  showBulten = true,
  currentPath = Astro.url.pathname,
  accentColor = 'vizon',
} = Astro.props;

const titleColorClass = accentColor === 'vizon' ? 'text-vizon' : accentColor === 'turuncu' ? 'text-turuncu' : 'text-mavi';
---

<BaseLayout title={title || `${pageTitle} — MTO`} description={description}>
  <Header />
  <main class="min-h-screen">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-12 lg:py-16">
      <div class="flex flex-col lg:flex-row gap-10 lg:gap-16">
        <!-- Sidebar -->
        <SidebarNav title={sidebarTitle} items={sidebarItems} currentPath={currentPath} accentColor={accentColor} />

        <!-- Content -->
        <div class="flex-1 min-w-0">
          <Breadcrumb items={breadcrumbs} />
          <h1 class:list={['text-3xl lg:text-4xl font-bold uppercase tracking-wide font-heading mt-2 mb-8', titleColorClass]}>
            {pageTitle}
          </h1>
          <div class="prose prose-lg max-w-none text-body font-body leading-relaxed">
            <slot />
          </div>

          {showBulten && <MtoBultenWidget />}
        </div>
      </div>
    </div>
  </main>
  <Footer />
  <ScrollTop />
</BaseLayout>
