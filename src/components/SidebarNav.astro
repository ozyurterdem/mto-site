---
interface NavItem {
  label: string;
  href: string;
  active?: boolean;
  children?: NavItem[];
}

interface Props {
  title: string;
  titleHref?: string;
  items: NavItem[];
  currentPath?: string;
  accentColor?: 'vizon' | 'turuncu' | 'mavi';
}

const { title, titleHref, items, currentPath = '', accentColor = 'vizon' } = Astro.props;

function isActive(item: NavItem): boolean {
  if (item.active) return true;
  if (item.href && item.href !== '#' && currentPath === item.href) return true;
  if (item.children?.some(c => isActive(c))) return true;
  return false;
}

// Renk eşlemeleri
const titleColor = accentColor === 'vizon' ? 'text-vizon' : accentColor === 'turuncu' ? 'text-turuncu' : 'text-mavi';
const borderColor = accentColor === 'vizon' ? 'border-vizon' : accentColor === 'turuncu' ? 'border-turuncu' : 'border-mavi';
const activeBg = accentColor === 'vizon' ? 'bg-vizon' : accentColor === 'turuncu' ? 'bg-turuncu' : 'bg-mavi';
const activeChildText = accentColor === 'vizon' ? 'text-vizon' : accentColor === 'turuncu' ? 'text-turuncu' : 'text-mavi';
const hoverText = accentColor === 'vizon' ? 'hover:text-vizon' : accentColor === 'turuncu' ? 'hover:text-turuncu' : 'hover:text-mavi';
---

<aside class="w-full lg:w-[260px] flex-shrink-0">
  {titleHref ? (
    <a href={titleHref} class:list={['block text-[1.1rem] font-bold tracking-wider uppercase border-b-2 pb-3 mb-4 font-heading no-underline hover:opacity-80 transition-opacity', titleColor, borderColor]}>
      {title}
    </a>
  ) : (
    <h3 class:list={['text-[1.1rem] font-bold tracking-wider uppercase border-b-2 pb-3 mb-4 font-heading', titleColor, borderColor]}>
      {title}
    </h3>
  )}
  <ul class="list-none space-y-0">
    {items.map(item => {
      const active = isActive(item);
      const hasChildren = item.children && item.children.length > 0;
      const childActive = hasChildren && item.children!.some(c => isActive(c));
      const isToggle = hasChildren && (item.href === '#' || !item.href);
      const showChildren = childActive || active;
      return (
        <li>
          {isToggle ? (
            <button
              class:list={[
                'sidebar-toggle w-full flex items-center gap-2 py-2.5 px-3 text-sm font-medium border-b border-vizon/15 transition-colors cursor-pointer text-left',
                active
                  ? `${activeBg} text-white`
                  : `text-lacivert ${hoverText} hover:bg-gray-50`,
              ]}
              data-open={showChildren ? 'true' : 'false'}
            >
              <svg class:list={['sidebar-chevron w-2.5 h-2.5 flex-shrink-0 transition-transform duration-200', showChildren ? 'rotate-90' : '']} fill="currentColor" viewBox="0 0 8 12">
                <path d="M0 0l8 6-8 6z"/>
              </svg>
              {item.label}
            </button>
          ) : (
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-2 py-2.5 px-3 text-sm font-medium border-b border-vizon/15 no-underline transition-colors',
                active
                  ? `${activeBg} text-white`
                  : `text-lacivert ${hoverText} hover:bg-gray-50`,
              ]}
            >
              {hasChildren ? (
                <svg class:list={['w-2.5 h-2.5 flex-shrink-0 transition-transform', childActive ? 'rotate-90' : '']} fill="currentColor" viewBox="0 0 8 12">
                  <path d="M0 0l8 6-8 6z"/>
                </svg>
              ) : (
                <svg class="w-2.5 h-2.5 flex-shrink-0 opacity-60" fill="currentColor" viewBox="0 0 8 12">
                  <path d="M0 0l8 6-8 6z"/>
                </svg>
              )}
              {item.label}
            </a>
          )}
          {hasChildren && (
            <ul class:list={['list-none sidebar-children', !showChildren && 'hidden']}>
              {item.children!.map(child => (
                <li>
                  <a
                    href={child.href}
                    class:list={[
                      'block py-2 pl-10 pr-3 text-sm border-b border-vizon/10 no-underline transition-colors',
                      isActive(child)
                        ? `${activeChildText} font-medium`
                        : `text-body ${hoverText}`,
                    ]}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      );
    })}
  </ul>
</aside>

<script>
  document.querySelectorAll('.sidebar-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const children = btn.parentElement?.querySelector('.sidebar-children');
      const chevron = btn.querySelector('.sidebar-chevron');
      if (!children) return;
      children.classList.toggle('hidden');
      chevron?.classList.toggle('rotate-90');
    });
  });
</script>
