---
const mainNav = [
  { label: 'Anasayfa', href: '/' },
  {
    label: 'İlim · Bilme',
    href: '#',
    children: [
      [
        { label: 'Nişangah', href: '/#nisangah' },
        { label: "MTO'dan Mesaj", href: '/#mto-mesaj' },
        { label: 'Akademi', href: '/#akademi' },
        { label: 'Şehir Temsilcilikleri', href: '/#sehir-temsilcilikleri' },
        { label: 'MTO Bülten', href: '/#mto-bulten' },
        { label: 'SSS', href: '/#sss' },
      ],
      [
        { label: 'Akademik Takvim', href: '/#akademik-takvim' },
        { label: 'Akademik Kadro', href: '/#akademik' },
        { label: 'Ders Programları', href: '/ders-programi' },
      ],
    ],
  },
  {
    label: 'İrfan · Bulma',
    href: '#',
    children: [
      [
        { label: 'Dersler', href: '/#dersler' },
        { label: '100 Kitap Listesi', href: '/100-kitap' },
        { label: '4 Kalem Tekniği', href: '/#dort-kalem' },
      ],
    ],
  },
  {
    label: 'Hikmet · Olma',
    href: '#',
    children: [
      [
        { label: 'Eğitimler', href: '/#egitimler' },
        { label: 'Videolar', href: '/#videolar' },
      ],
    ],
  },
  { label: 'İletişim', href: '/#iletisim-bolum' },
];
---

<header class="sticky top-0 z-50 bg-white shadow-[0_2px_20px_rgba(0,0,0,0.08)]">
  <div class="max-w-[1280px] mx-auto flex items-center justify-between px-8 lg:px-12 h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline">
      <img src="/images/mto-footer-logo.png" alt="MTO Logo" class="h-14 w-auto object-contain" />
    </a>

    <!-- Nav Desktop -->
    <nav class="hidden lg:flex items-center h-full">
      {mainNav.map((item, i) => (
        <>
          <div class="relative group h-full flex items-center">
            <a
              href={item.href}
              class:list={[
                'no-underline text-[13px] font-medium uppercase tracking-[1.2px] py-7 px-4 border-b-[3px] transition-all duration-300 font-body flex items-center gap-1',
                item.href === '/'
                  ? 'text-lacivert border-turkuaz font-bold'
                  : 'text-body border-transparent hover:text-lacivert hover:border-turkuaz',
              ]}
            >
              {item.label}
              {item.children && (
                <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              )}
            </a>

            {/* Mega Dropdown */}
            {item.children && (
              <div class="absolute top-full left-0 pt-0 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-200 z-50">
                <div class="bg-white/95 backdrop-blur-md border border-gray-200 rounded-lg shadow-xl p-6 min-w-[280px] flex gap-10">
                  {item.children.map((col) => (
                    <div class="space-y-1">
                      {col.map((link) => (
                        <a
                          href={link.href}
                          class="block py-1.5 px-2 text-sm text-body hover:text-turkuaz hover:bg-turkuaz/5 rounded-md transition-colors no-underline font-body whitespace-nowrap"
                        >
                          {link.label}
                        </a>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
          {i < mainNav.length - 1 && (
            <span class="w-px h-4 bg-gray-200"></span>
          )}
        </>
      ))}
    </nav>

    <!-- Right -->
    <div class="flex items-center gap-3">
      <!-- Social -->
      <div class="hidden md:flex gap-1">
        <a href="https://twitter.com/Mtokurumsal" target="_blank" rel="noopener" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="X">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://instagram.com/Mtokurumsal" target="_blank" rel="noopener" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="Instagram">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M12 2c2.717 0 3.056.01 4.122.06 1.065.05 1.79.217 2.428.465.66.254 1.216.598 1.772 1.153a4.908 4.908 0 011.153 1.772c.247.637.415 1.363.465 2.428.047 1.066.06 1.405.06 4.122 0 2.717-.01 3.056-.06 4.122-.05 1.065-.218 1.79-.465 2.428a4.883 4.883 0 01-1.153 1.772 4.915 4.915 0 01-1.772 1.153c-.637.247-1.363.415-2.428.465-1.066.047-1.405.06-4.122.06-2.717 0-3.056-.01-4.122-.06-1.065-.05-1.79-.218-2.428-.465a4.89 4.89 0 01-1.772-1.153 4.904 4.904 0 01-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.013 15.056 2 14.717 2 12c0-2.717.01-3.056.06-4.122.05-1.066.217-1.79.465-2.428a4.88 4.88 0 011.153-1.772A4.897 4.897 0 015.45 2.525c.638-.248 1.362-.415 2.428-.465C8.944 2.013 9.283 2 12 2zm0 5a5 5 0 100 10 5 5 0 000-10zm0 8.25a3.25 3.25 0 110-6.5 3.25 3.25 0 010 6.5zm5.884-8.538a1.17 1.17 0 11-2.34 0 1.17 1.17 0 012.34 0z"/></svg>
        </a>
        <a href="https://www.youtube.com/@mtokurumsal/featured" target="_blank" rel="noopener" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="YouTube">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://t.me/yusufkaplanmedia" target="_blank" rel="noopener" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="Telegram">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        </a>
        <a href="https://sosyal.teknofest.app/@mtokurumsal" target="_blank" rel="noopener" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="Next Social">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
        </a>
      </div>

      <!-- Search & Language (taslaktaki gibi) -->
      <button class="hidden lg:grid w-8 h-8 place-items-center text-lacivert hover:text-turkuaz transition-colors" aria-label="Ara">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </button>
      <div class="hidden lg:flex items-center gap-1.5 text-xs font-medium text-body/60 ml-2">
        <span class="hover:text-turkuaz cursor-pointer transition-colors">EN</span>
        <span class="text-gray-300">|</span>
        <span class="hover:text-turkuaz cursor-pointer transition-colors">AR</span>
      </div>

      <!-- Mobile hamburger -->
      <button class="lg:hidden w-9 h-9 grid place-items-center" id="mobile-toggle" aria-label="Menü">
        <svg class="w-6 h-6 fill-lacivert" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-nav" class="lg:hidden hidden bg-white border-t border-gray-100 px-8 pb-4">
    {mainNav.map(item => (
      <>
        <a
          href={item.href}
          class:list={[
            'block py-3 text-sm font-medium uppercase tracking-wider border-b border-gray-50 no-underline font-body',
            item.href === '/' ? 'text-turkuaz font-bold' : 'text-body',
          ]}
        >
          {item.label}
        </a>
        {item.children && item.children.flat().map(sub => (
          <a href={sub.href} class="block py-2 pl-6 text-sm text-body/70 hover:text-turkuaz no-underline font-body border-b border-gray-50/50">
            {sub.label}
          </a>
        ))}
      </>
    ))}
  </nav>
</header>

<script>
  document.getElementById('mobile-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.toggle('hidden');
  });
</script>
