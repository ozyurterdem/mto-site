---
const navLinks = [
  { label: 'Anasayfa', href: '#', active: true },
  { label: 'Akademik', href: '#akademik' },
  { label: '100 Kitap', href: '/100-kitap' },
  { label: 'Faaliyetler', href: '#egitimler' },
  { label: 'Hakkımızda', href: '#hakkimizda' },
  { label: 'İletişim', href: '#iletisim' },
];
---

<header class="sticky top-0 z-50 bg-white shadow-[0_2px_20px_rgba(0,0,0,0.08)]">
  <div class="max-w-[1280px] mx-auto flex items-center justify-between px-8 lg:px-12 h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline">
      <img src="/images/mto-footer-logo.png" alt="MTO Logo" class="h-14 w-auto object-contain" />
    </a>

    <!-- Nav Desktop -->
    <nav class="hidden lg:flex items-center">
      {navLinks.map((link, i) => (
        <>
          <a
            href={link.href}
            class:list={[
              'no-underline text-[13px] font-medium uppercase tracking-[1.2px] py-7 px-4 border-b-[3px] transition-all duration-300 font-body',
              link.active
                ? 'text-lacivert border-turkuaz font-bold'
                : 'text-body border-transparent hover:text-lacivert hover:border-turkuaz',
            ]}
          >
            {link.label}
          </a>
          {i < navLinks.length - 1 && (
            <span class="w-px h-4 bg-gray-200"></span>
          )}
        </>
      ))}
    </nav>

    <!-- Right -->
    <div class="flex items-center gap-3">
      <!-- Social - küçük, sağa yasık -->
      <div class="hidden md:flex gap-1">
        <a href="#" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="X">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="#" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="Facebook">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M12 2.04c-5.5 0-10 4.49-10 10.02 0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.52 1.49-3.93 3.78-3.93 1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 008.44-9.9c0-5.53-4.5-10.02-10-10.02z"/></svg>
        </a>
        <a href="#" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="Instagram">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M12 2c2.717 0 3.056.01 4.122.06 1.065.05 1.79.217 2.428.465.66.254 1.216.598 1.772 1.153a4.908 4.908 0 011.153 1.772c.247.637.415 1.363.465 2.428.047 1.066.06 1.405.06 4.122 0 2.717-.01 3.056-.06 4.122-.05 1.065-.218 1.79-.465 2.428a4.883 4.883 0 01-1.153 1.772 4.915 4.915 0 01-1.772 1.153c-.637.247-1.363.415-2.428.465-1.066.047-1.405.06-4.122.06-2.717 0-3.056-.01-4.122-.06-1.065-.05-1.79-.218-2.428-.465a4.89 4.89 0 01-1.772-1.153 4.904 4.904 0 01-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.013 15.056 2 14.717 2 12c0-2.717.01-3.056.06-4.122.05-1.066.217-1.79.465-2.428a4.88 4.88 0 011.153-1.772A4.897 4.897 0 015.45 2.525c.638-.248 1.362-.415 2.428-.465C8.944 2.013 9.283 2 12 2zm0 5a5 5 0 100 10 5 5 0 000-10zm0 8.25a3.25 3.25 0 110-6.5 3.25 3.25 0 010 6.5zm5.884-8.538a1.17 1.17 0 11-2.34 0 1.17 1.17 0 012.34 0z"/></svg>
        </a>
        <a href="#" class="w-6 h-6 rounded-full bg-lacivert grid place-items-center hover:bg-turkuaz transition-colors" aria-label="LinkedIn">
          <svg class="w-2.5 h-2.5 fill-white" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>

      <!-- Search -->
      <button class="w-9 h-9 border-2 border-gray-200 rounded-full grid place-items-center hover:border-turkuaz transition-colors" aria-label="Ara">
        <svg class="w-4 h-4 fill-body" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27a6.5 6.5 0 001.48-5.34c-.47-2.78-2.79-5-5.59-5.34a6.505 6.505 0 00-7.27 7.27c.34 2.8 2.56 5.12 5.34 5.59a6.5 6.5 0 005.34-1.48l.27.28v.79l4.25 4.25c.41.41 1.08.41 1.49 0 .41-.41.41-1.08 0-1.49L15.5 14zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
      </button>

      <!-- Lang -->
      <div class="hidden sm:flex gap-2 text-[12px] font-medium font-body">
        <a href="#" class="text-turkuaz no-underline">Türkçe</a>
        <span class="w-px h-3 bg-gray-300 self-center"></span>
        <a href="#" class="text-gray-400 no-underline hover:text-turkuaz transition-colors">English</a>
        <span class="w-px h-3 bg-gray-300 self-center"></span>
        <a href="#" class="text-gray-400 no-underline hover:text-turkuaz transition-colors">العربية</a>
      </div>

      <!-- Mobile hamburger -->
      <button class="lg:hidden w-9 h-9 grid place-items-center" id="mobile-toggle" aria-label="Menü">
        <svg class="w-6 h-6 fill-lacivert" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-nav" class="lg:hidden hidden bg-white border-t border-gray-100 px-8 pb-4">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={[
          'block py-3 text-sm font-medium uppercase tracking-wider border-b border-gray-50 no-underline font-body',
          link.active ? 'text-turkuaz font-bold' : 'text-body',
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<script>
  document.getElementById('mobile-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.toggle('hidden');
  });
</script>
