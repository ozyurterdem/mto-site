---
// Dal renk sistemi: İlim=vizon(#B7A78F), İrfan=turuncu(#E7A54E), Hikmet=mavi(#0D619A)
const mainNav = [
  { label: 'Anasayfa', href: '/', color: '' },
  {
    label: 'İlim · Bilme',
    href: '/ilim-bilme',
    color: 'vizon',
    children: [
      [
        { label: 'Hakkımızda', href: '/ilim-bilme/hakkimizda' },
        { label: 'Nişangah', href: '/ilim-bilme/nisangah' },
        { label: "MTO'dan Mesaj", href: '/ilim-bilme/mto-mesaj' },
        { label: 'Akademi', href: '#', isHeader: true },
        { label: 'Şehir Temsilcilikleri', href: '/ilim-bilme/sehir-temsilcilikleri' },
        { label: 'MTO Bülten', href: '/ilim-bilme/mto-bulten' },
        { label: 'SSS', href: '/ilim-bilme/sss' },
      ],
      [
        { label: 'Akademik Takvim', href: '/ilim-bilme/akademik-takvim' },
        { label: 'Akademik Kadro', href: '/ilim-bilme/akademik-kadro' },
        { label: 'Şehir Temsilcilikleri', href: '/ilim-bilme/sehir-temsilcilikleri' },
        { label: 'Ders Programları', href: '/ders-programi' },
      ],
    ],
  },
  {
    label: 'İrfan · Bulma',
    href: '/irfan-bulma',
    color: 'turuncu',
    children: [
      [
        { label: 'Dersler', href: '/irfan-bulma/dersler' },
        { label: '100 Kitap Listesi', href: '/100-kitap' },
        { label: '4 Kalem Tekniği', href: '/dort-kalem' },
      ],
    ],
  },
  {
    label: 'Hikmet · Olma',
    href: '/hikmet-olma',
    color: 'mavi',
    children: [
      [
        { label: 'Kamplar', href: '/hikmet-olma/kamplar' },
        { label: 'Makaleler', href: '/hikmet-olma/makaleler' },
        { label: 'Yazılar', href: '/hikmet-olma/yazilar' },
        { label: 'Kulüpler', href: '/hikmet-olma/kulupler' },
        { label: 'Seminerler', href: '/hikmet-olma/seminerler' },
        { label: 'Faaliyetler', href: '/hikmet-olma/faaliyetler' },
      ],
    ],
  },
  { label: 'İletişim', href: '/iletisim', color: '' },
];

const socialLinks = [
  { label: 'Facebook', href: 'https://facebook.com/mtokurumsal', icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
  { label: 'X', href: 'https://x.com/mtokurumsal', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { label: 'Instagram', href: 'https://instagram.com/Mtokurumsal', icon: 'M12 2c2.717 0 3.056.01 4.122.06 1.065.05 1.79.217 2.428.465.66.254 1.216.598 1.772 1.153a4.908 4.908 0 011.153 1.772c.247.637.415 1.363.465 2.428.047 1.066.06 1.405.06 4.122 0 2.717-.01 3.056-.06 4.122-.05 1.065-.218 1.79-.465 2.428a4.883 4.883 0 01-1.153 1.772 4.915 4.915 0 01-1.772 1.153c-.637.247-1.363.415-2.428.465-1.066.047-1.405.06-4.122.06-2.717 0-3.056-.01-4.122-.06-1.065-.05-1.79-.218-2.428-.465a4.89 4.89 0 01-1.772-1.153 4.904 4.904 0 01-1.153-1.772c-.248-.637-.415-1.363-.465-2.428C2.013 15.056 2 14.717 2 12c0-2.717.01-3.056.06-4.122.05-1.066.217-1.79.465-2.428a4.88 4.88 0 011.153-1.772A4.897 4.897 0 015.45 2.525c.638-.248 1.362-.415 2.428-.465C8.944 2.013 9.283 2 12 2zm0 5a5 5 0 100 10 5 5 0 000-10zm0 8.25a3.25 3.25 0 110-6.5 3.25 3.25 0 010 6.5zm5.884-8.538a1.17 1.17 0 11-2.34 0 1.17 1.17 0 012.34 0z' },
  { label: 'YouTube', href: 'https://youtube.com/@mtobilgi', icon: 'M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/mtokurumsal', icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
];
---

<header class="sticky top-0 z-50 bg-turkuaz shadow-md">
  <div class="max-w-[1400px] mx-auto flex items-center justify-between px-6 lg:px-10 h-[75px]">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline flex-shrink-0">
      <img src="/images/mto-web-logo.png" alt="MTO Logo" class="h-14 w-auto object-contain" />
    </a>

    <!-- Nav Desktop -->
    <nav class="hidden lg:flex items-center h-full">
      {mainNav.map((item, i) => {
        const borderColor = item.color === 'vizon' ? 'border-vizon' : item.color === 'turuncu' ? 'border-turuncu' : item.color === 'mavi' ? 'border-mavi' : 'border-white';
        const hoverTextColor = item.color === 'vizon' ? 'hover:text-vizon' : item.color === 'turuncu' ? 'hover:text-turuncu' : item.color === 'mavi' ? 'hover:text-mavi' : 'hover:text-turkuaz';
        const dropdownHoverText = item.color === 'vizon' ? 'hover:text-vizon' : item.color === 'turuncu' ? 'hover:text-turuncu' : item.color === 'mavi' ? 'hover:text-mavi' : 'hover:text-turkuaz';
        const dropdownHoverBg = item.color === 'vizon' ? 'hover:bg-vizon/5' : item.color === 'turuncu' ? 'hover:bg-turuncu/5' : item.color === 'mavi' ? 'hover:bg-mavi/5' : 'hover:bg-turkuaz/5';
        const topBorderColor = item.color === 'vizon' ? 'border-t-vizon' : item.color === 'turuncu' ? 'border-t-turuncu' : item.color === 'mavi' ? 'border-t-mavi' : 'border-t-turkuaz';
        return (
        <div class="relative group h-full flex items-center">
          <a
            href={item.href}
            class:list={[
              'no-underline text-[13px] font-semibold uppercase tracking-[1.5px] py-6 px-5 border-b-[3px] border-transparent transition-all duration-300 font-body text-white flex items-center gap-1',
              `group-hover:${borderColor}`,
            ]}
            style={item.color ? `--hover-border: var(--color-${item.color})` : ''}
            data-color={item.color || ''}
          >
            {item.label}
            {item.children && (
              <svg class="w-3 h-3 opacity-70 transition-transform duration-200 group-hover:rotate-180" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            )}
          </a>

          {/* Mega Dropdown */}
          {item.children && (
            <div class="absolute top-full left-0 pt-0 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-200 z-50">
              <div class:list={[
                'bg-white/95 backdrop-blur-md border border-gray-200 rounded-b-lg shadow-xl p-6 min-w-[280px] flex gap-10 border-t-[3px]',
                topBorderColor,
              ]}>
                {item.children.map((col) => (
                  <div class="space-y-1">
                    {col.map((link: any) => (
                      link.isHeader ? (
                        <span class="block py-1.5 px-2 text-sm font-bold text-lacivert font-body">{link.label}</span>
                      ) : (
                        <a
                          href={link.href}
                          class:list={[
                            'block py-1.5 px-2 text-sm text-body rounded-md transition-colors no-underline font-body whitespace-nowrap',
                            dropdownHoverText,
                            dropdownHoverBg,
                          ]}
                        >
                          {link.label}
                        </a>
                      )
                    ))}
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )})}
    </nav>

    <!-- Right side: Social + Search + Language -->
    <div class="flex items-center gap-3">
      <!-- Social Icons -->
      <div class="hidden md:flex gap-1.5">
        {socialLinks.map(social => (
          <a href={social.href} target="_blank" rel="noopener" class="w-8 h-8 rounded-full border border-white/40 grid place-items-center hover:bg-white/20 transition-colors" aria-label={social.label}>
            <svg class="w-3.5 h-3.5 fill-white" viewBox="0 0 24 24"><path d={social.icon}/></svg>
          </a>
        ))}
      </div>

      <!-- Search -->
      <button class="hidden lg:grid w-8 h-8 place-items-center text-white hover:text-white/70 transition-colors" aria-label="Ara">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </button>

      <!-- Language -->
      <div class="hidden lg:flex items-center gap-1.5 text-xs font-semibold text-white/80 ml-1">
        <span class="hover:text-white cursor-pointer transition-colors">EN</span>
        <span class="hover:text-white cursor-pointer transition-colors">AR</span>
      </div>

      <!-- Mobile hamburger -->
      <button class="lg:hidden w-9 h-9 grid place-items-center" id="mobile-toggle" aria-label="Menü">
        <svg class="w-6 h-6 fill-white" viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-nav" class="lg:hidden hidden bg-white border-t border-gray-100 px-6 pb-4 max-h-[70vh] overflow-y-auto">
    {mainNav.map(item => {
      const mobileColor = item.color === 'vizon' ? 'text-vizon' : item.color === 'turuncu' ? 'text-turuncu' : item.color === 'mavi' ? 'text-mavi' : 'text-lacivert';
      const mobileHover = item.color === 'vizon' ? 'hover:text-vizon' : item.color === 'turuncu' ? 'hover:text-turuncu' : item.color === 'mavi' ? 'hover:text-mavi' : 'hover:text-turkuaz';
      return (
      <>
        <a
          href={item.href}
          class:list={[
            'block py-3 text-sm font-semibold uppercase tracking-wider border-b border-gray-50 no-underline font-body',
            mobileColor,
          ]}
        >
          {item.label}
        </a>
        {item.children && item.children.flat().map((sub: any) => (
          !sub.isHeader && (
            <a href={sub.href} class:list={['block py-2 pl-6 text-sm text-body/70 no-underline font-body border-b border-gray-50/50', mobileHover]}>
              {sub.label}
            </a>
          )
        ))}
      </>
    )})}
  </nav>
</header>

<script>
  document.getElementById('mobile-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.toggle('hidden');
  });
</script>
