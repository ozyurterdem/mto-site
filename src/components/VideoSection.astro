---
---

<section class="py-20 px-8 lg:px-12 bg-white">
  <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- Video Frame -->
    <div class="relative rounded-2xl overflow-hidden aspect-[16/10] bg-lacivert">
      <img
        src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&q=80"
        alt="Video"
        class="w-full h-full object-cover opacity-70"
        loading="lazy"
      />
      <div class="absolute top-5 left-5 w-[60px] h-[60px] bg-white/90 rounded-xl grid place-items-center shadow-lg cursor-pointer hover:bg-white transition-colors">
        <svg class="w-6 h-6 fill-lacivert ml-0.5" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      </div>
      <div class="absolute -bottom-5 -right-5 w-[55%] aspect-[4/3] rounded-xl overflow-hidden border-4 border-white shadow-[0_8px_30px_rgba(0,0,0,0.2)]">
        <img
          src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=400&q=80"
          alt="Video 2"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Info -->
    <div>
      <h2 class="font-heading text-3xl text-lacivert uppercase tracking-wider mb-6 font-bold">
        YouTube<br/>Video Bölümü
      </h2>
      <p class="text-body leading-[1.8] text-[0.95rem] mb-4">
        Medeniyet Tasavvuru Okulu'nun akademik içeriklerini, ders özetlerini ve söyleşileri
        YouTube kanalımızdan takip edebilirsiniz. Her hafta yeni içerikler yayınlanmaktadır.
      </p>
      <p class="text-body leading-[1.8] text-[0.95rem]">
        Derslere katılamadığınız zamanlarda kayıtlara erişim sağlayarak
        akademik gelişiminizi sürdürebilirsiniz.
      </p>
    </div>
  </div>
</section>
