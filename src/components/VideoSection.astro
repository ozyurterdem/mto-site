---
const youtubeKanalUrl = 'https://www.youtube.com/@mtokurumsal/featured';
---

<section class="py-20 px-8 lg:px-12 bg-white">
  <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- Video Frame -->
    <a
      href={youtubeKanalUrl}
      target="_blank"
      rel="noopener"
      class="group relative rounded-2xl overflow-hidden aspect-video bg-lacivert shadow-[0_8px_30px_rgba(0,0,0,0.15)] block no-underline"
    >
      <div class="absolute inset-0 bg-gradient-to-br from-lacivert via-lacivert-light to-mavi"></div>
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 20px 20px;"></div>
      <div class="relative w-full h-full flex items-center justify-center">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-4 bg-turkuaz/20 border-2 border-turkuaz rounded-full grid place-items-center group-hover:bg-turkuaz group-hover:scale-110 transition-all duration-300">
            <svg class="w-8 h-8 fill-turkuaz group-hover:fill-white ml-1 transition-colors duration-300" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <p class="text-white/70 text-sm font-heading font-medium group-hover:text-turkuaz transition-colors">YouTube Kanalına Git</p>
        </div>
      </div>
    </a>

    <!-- Info -->
    <div>
      <div class="text-turkuaz text-sm uppercase tracking-[3px] font-medium mb-3">Videolarımız</div>
      <h2 class="font-heading text-3xl text-lacivert uppercase tracking-wider mb-6 font-bold">
        YouTube Kanalımız
      </h2>
      <p class="text-body leading-[1.8] text-[0.95rem] mb-4">
        Medeniyet Tasavvuru Okulu'nun akademik içeriklerini, ders özetlerini ve söyleşileri
        YouTube kanalımızdan takip edebilirsiniz.
      </p>
      <p class="text-body leading-[1.8] text-[0.95rem] mb-8">
        Derslere katılamadığınız zamanlarda kayıtlara erişim sağlayarak
        akademik gelişiminizi sürdürebilirsiniz.
      </p>
      <a
        href={youtubeKanalUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-8 py-3.5 bg-lacivert text-white no-underline font-bold text-sm uppercase tracking-[1.5px] rounded hover:bg-turkuaz transition-all duration-300"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        Kanala Git
      </a>
    </div>
  </div>
</section>
