---
// Gerçek isimler girildiğinde burayı güncelle
const kadro = [
  { isim: 'Hoca Adı', unvan: 'Prof. Dr.', alan: 'İslam Felsefesi', initials: 'HA' },
  { isim: 'Hoca Adı', unvan: 'Doç. Dr.', alan: 'Medeniyet Tarihi', initials: 'HA' },
  { isim: 'Hoca Adı', unvan: 'Dr. Öğr. Üyesi', alan: 'Kelam ve Akaid', initials: 'HA' },
];
---

<section id="akademik" class="py-20 px-5 md:px-8" style="background: linear-gradient(180deg, #03253A 60%, #f5f7fa 60%);">
  <div class="text-center mb-12">
    <div class="text-turkuaz text-sm uppercase tracking-[3px] font-medium mb-3">Eğitim Kadromuz</div>
    <h2 class="font-heading text-[clamp(1.8rem,3vw,2.6rem)] text-white uppercase tracking-wider font-bold">
      Akademik Kadro
    </h2>
  </div>

  <div class="max-w-[1000px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
    {kadro.map(item => (
      <div class="bg-white/[0.08] border border-white/[0.12] backdrop-blur-[10px] rounded-xl p-8 transition-all duration-300 hover:bg-white/[0.14] hover:-translate-y-1 text-center">
        <!-- Fotoğraf placeholder -->
        <div class="w-24 h-24 mx-auto mb-5 rounded-full bg-lacivert-light border-2 border-turkuaz grid place-items-center overflow-hidden">
          <!-- Gerçek fotoğraf eklendiğinde img ile değiştir -->
          <span class="text-turkuaz font-heading font-bold text-2xl">{item.initials}</span>
        </div>
        <div class="text-vizon text-xs uppercase tracking-wider mb-1">{item.unvan}</div>
        <h3 class="text-white text-lg font-bold font-heading mb-2">{item.isim}</h3>
        <div class="w-10 h-[2px] bg-turkuaz mx-auto mb-3"></div>
        <p class="text-gray-400 text-sm">{item.alan}</p>
      </div>
    ))}
  </div>
</section>
