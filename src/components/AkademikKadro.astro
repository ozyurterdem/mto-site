---
const kadro = [
  { name: 'SAAADETTİN ACAR', ders: 'Öncüler' },
  { name: 'KASIM KÜÇÜKALP', ders: 'Klasikten Çağdaşa Batı Düşüncesinin Serüveni' },
  { name: 'TAHSİN GÖRGÜN', ders: 'Düşünce Tarihi' },
  { name: 'YÜCEL ARZEN', ders: 'Sesin Nefesi: Nefesin Sesi' },
  { name: 'AHMET DAĞ', ders: 'Yapay Zekâ, İslâm ve Etik' },
];
---

<section class="py-16 px-6 bg-gradient-to-b from-white to-gray-50">
  <div class="max-w-[1200px] mx-auto">
    <!-- Header -->
    <div class="flex items-end justify-between mb-10">
      <div>
        <span class="text-turkuaz text-xs font-bold uppercase tracking-[0.2em] font-heading">İlim · Bilme</span>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-lacivert mt-1">Akademik Kadro</h2>
        <p class="text-lacivert/60 font-body mt-2 max-w-xl">Medeniyet bilinciyle hareket eden, ilmî karakter ve düşünme disiplini kazandıran öncüler.</p>
      </div>
      <a href="/ilim-bilme/akademik-kadro" class="hidden md:inline-flex items-center gap-2 text-sm font-semibold text-turkuaz hover:text-mavi transition-colors font-heading whitespace-nowrap">
        Tümünü Gör
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Faculty Cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {kadro.map((hoca, i) => (
        <div class="group relative bg-white rounded-xl border border-lacivert/8 p-5 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <!-- Avatar -->
          <div class="w-14 h-14 rounded-full bg-lacivert/8 flex items-center justify-center mb-4 group-hover:bg-turkuaz/10 transition-colors">
            <svg class="w-7 h-7 text-lacivert/30 group-hover:text-turkuaz transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
          </div>
          <!-- Info -->
          <h3 class="font-heading text-xs font-bold text-lacivert leading-tight mb-1">{hoca.name}</h3>
          <p class="text-[0.7rem] text-lacivert/50 font-body leading-snug">{hoca.ders}</p>
          <!-- Accent line -->
          <div class="absolute bottom-0 left-4 right-4 h-0.5 bg-turkuaz rounded-full scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </div>
      ))}
    </div>

    <!-- Mobile CTA -->
    <div class="mt-8 text-center md:hidden">
      <a href="/ilim-bilme/akademik-kadro" class="inline-flex items-center gap-2 text-sm font-semibold text-turkuaz hover:text-mavi transition-colors font-heading">
        Tümünü Gör
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>
