---
const kadrolar = [
  { baslik: 'Akademik Kadro 01', resim: '/images/kadro/akademik-kadro-01.jpg' },
  { baslik: 'Akademik Kadro 02', resim: '/images/kadro/akademik-kadro-02.jpg' },
];
---

<section id="akademik" class="py-20 px-5 md:px-8 lg:px-12 bg-lacivert">
  <div class="max-w-[1100px] mx-auto">

    <!-- Başlık -->
    <div class="text-center mb-14">
      <div class="text-turkuaz text-sm uppercase tracking-[3px] font-medium mb-3">Eğitim Kadromuz</div>
      <h2 class="font-heading text-[clamp(1.8rem,3vw,2.6rem)] text-white uppercase tracking-wider font-bold">
        Akademik Kadro
      </h2>
      <div class="w-16 h-[2px] bg-turkuaz mx-auto mt-4"></div>
    </div>

    <!-- Kadro Görselleri -->
    <div class="flex flex-col gap-8">
      {kadrolar.map(item => (
        <div class="rounded-xl overflow-hidden shadow-[0_8px_24px_rgba(0,0,0,0.2)]">
          <img
            src={item.resim}
            alt={item.baslik}
            class="w-full h-auto"
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>

  </div>
</section>
