---
import { socialLinks } from '../data/social-links';
import { t, localePath, defaultLocale, tArray, type Locale } from '../i18n/index';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;

const navLinks = tArray(locale, 'footer.navLinks');
---

<footer class="bg-lacivert text-white">
  <!-- Üst satır: Logo + Email | Sosyal İkonlar (ortada) | Nav -->
  <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
    <!-- Logo + İletişim -->
    <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
      <a href={localePath(locale, '/')}>
        <img src="/images/mto-web-logo.png" alt="MTO — Medeniyet Tasavvuru Okulu" class="h-10 w-auto object-contain flex-shrink-0" />
      </a>
      <div class="hidden sm:block h-8 w-px bg-white/20"></div>
      <div class="flex flex-col gap-1.5 text-xs text-white/70">
        <a href="mailto:medeniyetasavvuruokulu@gmail.com" class="flex items-center justify-center sm:justify-start gap-1.5 hover:text-white transition-colors no-underline">
          <svg class="w-3.5 h-3.5 fill-white/50 flex-shrink-0" viewBox="0 0 24 24">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          medeniyetasavvuruokulu@gmail.com
        </a>
        <a href="mailto:mtokurumsal@gmail.com" class="flex items-center justify-center sm:justify-start gap-1.5 hover:text-white transition-colors no-underline">
          <svg class="w-3.5 h-3.5 fill-white/50 flex-shrink-0" viewBox="0 0 24 24">
            <path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/>
          </svg>
          mtokurumsal@gmail.com
        </a>
      </div>
    </div>

    <!-- Sosyal İkonlar (ortada) -->
    <div class="flex items-center gap-2.5">
      {socialLinks.map(social => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener"
          class="w-8 h-8 border border-white/20 rounded-full grid place-items-center hover:border-white/50 hover:bg-white/10 transition-all group"
          aria-label={social.label}
        >
          <svg class="w-3.5 h-3.5 fill-white/50 group-hover:fill-white transition-colors" viewBox="0 0 24 24">
            <path d={social.icon}/>
          </svg>
        </a>
      ))}
    </div>

    <!-- Nav -->
    <nav class="flex items-center gap-5 text-sm">
      {navLinks.map((link: { label: string; href: string }) => (
        <a href={link.href} class="text-white/70 no-underline hover:text-white transition-colors font-body">
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Alt çizgi -->
  <div class="border-t border-white/10">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/50">
      <span>{t(locale, 'footer.copyright')}</span>
      <div class="flex items-center gap-1 text-white/25 text-[10px]">
        <span>{t(locale, 'footer.designBy')}</span>
        <a href="https://erdemozyurt.com" target="_blank" rel="noopener" class="hover:text-white/50 transition-colors">Erdem Özyurt</a>
        <span>·</span>
        <a href="https://siberkale.com" target="_blank" rel="noopener" class="hover:text-white/50 transition-colors">SiberKale</a>
      </div>
    </div>
  </div>
</footer>
