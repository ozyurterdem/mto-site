---

<footer class="bg-turkuaz text-white pt-16 px-6 lg:px-12">
  <div class="max-w-[1200px] mx-auto grid grid-cols-1 md:grid-cols-[1.5fr_1fr] gap-12">
    <!-- Col 1: Logo + Contact -->
    <div>
      <div class="mb-6">
        <img src="/images/mto-web-logo.png" alt="MTO — Medeniyet Tasavvuru Okulu" class="h-14 w-auto object-contain" />
      </div>
      <div class="w-[60px] h-px bg-white/30 my-6"></div>
      <div class="flex flex-col gap-3 text-sm text-white/90">
        <div class="flex items-center gap-2.5">
          <svg class="w-[18px] h-[18px] fill-white flex-shrink-0" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          medeniyetasavvuruokulu@gmail.com
        </div>
        <div class="flex items-center gap-2.5">
          <svg class="w-[18px] h-[18px] fill-white flex-shrink-0" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          mtokurumsal@gmail.com
        </div>
      </div>
    </div>

    <!-- Col 2: Nav -->
    <div>
      <h4 class="text-white text-[0.85rem] font-bold uppercase tracking-[2px] mb-6 font-heading">Keşfetmek</h4>
      <ul class="list-none flex flex-col gap-2.5">
        {navLinks.map(link => (
          <li><a href={link.href} class="text-white/80 no-underline text-sm hover:text-white transition-colors font-body">{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom -->
  <div class="max-w-[1200px] mx-auto mt-12 py-6 border-t border-white/20 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/70">
    <span>&copy; 2025–2026 Medeniyet Tasavvuru Okulu — Tüm hakları saklıdır.</span>
    <div class="flex gap-2.5">
      {socialLinks.map(social => (
        <a href={social.href} target="_blank" rel="noopener" class="w-8 h-8 border border-white/30 rounded-full grid place-items-center hover:border-white hover:bg-white/10 transition-all group" aria-label={social.label}>
          <svg class="w-3.5 h-3.5 fill-white/70 group-hover:fill-white" viewBox="0 0 24 24"><path d={social.icon}/></svg>
        </a>
      ))}
    </div>
  </div>
</footer>
