---
import { socialLinks } from '../data/social-links';
import { t, localePath, defaultLocale, tArray, type Locale } from '../i18n/index';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;

const navLinks = tArray(locale, 'footer.navLinks');

const quickLinks = [
  { label: 'Ders Programı', href: localePath(locale, '/ders-programi') },
  { label: 'Akademik Kadro', href: localePath(locale, '/ilim-bilme/akademik-kadro') },
  { label: 'Hakkımızda', href: localePath(locale, '/ilim-bilme/hakkimizda') },
  { label: '100 Kitap', href: localePath(locale, '/100-kitap') },
  { label: 'SSS', href: localePath(locale, '/ilim-bilme/sss') },
  { label: 'İletişim', href: localePath(locale, '/iletisim') },
];

const programLinks = [
  { label: 'İlim · Bilme', href: localePath(locale, '/ilim-bilme') },
  { label: 'İrfan · Bulma', href: localePath(locale, '/irfan-bulma') },
  { label: 'Hikmet · Olma', href: localePath(locale, '/hikmet-olma') },
  { label: 'Dört Kalem', href: localePath(locale, '/dort-kalem') },
];
---

<footer class="relative bg-lacivert text-white overflow-hidden">
  <!-- Dekoratif üst çizgi -->
  <div class="h-[3px] bg-gradient-to-r from-transparent via-turkuaz to-transparent"></div>

  <!-- Dekoratif arka plan deseni -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.03]">
    <div class="absolute top-10 left-10 w-72 h-72 rounded-full border border-white"></div>
    <div class="absolute bottom-10 right-10 w-56 h-56 rounded-full border border-white"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 rounded-full border border-white"></div>
  </div>

  <!-- Ana içerik -->
  <div class="relative z-10 max-w-[1200px] mx-auto px-6 lg:px-12 pt-14 pb-8">

    <!-- Üst bölüm: 4 kolon -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Kolon 1: Logo + Açıklama -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={localePath(locale, '/')} class="inline-block mb-4">
          <img src="/images/mto-web-logo.png" alt="MTO — Medeniyet Tasavvuru Okulu" class="h-11 w-auto object-contain" />
        </a>
        <p class="text-white/50 text-sm leading-relaxed mb-5 max-w-[280px]">
          İslâm medeniyetini yeniden inşa ve ihya sürecinin kavramsal çerçevesi. Bilgi, irfan ve hikmet merkezli eğitim programı.
        </p>
        <!-- Sosyal ikonlar -->
        <div class="flex items-center gap-2">
          {socialLinks.map(social => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener"
              class="w-9 h-9 border border-white/10 rounded-lg grid place-items-center hover:border-turkuaz hover:bg-turkuaz/10 transition-all duration-300 group"
              aria-label={social.label}
            >
              <svg class="w-4 h-4 fill-white/40 group-hover:fill-turkuaz transition-colors duration-300" viewBox="0 0 24 24">
                <path d={social.icon}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Kolon 2: Program -->
      <div>
        <h4 class="font-heading font-bold text-sm uppercase tracking-[2px] text-white/90 mb-5 flex items-center gap-2">
          <span class="w-5 h-[2px] bg-turkuaz rounded-full"></span>
          Program
        </h4>
        <ul class="space-y-3">
          {programLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/50 text-sm no-underline hover:text-turkuaz hover:translate-x-1 transition-all duration-300 inline-flex items-center gap-2">
                <svg class="w-3 h-3 fill-turkuaz/50" viewBox="0 0 24 24"><path d="M10 17l5-5-5-5v10z"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kolon 3: Hızlı Linkler -->
      <div>
        <h4 class="font-heading font-bold text-sm uppercase tracking-[2px] text-white/90 mb-5 flex items-center gap-2">
          <span class="w-5 h-[2px] bg-turkuaz rounded-full"></span>
          Keşfet
        </h4>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/50 text-sm no-underline hover:text-turkuaz hover:translate-x-1 transition-all duration-300 inline-flex items-center gap-2">
                <svg class="w-3 h-3 fill-turkuaz/50" viewBox="0 0 24 24"><path d="M10 17l5-5-5-5v10z"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kolon 4: İletişim -->
      <div>
        <h4 class="font-heading font-bold text-sm uppercase tracking-[2px] text-white/90 mb-5 flex items-center gap-2">
          <span class="w-5 h-[2px] bg-turkuaz rounded-full"></span>
          İletişim
        </h4>
        <div class="space-y-4">
          <a href="mailto:medeniyetasavvuruokulu@gmail.com" class="flex items-start gap-3 text-white/50 text-sm no-underline hover:text-turkuaz transition-colors duration-300 group">
            <div class="w-8 h-8 rounded-lg bg-white/5 grid place-items-center flex-shrink-0 group-hover:bg-turkuaz/10 transition-colors duration-300">
              <svg class="w-4 h-4 fill-white/40 group-hover:fill-turkuaz transition-colors duration-300" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <span class="pt-1.5 break-all leading-tight">medeniyetasavvuruokulu<wbr>@gmail.com</span>
          </a>
          <a href="mailto:mtokurumsal@gmail.com" class="flex items-start gap-3 text-white/50 text-sm no-underline hover:text-turkuaz transition-colors duration-300 group">
            <div class="w-8 h-8 rounded-lg bg-white/5 grid place-items-center flex-shrink-0 group-hover:bg-turkuaz/10 transition-colors duration-300">
              <svg class="w-4 h-4 fill-white/40 group-hover:fill-turkuaz transition-colors duration-300" viewBox="0 0 24 24">
                <path d="M22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6zm-2 0l-8 5-8-5h16zm0 12H4V8l8 5 8-5v10z"/>
              </svg>
            </div>
            <span class="pt-1.5 break-all leading-tight">mtokurumsal@gmail.com</span>
          </a>
        </div>
      </div>

    </div>

    <!-- Ayırıcı -->
    <div class="mt-12 mb-6 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

    <!-- Alt satır -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/35">
      <span>{t(locale, 'footer.copyright')}</span>
      <div class="flex items-center gap-1.5">
        <span>{t(locale, 'footer.designBy')}</span>
        <a href="https://erdemozyurt.com" target="_blank" rel="noopener" class="text-white/35 hover:text-turkuaz transition-colors duration-300 no-underline">Erdem Özyurt</a>
        <span class="text-white/15">·</span>
        <a href="https://siberkale.com" target="_blank" rel="noopener" class="text-white/35 hover:text-turkuaz transition-colors duration-300 no-underline">SiberKale</a>
      </div>
    </div>

  </div>
</footer>
