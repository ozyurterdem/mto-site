---
const makaleler = [
  { title: 'Medeniyet ve Tasavvur', img: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&q=80' },
  { title: 'İslâm Felsefesinde Bilgi', img: 'https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=500&q=80' },
  { title: 'Kavram ve Düşünce', img: 'https://images.unsplash.com/photo-1475721027785-f74eccf877e2?w=500&q=80' },
];
---

<section class="py-20 px-5 md:px-8 bg-gray-50">
  <h2 class="font-heading text-[clamp(1.8rem,3vw,2.6rem)] text-navy uppercase text-center tracking-[2px] mb-12">
    Makaleler
  </h2>

  <div class="max-w-[1100px] mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
    {makaleler.map(m => (
      <div class="relative rounded-xl overflow-hidden aspect-[3/4] cursor-pointer group">
        <img
          src={m.img}
          alt={m.title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy-light/50 to-blue-accent/30"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8 z-10">
          <h3 class="font-heading text-white text-xl uppercase tracking-wide">{m.title}</h3>
        </div>
      </div>
    ))}
  </div>
</section>
