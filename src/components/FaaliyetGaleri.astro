---
/**
 * Reusable faaliyet gallery — pulls from Panel API, fallback to placeholder
 */
import { getFaaliyetler, getTranslation } from '../lib/panel';

interface Props {
  tur: string;
  locale: string;
  placeholderCount?: number;
  placeholderLabel?: string;
}

const { tur, locale, placeholderCount = 12, placeholderLabel = 'Fotoğraf' } = Astro.props;

const faaliyetler = await getFaaliyetler(tur);
const hasPanelData = faaliyetler.length > 0;

// Collect all images from panel faaliyetler
const panelImages = faaliyetler.flatMap(f => {
  const imgs = [];
  if (f.kapak_url) imgs.push({ url: f.kapak_url, alt: getTranslation(f.translations, locale)?.baslik || '' });
  return imgs;
});

const placeholders = Array.from({ length: placeholderCount }, (_, i) => ({
  id: i + 1,
  alt: `${placeholderLabel} ${i + 1}`,
}));
---

{hasPanelData && faaliyetler.map(f => {
  const tr = getTranslation(f.translations, locale);
  return tr?.aciklama ? (
    <div class="mb-8 text-body text-[1.05rem] leading-[2]">
      <Fragment set:html={tr.aciklama.replace(/\n/g, '<br>')} />
    </div>
  ) : null;
})}

<div class="grid grid-cols-2 md:grid-cols-4 gap-3 not-prose">
  {(panelImages.length > 0 ? panelImages : placeholders).map((item: any) => (
    <div class="group relative aspect-square rounded-xl overflow-hidden bg-lacivert/5 hover:shadow-lg transition-all duration-300">
      {item.url ? (
        <img src={item.url} alt={item.alt} class="w-full h-full object-cover" />
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-turkuaz/10 via-lacivert/5 to-mavi/10 flex items-center justify-center">
          <div class="text-center opacity-60 group-hover:opacity-100 transition-opacity">
            <svg class="w-8 h-8 text-lacivert/30 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-lacivert/40 text-[10px] font-heading uppercase tracking-widest">{item.alt}</span>
          </div>
        </div>
      )}
    </div>
  ))}
</div>
