---

<section class="py-20 px-5 md:px-8 bg-gray-50 text-center">
  <div class="text-gray-400 text-[0.85rem] uppercase tracking-[3px] mb-2">Medeniyet Tasavvuru Okulu</div>
  <h2 class="font-heading text-[clamp(1.8rem,3vw,2.6rem)] text-navy uppercase tracking-[2px] mb-4">
    Kavram Haritası
  </h2>
  <p class="text-gray-600 max-w-[600px] mx-auto text-[0.95rem] mb-8">
    İslâm medeniyetini yeniden inşa ve ihya sürecinin kavramsal çerçevesi
  </p>

  <!-- Stages -->
  <div class="flex flex-wrap items-center justify-center gap-4 mb-8">
    <button class="kavram-stage px-5 py-2 border-2 border-gray-200 rounded text-[0.85rem] font-bold uppercase tracking-[1.5px] text-gray-600 cursor-pointer transition-all hover:border-teal hover:text-teal bg-transparent">
      Mekke · Bilme
    </button>
    <span class="text-gray-400 text-xl">→</span>
    <button class="kavram-stage px-5 py-2 border-2 border-gray-200 rounded text-[0.85rem] font-bold uppercase tracking-[1.5px] text-gray-600 cursor-pointer transition-all hover:border-teal hover:text-teal bg-transparent">
      Medine · Bulma
    </button>
    <span class="text-gray-400 text-xl">→</span>
    <button class="kavram-stage px-5 py-2 border-2 border-teal rounded text-[0.85rem] font-bold uppercase tracking-[1.5px] text-teal cursor-pointer transition-all bg-transparent">
      Medeniyet · Olma
    </button>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap justify-center gap-2 mb-12">
    {kategoriler.map(k => (
      <button
        class:list={[
          'kavram-filter flex items-center gap-1.5 px-3.5 py-1.5 border rounded-full text-xs cursor-pointer transition-all',
          k.active ? 'bg-navy text-white border-navy' : 'bg-white text-gray-600 border-gray-200 hover:border-teal hover:text-teal',
        ]}
        data-kat={k.label}
      >
        {k.color && <span class="w-2 h-2 rounded-full inline-block" style={`background:${k.color}`}></span>}
        {k.label}
      </button>
    ))}
  </div>

  <!-- Bubble Cloud -->
  <div class="kavram-cloud max-w-[1100px] mx-auto flex flex-wrap items-center justify-center gap-2 p-8 min-h-[400px]">
    {kavramlar.map(k => (
      <span
        class:list={[
          'kavram-bubble inline-flex items-center border-[1.5px] border-gray-200 rounded-full bg-white cursor-pointer transition-all shadow-[0_2px_8px_rgba(0,0,0,0.04)] hover:border-teal hover:shadow-[0_4px_16px_rgba(63,191,173,0.15)] hover:-translate-y-0.5 whitespace-nowrap',
          k.size === 'large' && 'text-lg font-bold px-6 py-2.5',
          k.size === 'normal' && 'text-sm px-5 py-2',
          k.size === 'small' && 'text-xs text-gray-400 border-gray-100 px-4 py-1.5',
        ]}
        data-kat={k.kat}
      >
        {k.ad}
      </span>
    ))}
  </div>
</section>

<script>
  // Filter functionality
  document.querySelectorAll('.kavram-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      // Active state
      document.querySelectorAll('.kavram-filter').forEach(f => {
        f.classList.remove('bg-navy', 'text-white', 'border-navy');
        f.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
      });
      btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
      btn.classList.add('bg-navy', 'text-white', 'border-navy');

      const kat = (btn as HTMLElement).dataset.kat;
      document.querySelectorAll('.kavram-bubble').forEach(bubble => {
        const bKat = (bubble as HTMLElement).dataset.kat;
        if (kat === 'Tümü' || bKat === kat) {
          (bubble as HTMLElement).style.opacity = '1';
          (bubble as HTMLElement).style.transform = '';
        } else {
          (bubble as HTMLElement).style.opacity = '0.15';
          (bubble as HTMLElement).style.transform = 'scale(0.9)';
        }
      });
    });
  });

  // Stage click
  document.querySelectorAll('.kavram-stage').forEach(stage => {
    stage.addEventListener('click', () => {
      document.querySelectorAll('.kavram-stage').forEach(s => {
        s.classList.remove('border-teal', 'text-teal');
        s.classList.add('border-gray-200', 'text-gray-600');
      });
      stage.classList.remove('border-gray-200', 'text-gray-600');
      stage.classList.add('border-teal', 'text-teal');
    });
  });
</script>
