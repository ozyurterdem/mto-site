---
import { t, defaultLocale, type Locale } from '../i18n/index';
import { extendedSocialLinks as socialLinks } from '../data/social-links';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;
---

<main class="min-h-screen">
  <!-- Hero Banner -->
  <section class="relative bg-lacivert pt-24 pb-20 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-16 left-16 w-80 h-80 rounded-full border border-turkuaz/10"></div>
      <div class="absolute top-32 right-24 w-[420px] h-[420px] rounded-full border border-turkuaz/5"></div>
      <div class="absolute -bottom-16 left-1/4 w-64 h-64 rounded-full border border-turkuaz/8"></div>
    </div>
    <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-turkuaz/8 to-transparent pointer-events-none"></div>
    <div class="absolute right-0 top-1/2 -translate-y-1/2 w-[500px] h-[500px] pointer-events-none hidden lg:block">
      <img src="/images/medrese-mesaj.png" alt="" class="w-full h-full object-contain opacity-20" />
    </div>

    <div class="relative max-w-[1100px] mx-auto px-6 lg:px-12 text-center">
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full border border-turkuaz/30 bg-turkuaz/10 mb-8">
        <div class="w-2 h-2 rounded-full bg-turkuaz animate-pulse"></div>
        <span class="text-turkuaz text-xs uppercase tracking-[3px] font-semibold font-body">{t(locale, 'iletisim.badge')}</span>
      </div>
      <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold text-white uppercase tracking-wider mb-6">
        {t(locale, 'iletisim.title')}
      </h1>
      <p class="text-white/60 font-body text-lg max-w-xl mx-auto leading-relaxed">
        {t(locale, 'iletisim.subtitle')}
      </p>

      <div class="grid md:grid-cols-2 gap-5 mt-14 text-left">
        <a href="mailto:medeniyetasavvuruokulu@gmail.com" class="group block p-5 rounded-2xl bg-lacivert-light border border-turkuaz/15 hover:border-turkuaz/40 hover:bg-lacivert-light/80 transition-all duration-300 no-underline">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-turkuaz/15 grid place-items-center flex-shrink-0 group-hover:bg-turkuaz/25 transition-colors">
              <svg class="w-5 h-5 text-turkuaz" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
            </div>
            <div>
              <span class="block text-turkuaz/70 text-[10px] uppercase tracking-[2px] font-body mb-0.5">{t(locale, 'iletisim.genelIletisim')}</span>
              <span class="block text-white font-body text-sm font-medium group-hover:text-turkuaz transition-colors">medeniyetasavvuruokulu@gmail.com</span>
            </div>
          </div>
        </a>
        <a href="mailto:mtokurumsal@gmail.com" class="group block p-5 rounded-2xl bg-lacivert-light border border-turkuaz/15 hover:border-turkuaz/40 hover:bg-lacivert-light/80 transition-all duration-300 no-underline">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-turkuaz/15 grid place-items-center flex-shrink-0 group-hover:bg-turkuaz/25 transition-colors">
              <svg class="w-5 h-5 text-turkuaz" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21"/>
              </svg>
            </div>
            <div>
              <span class="block text-turkuaz/70 text-[10px] uppercase tracking-[2px] font-body mb-0.5">{t(locale, 'iletisim.kurumsal')}</span>
              <span class="block text-white font-body text-sm font-medium group-hover:text-turkuaz transition-colors">mtokurumsal@gmail.com</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Form + Sosyal Medya -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-[1100px] mx-auto px-6 lg:px-12">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-3">
          <div class="text-turkuaz text-xs uppercase tracking-[3px] font-semibold font-body mb-3">{t(locale, 'iletisim.formBadge')}</div>
          <h2 class="font-heading text-3xl lg:text-4xl font-bold text-lacivert uppercase tracking-wider mb-3">
            {t(locale, 'iletisim.formTitle')}
          </h2>
          <div class="w-16 h-1 bg-turkuaz rounded-full mb-4"></div>
          <p class="text-body font-body text-sm mb-10 leading-relaxed">{t(locale, 'iletisim.formSubtitle')}</p>

          <form id="contact-form" class="space-y-6">
            <div class="grid md:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-lacivert/70 text-xs uppercase tracking-widest font-body font-medium mb-2">{t(locale, 'iletisim.labelName')}</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3.5 rounded-xl bg-gray-50 border border-gray-200 text-lacivert font-body text-sm placeholder-gray-400 focus:outline-none focus:border-turkuaz focus:ring-2 focus:ring-turkuaz/20 transition-all" placeholder={t(locale, 'iletisim.placeholderName')} />
              </div>
              <div>
                <label for="email" class="block text-lacivert/70 text-xs uppercase tracking-widest font-body font-medium mb-2">{t(locale, 'iletisim.labelEmail')}</label>
                <input type="email" id="email" name="email" required class="w-full px-4 py-3.5 rounded-xl bg-gray-50 border border-gray-200 text-lacivert font-body text-sm placeholder-gray-400 focus:outline-none focus:border-turkuaz focus:ring-2 focus:ring-turkuaz/20 transition-all" placeholder={t(locale, 'iletisim.placeholderEmail')} />
              </div>
            </div>
            <div>
              <label for="subject" class="block text-lacivert/70 text-xs uppercase tracking-widest font-body font-medium mb-2">{t(locale, 'iletisim.labelSubject')}</label>
              <select id="subject" name="subject" class="w-full px-4 py-3.5 rounded-xl bg-gray-50 border border-gray-200 text-lacivert font-body text-sm focus:outline-none focus:border-turkuaz focus:ring-2 focus:ring-turkuaz/20 transition-all appearance-none" style="background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2012%2012%22%3E%3Cpath%20fill%3D%22%2303253A%22%20d%3D%22M6%208L1%203h10z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 1rem center;">
                <option value="">{t(locale, 'iletisim.placeholderSubject')}</option>
                <option value="genel">{t(locale, 'iletisim.optGenel')}</option>
                <option value="kayit">{t(locale, 'iletisim.optKayit')}</option>
                <option value="isbirligi">{t(locale, 'iletisim.optIsbirligi')}</option>
                <option value="temsilcilik">{t(locale, 'iletisim.optTemsilcilik')}</option>
                <option value="diger">{t(locale, 'iletisim.optDiger')}</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-lacivert/70 text-xs uppercase tracking-widest font-body font-medium mb-2">{t(locale, 'iletisim.labelMessage')}</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3.5 rounded-xl bg-gray-50 border border-gray-200 text-lacivert font-body text-sm placeholder-gray-400 focus:outline-none focus:border-turkuaz focus:ring-2 focus:ring-turkuaz/20 transition-all resize-none" placeholder={t(locale, 'iletisim.placeholderMessage')}></textarea>
            </div>
            <button type="submit" class="group inline-flex items-center gap-3 px-10 py-4 rounded-xl bg-lacivert text-white font-heading font-bold text-sm uppercase tracking-widest hover:bg-turkuaz hover:text-lacivert transition-all duration-300">
              <span>{t(locale, 'iletisim.submit')}</span>
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </button>
          </form>
          <div id="success-msg" class="hidden mt-6 p-4 rounded-xl bg-turkuaz/10 border border-turkuaz/30">
            <p class="text-lacivert font-body text-sm flex items-center gap-2">
              <svg class="w-5 h-5 text-turkuaz flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              {t(locale, 'iletisim.successMsg')}
            </p>
          </div>
        </div>

        <div class="lg:col-span-2">
          <div class="text-turkuaz text-xs uppercase tracking-[3px] font-semibold font-body mb-3">{t(locale, 'iletisim.sosyalBadge')}</div>
          <h2 class="font-heading text-3xl lg:text-4xl font-bold text-lacivert uppercase tracking-wider mb-3">
            {t(locale, 'iletisim.sosyalTitle')}
          </h2>
          <div class="w-16 h-1 bg-turkuaz rounded-full mb-4"></div>
          <p class="text-body font-body text-sm mb-8 leading-relaxed">{t(locale, 'iletisim.sosyalSubtitle')}</p>
          <div class="space-y-3">
            {socialLinks.map(social => (
              <a href={social.href} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3.5 p-4 rounded-xl border border-gray-100 bg-gray-50/50 hover:bg-turkuaz/5 hover:border-turkuaz/30 transition-all duration-300 no-underline">
                <div class="w-10 h-10 rounded-lg bg-lacivert/5 grid place-items-center flex-shrink-0 group-hover:bg-turkuaz/15 transition-colors">
                  <svg class="w-4 h-4 fill-lacivert/60 group-hover:fill-turkuaz transition-colors" viewBox="0 0 24 24"><path d={social.icon}/></svg>
                </div>
                <div class="min-w-0">
                  <span class="block text-lacivert text-sm font-semibold font-body group-hover:text-turkuaz transition-colors">{social.label}</span>
                  <span class="block text-body/50 text-xs font-body truncate">{social.handle}</span>
                </div>
                <svg class="w-4 h-4 text-gray-300 ml-auto flex-shrink-0 group-hover:text-turkuaz group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-msg');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (form.querySelector('#name') as HTMLInputElement).value;
    const email = (form.querySelector('#email') as HTMLInputElement).value;
    const subject = (form.querySelector('#subject') as HTMLSelectElement).value;
    const message = (form.querySelector('#message') as HTMLTextAreaElement).value;
    const subjectText = subject || 'İletişim Formu';
    const body = `Ad Soyad: ${name}\nE-posta: ${email}\n\n${message}`;
    const mailtoLink = `mailto:medeniyetasavvuruokulu@gmail.com?subject=${encodeURIComponent(subjectText)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailtoLink;
    if (successMsg) {
      successMsg.classList.remove('hidden');
      setTimeout(() => successMsg.classList.add('hidden'), 5000);
    }
  });
</script>
