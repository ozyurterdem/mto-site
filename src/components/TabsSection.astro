---

<section class="py-16 px-5 md:px-8 bg-white">
  <div class="max-w-[900px] mx-auto">
    <!-- Tab Buttons -->
    <div class="flex">
      <button class="tab-btn active flex-1 py-[18px] px-6 border-none cursor-pointer text-sm font-bold uppercase tracking-[1.5px] flex items-center gap-3 transition-all duration-300 bg-navy text-white" data-tab="takvim">
        <span class="w-9 h-9 rounded-lg bg-teal text-white grid place-items-center text-[13px] font-bold">01</span>
        Akademik Takvim
      </button>
      <button class="tab-btn flex-1 py-[18px] px-6 border-none cursor-pointer text-sm font-bold uppercase tracking-[1.5px] flex items-center gap-3 transition-all duration-300 bg-gray-100 text-gray-600" data-tab="haberler">
        <span class="w-9 h-9 rounded-lg bg-navy-light text-white grid place-items-center text-[13px] font-bold">02</span>
        Haberler
      </button>
    </div>

    <!-- Tab Content -->
    <div class="border border-gray-200 border-t-0 p-8 min-h-[100px]">
      <div id="tab-takvim" class="tab-content">
        <p class="text-gray-600 text-[0.95rem]">
          Bahar dönemi akademik takvimi ve önemli tarihler burada listelenecektir. Kayıt dönemi, ders başlangıçları, sınav tarihleri ve özel etkinlikler...
        </p>
      </div>
      <div id="tab-haberler" class="tab-content hidden">
        <p class="text-gray-600 text-[0.95rem]">
          En güncel haberler, duyurular ve etkinlik haberleri burada yer alacaktır.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      // Reset all tabs
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('bg-navy', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-600');
        const num = b.querySelector('span');
        if (num) { num.classList.remove('bg-teal'); num.classList.add('bg-navy-light'); }
      });
      // Activate clicked
      btn.classList.remove('bg-gray-100', 'text-gray-600');
      btn.classList.add('bg-navy', 'text-white');
      const num = btn.querySelector('span');
      if (num) { num.classList.remove('bg-navy-light'); num.classList.add('bg-teal'); }

      // Show content
      document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
      const target = btn.getAttribute('data-tab');
      document.getElementById(`tab-${target}`)?.classList.remove('hidden');
    });
  });
</script>
