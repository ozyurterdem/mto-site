---
import { t, localePath, defaultLocale, type Locale } from '../i18n/index';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;
---

<section class="relative min-h-[600px] flex items-center overflow-hidden">
  <!-- BG -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-lacivert"></div>
    <!-- Dekoratif daireler -->
    <div class="absolute -right-24 -top-24 w-[500px] h-[500px] rounded-full bg-turkuaz/5"></div>
    <div class="absolute right-32 bottom-0 w-80 h-80 rounded-full bg-mavi/10"></div>
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full bg-turkuaz/3"></div>
    <!-- Izgara deseni -->
    <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(48,213,225,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(48,213,225,0.3) 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-lacivert via-lacivert/80 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-[1280px] mx-auto px-8 lg:px-12 py-16 w-full">
    <p class="text-turkuaz text-sm uppercase tracking-[3px] font-medium mb-3">{t(locale, 'hero.badge')}</p>
    <h1 class="font-heading text-white text-[clamp(1.8rem,3.5vw,2.8rem)] leading-[1.2] max-w-[640px] mb-4 uppercase tracking-wide font-bold"
      set:html={t(locale, 'hero.title').replace(/\n/g, '<br/>')}
    />
    <p class="text-white/60 text-base max-w-[500px] mb-8 leading-relaxed">
      {t(locale, 'hero.subtitle')}
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href={localePath(locale, '/ders-programi')}
        class="inline-block px-10 py-4 bg-turkuaz text-white no-underline font-bold text-sm uppercase tracking-[1.5px] rounded hover:brightness-110 hover:-translate-y-0.5 hover:shadow-[0_8px_25px_rgba(48,213,225,0.4)] transition-all duration-300"
      >
        {t(locale, 'hero.cta1')}
      </a>
      <a
        href={localePath(locale, '/ilim-bilme/akademik-kadro')}
        class="inline-block px-10 py-4 bg-transparent text-white no-underline font-bold text-sm uppercase tracking-[1.5px] rounded border-2 border-white/30 hover:border-turkuaz hover:text-turkuaz transition-all duration-300"
      >
        {t(locale, 'hero.cta2')}
      </a>
    </div>
  </div>
</section>
