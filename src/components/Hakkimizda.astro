---
---

<section id="hakkimizda" class="py-20 px-8 lg:px-12 bg-white">
  <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Sol: Metin -->
    <div>
      <div class="text-turkuaz text-sm uppercase tracking-[3px] font-medium mb-3">Bizi Tanıyın</div>
      <h2 class="font-heading text-[clamp(1.8rem,3vw,2.6rem)] text-lacivert uppercase tracking-wider mb-8 font-bold">
        Hakkımızda
      </h2>
      <p class="text-body text-[1rem] leading-[1.9] mb-6">
        Medeniyet Tasavvuru Okulu (MTO), İslâm medeniyetinin temel kavramlarını sistematik bir müfredat çerçevesinde aktarmayı amaçlayan bağımsız bir eğitim programıdır.
      </p>
      <p class="text-body text-[1rem] leading-[1.9] mb-6">
        Bilgi, irfan ve hikmet üçlüsünü merkeze alarak; tarihî birikimimizi günümüz meseleleriyle buluşturan, kavramsal düşünme yetisi kazandıran bir eğitim anlayışı benimsiyoruz.
      </p>

      <div class="grid grid-cols-2 gap-6 mt-8">
        <div class="border-l-[3px] border-turkuaz pl-4">
          <div class="font-heading text-lacivert font-bold text-lg">Vizyon</div>
          <p class="text-body text-sm leading-relaxed mt-1">Medeniyetimizin kavramsal mirasını yeni nesillere taşımak.</p>
        </div>
        <div class="border-l-[3px] border-turkuaz pl-4">
          <div class="font-heading text-lacivert font-bold text-lg">Misyon</div>
          <p class="text-body text-sm leading-relaxed mt-1">Kavramları özümseyerek hayata geçiren bireyler yetiştirmek.</p>
        </div>
      </div>
    </div>

    <!-- Sağ: Görsel -->
    <div class="relative">
      <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-gray-100">
        <!-- Gerçek görsel eklendiğinde src değiştirilecek -->
        <div class="w-full h-full bg-gradient-to-br from-lacivert to-mavi flex items-center justify-center">
          <div class="text-center text-white/60">
            <svg class="w-16 h-16 mx-auto mb-3 fill-current" viewBox="0 0 24 24"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
            <p class="text-sm">MTO Görsel</p>
          </div>
        </div>
      </div>
      <!-- Dekoratif köşe -->
      <div class="absolute -bottom-4 -left-4 w-24 h-24 border-[3px] border-turkuaz rounded-xl -z-10"></div>
    </div>
  </div>
</section>
