---
import { t, tArray, defaultLocale, type Locale } from '../i18n/index';

interface Props {
  locale?: Locale;
}
const { locale = defaultLocale } = Astro.props;

const yorumlar = tArray(locale, 'yorumlar.items') as { yorum: string; isim: string; unvan: string; initials: string }[];
---

<section class="py-20 px-8 lg:px-12 bg-white border-t-4 border-lacivert">
  <div class="max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-12 items-start">
    <div>
      <div class="text-turkuaz text-sm uppercase tracking-[3px] font-medium mb-3">{t(locale, 'yorumlar.badge')}</div>
      <h2 class="font-heading text-[2.4rem] text-lacivert uppercase tracking-wider mb-4 font-bold"
        set:html={t(locale, 'yorumlar.title').replace(/\n/g, '<br/>')}
      />
      <p class="text-body text-sm leading-relaxed mb-6">{t(locale, 'yorumlar.subtitle')}</p>
      <div class="flex gap-3">
        <button id="yorum-prev" class="w-11 h-11 border-2 border-gray-200 rounded-full bg-transparent cursor-pointer text-lg text-body hover:border-turkuaz hover:text-turkuaz transition-all" aria-label={t(locale, 'yorumlar.prevAria')}>&#8592;</button>
        <button id="yorum-next" class="w-11 h-11 border-2 border-gray-200 rounded-full bg-transparent cursor-pointer text-lg text-body hover:border-turkuaz hover:text-turkuaz transition-all" aria-label={t(locale, 'yorumlar.nextAria')}>&#8594;</button>
      </div>
    </div>

    <div class="relative overflow-hidden">
      <div id="yorum-track" class="flex transition-transform duration-500 ease-in-out" style="width: 200%;">
        {yorumlar.map(y => (
          <div class="w-1/2 flex-shrink-0 px-2.5">
            <div class="bg-gray-50 rounded-xl p-8 h-full">
              <svg class="w-8 h-8 fill-turkuaz/20 mb-4" viewBox="0 0 24 24"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
              <p class="text-body text-sm leading-relaxed mb-6">{y.yorum}</p>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-lacivert text-white grid place-items-center font-bold text-xs">
                  {y.initials}
                </div>
                <div>
                  <div class="font-bold text-lacivert text-sm">{y.isim}</div>
                  <div class="text-vizon text-xs">{y.unvan}</div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('yorum-track');
  const prevBtn = document.getElementById('yorum-prev');
  const nextBtn = document.getElementById('yorum-next');

  if (track && prevBtn && nextBtn) {
    let current = 0;
    const total = track.children.length;
    const perPage = window.innerWidth >= 768 ? 2 : 1;
    const maxSlide = Math.max(0, total - perPage);

    function updateSlide() {
      const pct = (current / total) * 100;
      (track as HTMLElement).style.transform = `translateX(-${pct}%)`;
    }

    prevBtn.addEventListener('click', () => {
      current = current > 0 ? current - 1 : maxSlide;
      updateSlide();
    });

    nextBtn.addEventListener('click', () => {
      current = current < maxSlide ? current + 1 : 0;
      updateSlide();
    });
  }
</script>
