---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="text-xs uppercase tracking-wider mb-2 font-body" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-1 list-none">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && <span class="text-gray-400">/</span>}
        {i === items.length - 1 ? (
          <span class="text-turkuaz font-medium">{item.label}</span>
        ) : (
          <a href={item.href || '#'} class="text-lacivert hover:text-turkuaz no-underline transition-colors">
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
