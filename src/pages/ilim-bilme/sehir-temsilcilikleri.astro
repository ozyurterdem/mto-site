---
import InnerPageLayout from '../../layouts/InnerPageLayout.astro'
import { ilimBilmeNav } from '../../data/navigation'

const sidebarItems = ilimBilmeNav.items.map(item => ({
  ...item,
  active: item.href === '/ilim-bilme/sehir-temsilcilikleri'
}))

const breadcrumbs = [
  { label: 'İLİM - BİLME', href: '/ilim-bilme' },
  { label: 'Şehir Temsilcilikleri' }
]

const sehirler = [
  'İstanbul',
  'Bursa',
  'Ankara',
  'Diyarbakır',
  'Erzurum',
  'Trabzon',
]
---

<InnerPageLayout
  title="Şehir Temsilcilikleri - İLİM·BİLME"
  description="Medeniyet Tasavvuru Okulu şehir temsilcilikleri ve iletişim bilgileri."
  pageTitle="Şehir Temsilcilikleri"
  sidebarTitle={ilimBilmeNav.title}
  sidebarTitleHref="/ilim-bilme"
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath="/ilim-bilme/sehir-temsilcilikleri"
>
  <!-- Content -->
  <div class="space-y-10">
    <!-- Description -->
    <div class="prose prose-lg max-w-none font-body text-lacivert/80">
      <p>
        Temsilciliklerimizin bulunduğu şehirler aşağıda verilmiştir. İletişime geçmek için
        <a href="mailto:mtokurumsal@gmail.com" class="text-turkuaz hover:text-turkuaz/80 font-semibold underline underline-offset-2">
          mtokurumsal@gmail.com
        </a>
        mail adresinden yönlendirme talep edebilirsiniz.
      </p>
    </div>

    <!-- Cities Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[0, 1, 2].map((colIndex) => (
        <div class="space-y-4">
          {sehirler.map((sehir) => (
            <div class="flex items-center gap-3 p-4 bg-lacivert/5 rounded-xl hover:bg-turkuaz/10 transition-colors group">
              <span class="font-heading font-semibold text-lacivert">{sehir}</span>
            </div>
          ))}
        </div>
      ))}
    </div>

    <!-- Contact CTA -->
    <div class="bg-gradient-to-r from-lacivert to-lacivert/90 rounded-2xl p-8 text-center">
      <h3 class="font-heading text-2xl font-bold text-white mb-3">İletişime Geçin</h3>
      <p class="font-body text-white/70 mb-6">
        Şehir temsilciliğimize ulaşmak veya yeni bir temsilcilik açmak için bizimle iletişime geçebilirsiniz.
      </p>
      <a
        href="mailto:mtokurumsal@gmail.com"
        class="inline-flex items-center gap-2 bg-turuncu hover:bg-turuncu/90 text-white font-heading font-semibold px-8 py-3 rounded-full transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
        mtokurumsal@gmail.com
      </a>
    </div>
  </div>
</InnerPageLayout>
