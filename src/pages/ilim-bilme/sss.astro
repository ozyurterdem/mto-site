---
import InnerPageLayout from '../../layouts/InnerPageLayout.astro'
import { ilimBilmeNav } from '../../data/navigation'

const sidebarItems = ilimBilmeNav.items.map(item => ({
  ...item,
  active: item.href === '/ilim-bilme/sss'
}))

const breadcrumbs = [
  { label: 'İLİM - BİLME', href: '/ilim-bilme' },
  { label: 'SSS' }
]

const sorular = [
  { q: 'Başvurular Ne Zaman Alınıyor?', a: "Her yıl Güz Dönem'nde (Eylül – Ekim) 1. Kademe Başvurusu alınırken; Bahar Dönemi'nde (Şubat – Mart) Hazırlık Dönemi başvurusu alınmaktadır. Hazırlık Dönemi zorunlu değildir. Fakat 1. Kademe Başvurusu'nı kaçıranlar ve okula dönem ortasında dahil olmak isteyen talebeler için Hazırlık Dönemi oluşturulmuştur." },
  { q: 'Başvuru Nereden ve Nasıl Yapılır?', a: 'Başvuru döneminde, erişime açtığımız başvuru form linkine web sitemizden veya sosyal medya hesaplarımızdan ulaşabilirsiniz. Başvurular eksiksiz ve doğru bir şekilde doldurulmalıdır aksi halde değerlendirmeye alınmayacaktır.' },
  { q: 'Başvuru Şartları Nelerdir?', a: "MTO'ya başvuru yapmak isteyen talebenin başvuru öncesinde 100 Kitap Listesi'nin Birinci Aşaması'nı 4 kalem tekniğiyle okumuş olması gerekir. Dört yıllık eğitim süresince de listenin tamamını okumaya söz vermelidir." },
  { q: 'Kitapları Sırasıyla ve 4 Kalem Tekniğiyle Okumak Zorunlu Mu?', a: '100 Kitap Listesi belli kıstaslar göz önünde bulundurularak hazırlanmış bir listedir. Dolayısıyla talebenin burada listeye uyması ve 4 Kalem Tekniği ile okuması alınacak verim açısından oldukça önemlidir.' },
  { q: 'Başvurularda Yaş Sınırı Var Mı?', a: 'Herhangi bir yaş sınırlaması yoktur. MTO "yaş değil baş" düsturu ile ilerler.' },
  { q: 'Başvurusunu Gerçekleştirenler Ne Yapmalıdır?', a: 'Başvurusunu yapan talebe adaylarının sonuçları belirtilen tarihte SMS ve Gmail ile iletilecektir. Talebeler bu süreçte hesaplarını kontrol etmelidir.' },
  { q: 'Başvuru Sürecini Kaçıranlar Ne Yapmalı?', a: "Güz Dönemi başvurularını kaçıran talebeler Bahar Dönemi'nde başvuru yaparak Hazırlık Dönemi'den başlayabilirler. Bahar Dönemi başvurularını kaçıran talebeler ise Güz Dönemi'ndeki başvuruları bekleyebilirler." },
  { q: 'Kayıtlı Talebelerin Başvuru Yapması Gerekir mi?', a: 'Başvurular ilk defa talebe olacaklar içindir. Başvuru bir kez yapılır, talebe olduktan sonra tekrarlanması gerekmez. Kayıtlı talebelerin ders gruplarını takip etmeleri yeterlidir.' },
  { q: 'Eğitimin Süresi Ne Kadar Olacak?', a: 'Her yıl iki dönemden oluşan MTO toplamda 3 yıllık bir eğitim sunmaktadır. Üç yılı bitiren talebeler süresiz bir şekilde ihtisas dersleri alır.' },
  { q: 'Eğitim Ücretli Mi?', a: 'Okulumuz ücretli olmayıp; aidiyetin sağlanabilmesi, talebelerin, hocaların ve okulun ihtiyaçlarını karşılamak amacıyla kayıt yenileme işlemi sırasında dönemlik 750 TL gönüllü bağış talep edilmektedir.' },
  { q: 'Eğitimi Dondurma İmkanı Var mıdır?', a: 'Okulumuzda eğitimi dondurma imkanı yoktur, yalnızca kayıt silme vardır. Talebe kaydını sildikten sonra isterse tekrar başvuru yaparak baştan başlayabilir.' },
  { q: 'Kademe Tekrarı Var Mıdır?', a: "Kademe tekrarları talebenin isteğine göre Güz Dönemi'nde yapılmaktadır. Bahar Dönemi'nde kademe tekrarı gerçekleştirilemez." },
  { q: 'Dersler Ne Zaman ve Ne Şekilde Gerçekleştirilmektedir?', a: 'Dersler her gün akşam saatlerinde WhatsApp gruplarına atılan link üzerinden online gerçekleşmektedir.' },
  { q: 'Derslere Devam Zorunluluğu Var Mı?', a: 'Derslere devamlılık alınacak verim açısından önem arz eder. Okulumuzda devamsızlık durumu yoktur. Mecburi sebeplerden ötürü zamanında katılamayan talebelere herhangi bir yaptırım uygulanmamaktadır.' },
  { q: 'Derslere Zamanında Katılamadım Sonradan İzleyebilir Miyim?', a: 'Dersler YouTube üzerinden gerçekleştiği için istediğiniz vakitte aynı linkten izleyebilirsiniz. Talebelerin dersleri indirmesi yasaktır.' },
  { q: 'Derslerden Sınav Olacak Mıyız?', a: 'Okulumuzda herhangi bir sınav uygulanmamaktadır. Talebelerin gelişimi, gönüllü olarak yazdığı yazılar ile tespit edilmektedir.' },
  { q: 'Kitaplar Nasıl Temin Edilmektedir?', a: 'Kitap sitelerinden veya kitapçılardan bireysel olarak temin edilmektedir. Sadece basımı olmayan kitaplar pdf üzerinden temin edilerek okunabilir.' },
  { q: 'Okuldan Atılma Nasıl Gerçekleşir?', a: 'Etik ve ahlak dışı hareketler işlendiğinde okuldan atılma gerçekleşir.' },
]
---

<InnerPageLayout
  title="Sıkça Sorulan Sorular — MTO"
  description="Medeniyet Tasavvuru Okulu hakkında sıkça sorulan sorular ve cevapları."
  pageTitle="SIKÇA SORULAN SORULAR"
  sidebarTitle={ilimBilmeNav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  showBulten={false}
  currentPath="/ilim-bilme/sss"
>
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_400px] gap-8">
    <!-- FAQ Accordion -->
    <div class="space-y-3" id="faq-accordion">
      {sorular.map((item, i) => (
        <div class="faq-item bg-gray-50 rounded-lg overflow-hidden">
          <button class="faq-toggle w-full flex items-center justify-between px-6 py-4 text-left hover:bg-gray-100 transition-colors">
            <span class="text-sm font-medium text-body">
              <span class="text-turkuaz font-bold mr-1">{i + 1}-</span> {item.q}
            </span>
            <svg class="faq-icon w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12M6 12h12"/>
            </svg>
          </button>
          <div class="faq-content hidden px-6 pb-4">
            <p class="text-sm text-body/80 leading-relaxed">{item.a}</p>
          </div>
        </div>
      ))}

      <div class="pt-4">
        <a href="#" class="inline-block bg-lacivert text-white font-heading font-semibold uppercase tracking-wider text-sm px-8 py-3 hover:bg-lacivert-light transition-colors">
          DEVAMINI GÖR
        </a>
      </div>
    </div>

    <!-- Right Side Image -->
    <div class="hidden lg:block">
      <div class="w-full aspect-[3/4] bg-gray-300 rounded sticky top-28"></div>
    </div>
  </div>
</InnerPageLayout>

<script>
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const content = item?.querySelector('.faq-content');
      const icon = btn.querySelector('.faq-icon');
      const isOpen = !content?.classList.contains('hidden');

      document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => i.classList.remove('rotate-45'));

      if (!isOpen) {
        content?.classList.remove('hidden');
        icon?.classList.add('rotate-45');
      }
    });
  });
</script>
