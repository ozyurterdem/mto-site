---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="E-posta Doğrulama — MTO" description="E-posta adresinizi doğrulayın.">
  <Header locale="tr" />

  <main class="min-h-[70vh] flex items-center justify-center px-4 py-16 bg-gray-50">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-8 text-center">
        <!-- Loading -->
        <div id="state-loading">
          <div class="w-12 h-12 border-4 border-turkuaz/20 border-t-turkuaz rounded-full animate-spin mx-auto mb-4"></div>
          <p class="text-sm text-body/70">E-posta doğrulanıyor...</p>
        </div>

        <!-- Success -->
        <div id="state-success" class="hidden">
          <div class="w-16 h-16 rounded-full bg-green-50 grid place-items-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h1 class="font-heading text-xl font-bold text-lacivert mb-2">E-posta Doğrulandı!</h1>
          <p class="text-sm text-body/70 mb-6">Hesabınız aktif. Artık giriş yapabilir ve yorum bırakabilirsiniz.</p>
          <a href="/giris" class="inline-block px-8 py-3 bg-turkuaz text-white rounded-xl text-sm font-bold uppercase tracking-wider hover:bg-turkuaz/90 transition-all">
            Giriş Yap
          </a>
        </div>

        <!-- Already Verified -->
        <div id="state-already" class="hidden">
          <div class="w-16 h-16 rounded-full bg-blue-50 grid place-items-center mx-auto mb-4">
            <svg class="w-8 h-8 text-turkuaz" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h1 class="font-heading text-xl font-bold text-lacivert mb-2">Zaten Doğrulanmış</h1>
          <p class="text-sm text-body/70 mb-6">E-posta adresiniz zaten doğrulanmış durumda.</p>
          <a href="/giris" class="inline-block px-8 py-3 bg-turkuaz text-white rounded-xl text-sm font-bold uppercase tracking-wider hover:bg-turkuaz/90 transition-all">
            Giriş Yap
          </a>
        </div>

        <!-- Error -->
        <div id="state-error" class="hidden">
          <div class="w-16 h-16 rounded-full bg-red-50 grid place-items-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
            </svg>
          </div>
          <h1 class="font-heading text-xl font-bold text-lacivert mb-2">Doğrulama Başarısız</h1>
          <p id="error-msg" class="text-sm text-body/70 mb-6">Bağlantı geçersiz veya süresi dolmuş olabilir.</p>
          <a href="/giris?tab=register" class="inline-block px-8 py-3 bg-lacivert text-white rounded-xl text-sm font-bold uppercase tracking-wider hover:bg-lacivert-light transition-all">
            Tekrar Kayıt Ol
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer locale="tr" />
</BaseLayout>

<script>
  import { verifyEmail } from '../lib/auth-client';

  async function doVerify() {
    const token = new URLSearchParams(window.location.search).get('token');
    
    if (!token) {
      showState('error', 'Doğrulama bağlantısı eksik.');
      return;
    }

    try {
      const msg = await verifyEmail(token);
      if (msg.includes('zaten')) {
        showState('already');
      } else {
        showState('success');
      }
    } catch (err: any) {
      showState('error', err.message || 'Doğrulama başarısız');
    }
  }

  function showState(state: string, errorMsg?: string) {
    ['loading', 'success', 'already', 'error'].forEach(s => {
      document.getElementById(`state-${s}`)?.classList.toggle('hidden', s !== state);
    });
    if (errorMsg) {
      document.getElementById('error-msg')!.textContent = errorMsg;
    }
  }

  doVerify();
</script>
