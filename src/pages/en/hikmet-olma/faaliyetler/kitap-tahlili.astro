---
import InnerPageLayout from '../../../../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../../../../data/navigation';

const breadcrumbs = [
  { label: 'Anasayfa', href: '/' },
  { label: 'HİKMET · OLMA', href: '/hikmet-olma' },
  { label: 'Faaliyetler', href: '/hikmet-olma/faaliyetler' },
  { label: 'Kitap Tahlili' },
];

const adimlar = [
  { num: '01', baslik: 'Kitap Seçimi', aciklama: 'Her dönem başında kademe müfredatıyla uyumlu kitaplar belirlenir. Talebeler okuma sürecini birlikte tamamlar.' },
  { num: '02', baslik: 'Tahlil Oturumu', aciklama: "Cuma günleri 20:00'de gerçekleşen oturumlarda her talebe kitabın bölümlerine dair notlarını ve çıkarımlarını paylaşır." },
  { num: '03', baslik: 'Ortak Çerçeve', aciklama: 'Oturum sonunda hoca rehberliğinde kitabın bütünü değerlendirilir, kavram haritası çıkarılır ve medeniyet perspektifiyle ilişkilendirilir.' },
];
const locale = 'en' as const;
const nav = getHikmetOlmaNav(locale);
---

<InnerPageLayout
  locale={locale}
  accentColor="mavi"
  pageTitle="Kitap Tahlili"
  sidebarTitle={nav.title}
  sidebarItems={nav.items}
  breadcrumbs={breadcrumbs}
  currentPath="/hikmet-olma/faaliyetler/kitap-tahlili"
  showBulten={false}
>
  <!-- Aciklama -->
  <div class="mb-10 text-body text-[1.05rem] leading-[2]">
    <p>
      Kitap Tahlili, MTO talebelerinin her hafta düzenli olarak bir araya geldiği ve belirlenen kitabı derinlemesine incelediği çalışma oturumlarıdır. Her oturumda talebeler, okunan metnin kavramsal çerçevesini çıkarır, yazarın düşünce sistemini çözümler ve kitabın medeniyet tasavvuru açısından yerine dair değerlendirmeler yapar.
    </p>
    <p class="mt-4">
      Bu buluşmalar, yalnızca bir kitabı anlamakla kalmaz; aynı zamanda tahlil yeteneği, eleştirel okuma becerisi ve fikrî ifade gücü kazandırır. Kitap Tahlili, MTO'nun "okumak, anlamak, dönüştürmek" anlayışının pratik zeminidir.
    </p>
  </div>

  <!-- Nasil Isliyor -->
  <div class="not-prose mb-10">
    <h2 class="font-heading text-xl text-lacivert font-bold uppercase tracking-wide mb-5">Nasıl İşliyor?</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {adimlar.map(adim => (
        <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
          <span class="text-3xl font-heading font-black text-turkuaz/20">{adim.num}</span>
          <h3 class="font-heading text-lacivert font-bold text-base mt-1 mb-2">{adim.baslik}</h3>
          <p class="text-body text-sm leading-relaxed">{adim.aciklama}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Bilgi Notu -->
  <div class="not-prose bg-turkuaz/5 border-l-4 border-turkuaz rounded-r-xl p-5">
    <p class="text-body text-sm leading-relaxed">
      <strong class="text-lacivert font-heading">Zaman & Yer:</strong> Her hafta Cuma günü saat 20:00'de çevrimiçi olarak gerçekleştirilmektedir. Tüm kademelerden talebeler katılabilir.
    </p>
  </div>
</InnerPageLayout>
