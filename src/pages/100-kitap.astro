---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollTop from '../components/ScrollTop.astro';
import { hundredBooks, readingCategories, categoryColors, categorySubtitles, categoryNotes } from '../data/hundred-books';

const grouped = readingCategories.map(cat => {
  const allBooks = hundredBooks.filter(b => b.category === cat);
  const mainBooks = allBooks.filter(b => !b.isReference);
  const refBooks = allBooks.filter(b => b.isReference);
  return {
    category: cat,
    subtitle: categorySubtitles[cat],
    color: categoryColors[cat],
    note: categoryNotes[cat],
    mainBooks,
    refBooks,
    totalCount: allBooks.length,
  };
});

const totalMain = hundredBooks.filter(b => !b.isReference).length;
const totalRef = hundredBooks.filter(b => b.isReference).length;
const totalAuthors = new Set(hundredBooks.map(b => b.author).filter(Boolean)).size;

const stageIcons = ['🔥', '📖', '🏛️', '💡', '🏆'];
const stageQuotes = [
  '',
  '"Bir medeniyet ancak dert sahiplerinin omuzlarında yükselir."',
  '"Bilgisiz dert, düşüncesiz bilgi, köksüz düşünce — hepsi eksiktir."',
  '"Tarihi bilmeyen, geleceği inşa edemez."',
  '"Moderniteyi anlamadan, geleneği savunamazsınız."',
  '',
];
---

<BaseLayout title="100 Kitap Listesi — Yusuf Kaplan · MTO" description="Yusuf Kaplan 100 Kitap okuma programı. Medeniyet Tasavvuru Okulu beş aşamalı okuma rehberi.">
  <Header />

  <!-- Scroll Progress Bar -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-turkuaz via-mavi to-turuncu z-[100] transition-all duration-150" style="width:0%"></div>

  <!-- Hero -->
  <section class="relative py-28 md:py-36 px-6 overflow-hidden bg-lacivert text-center">
    <!-- Animated Background -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-b from-lacivert via-lacivert/95 to-lacivert"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><rect width=%2260%22 height=%2260%22 fill=%22none%22/><path d=%22M0 30h60M30 0v60%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"></div>
      <!-- Floating orbs -->
      <div class="absolute top-20 left-[10%] w-72 h-72 bg-turkuaz/10 rounded-full blur-[100px] animate-pulse"></div>
      <div class="absolute bottom-10 right-[15%] w-96 h-96 bg-mavi/10 rounded-full blur-[120px] animate-pulse" style="animation-delay:1s"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-turuncu/5 rounded-full blur-[150px]"></div>
    </div>

    <div class="relative z-10 max-w-[900px] mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-white/[0.07] backdrop-blur-md border border-white/10 mb-8 animate-fade-in">
        <div class="w-2 h-2 rounded-full bg-turkuaz animate-ping-slow"></div>
        <span class="text-sm font-medium text-vizon uppercase tracking-[0.2em]">Yusuf Kaplan · Medeniyet Tasavvuru Okulu</span>
      </div>

      <!-- Title -->
      <h1 class="animate-fade-in-up" style="animation-delay:0.1s">
        <span class="block font-heading text-vizon/60 text-lg md:text-xl font-medium uppercase tracking-[0.3em] mb-3">Okuma Programı</span>
        <span class="block font-heading text-white text-[clamp(3rem,8vw,6.5rem)] font-black uppercase tracking-tight leading-[0.85]">100</span>
        <span class="block font-heading text-white text-[clamp(2rem,5vw,4rem)] font-bold uppercase tracking-[0.15em] -mt-2">Kitap</span>
      </h1>

      <p class="text-vizon/80 text-lg md:text-xl leading-relaxed max-w-[550px] mx-auto mt-8 mb-12 animate-fade-in-up" style="animation-delay:0.2s">
        Beş aşamalı okuma yolculuğu ile dert sahibi olmaktan klasiklere uzanan bir medeniyet inşası
      </p>

      <!-- Stats Cards -->
      <div class="flex flex-wrap justify-center gap-4 md:gap-6 animate-fade-in-up" style="animation-delay:0.3s">
        <div class="group relative px-6 py-5 rounded-2xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-4xl font-black text-white mb-1" id="counter-main">0</div>
          <div class="text-xs text-vizon/60 uppercase tracking-[0.2em]">Ana Eser</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-turkuaz to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-6 py-5 rounded-2xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-4xl font-black text-white mb-1" id="counter-ref">0</div>
          <div class="text-xs text-vizon/60 uppercase tracking-[0.2em]">Referans</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-mavi to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-6 py-5 rounded-2xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-4xl font-black text-white mb-1" id="counter-authors">0</div>
          <div class="text-xs text-vizon/60 uppercase tracking-[0.2em]">Yazar</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-turuncu to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-6 py-5 rounded-2xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-4xl font-black text-white mb-1">5</div>
          <div class="text-xs text-vizon/60 uppercase tracking-[0.2em]">Aşama</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-vizon to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="mt-16 animate-bounce-slow">
        <svg class="w-6 h-6 mx-auto text-vizon/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Roadmap Overview -->
  <section class="py-12 px-6 bg-white border-b border-gray-100">
    <div class="max-w-[1100px] mx-auto">
      <div class="flex items-center justify-between overflow-x-auto gap-2 pb-2">
        {grouped.map((g, i) => (
          <a href={`#asama-${i + 1}`} class="group flex-1 min-w-[140px] no-underline">
            <div class="relative p-4 rounded-2xl border-2 border-transparent hover:border-gray-200 transition-all text-center">
              <!-- Progress line -->
              {i < grouped.length - 1 && (
                <div class="absolute top-1/2 -right-1 w-2 h-0.5 bg-gray-200 hidden md:block"></div>
              )}
              <div class="text-2xl mb-2">{stageIcons[i]}</div>
              <div class="font-heading font-bold text-sm text-lacivert uppercase tracking-wide">{g.category.replace('Aşama', '').trim()}</div>
              <div class="text-[0.65rem] font-medium mt-1 uppercase tracking-wider" style={`color: ${g.color}`}>{g.subtitle}</div>
              <div class="flex items-center justify-center gap-1 mt-2">
                <div class="w-full h-1.5 rounded-full bg-gray-100 overflow-hidden">
                  <div class="h-full rounded-full transition-all duration-700" style={`background: ${g.color}; width: ${(g.mainBooks.length / totalMain) * 100}%`}></div>
                </div>
                <span class="text-[0.6rem] text-body/50 font-medium ml-1">{g.mainBooks.length}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sticky Nav -->
  <section class="sticky top-0 z-40 bg-white/95 backdrop-blur-md border-b border-gray-200/80 shadow-sm py-3 px-6">
    <div class="max-w-[1100px] mx-auto flex flex-wrap justify-center gap-2">
      {grouped.map((g, i) => (
        <a
          href={`#asama-${i + 1}`}
          class="nav-link group flex items-center gap-2 px-3.5 py-2 rounded-xl text-sm font-medium transition-all hover:shadow-md no-underline"
          data-stage={i + 1}
          style={`color: ${g.color};`}
        >
          <div class="w-7 h-7 rounded-lg grid place-items-center text-white text-xs font-bold transition-all group-hover:scale-110 group-hover:shadow-md" style={`background: ${g.color}`}>
            {i + 1}
          </div>
          <span class="hidden md:inline font-semibold">{g.category}</span>
          <span class="text-[0.65rem] opacity-50 font-medium">{g.mainBooks.length}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Kitap Listesi -->
  <main class="py-16 px-6 bg-gray-50/50">
    <div class="max-w-[1000px] mx-auto">
      {grouped.map((g, gi) => (
        <section id={`asama-${gi + 1}`} class="mb-24 last:mb-0 scroll-mt-24">
          
          {/* Aşamalar arası alıntı */}
          {stageQuotes[gi] && (
            <div class="text-center mb-12 py-8">
              <div class="w-12 h-[1px] bg-gray-300 mx-auto mb-6"></div>
              <blockquote class="font-body italic text-lg text-body/60 max-w-[500px] mx-auto leading-relaxed">
                {stageQuotes[gi]}
              </blockquote>
              <div class="w-12 h-[1px] bg-gray-300 mx-auto mt-6"></div>
            </div>
          )}

          {/* Aşama Header */}
          <div class="mb-10">
            <div class="flex items-start gap-5">
              <div class="relative flex-shrink-0">
                <div
                  class="w-16 h-16 md:w-20 md:h-20 rounded-2xl grid place-items-center text-white font-heading font-black text-2xl md:text-3xl shadow-xl"
                  style={`background: linear-gradient(135deg, ${g.color}, ${g.color}cc); box-shadow: 0 8px 32px ${g.color}40;`}
                >
                  {gi + 1}
                </div>
                <div class="absolute -top-1 -right-1 text-lg">{stageIcons[gi]}</div>
              </div>
              <div class="flex-1 pt-1">
                <h2 class="font-heading text-2xl md:text-4xl text-lacivert font-black uppercase tracking-tight mb-1.5">{g.category}</h2>
                <p class="text-base md:text-lg font-semibold" style={`color: ${g.color}`}>{g.subtitle}</p>
                <div class="flex items-center gap-4 mt-3">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-white border border-gray-200 text-body/70">
                    📚 {g.mainBooks.length} kitap
                  </span>
                  {g.refBooks.length > 0 && (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-white border border-gray-200 text-body/70">
                      📖 {g.refBooks.length} referans
                    </span>
                  )}
                </div>
              </div>
            </div>

            {g.note && (
              <div class="mt-6 ml-0 md:ml-[5.5rem] p-5 rounded-2xl border-l-4 bg-white shadow-sm" style={`border-color: ${g.color}`}>
                <div class="flex items-start gap-3">
                  <span class="text-xl flex-shrink-0">📝</span>
                  <p class="text-sm leading-relaxed text-body/80">{g.note}</p>
                </div>
              </div>
            )}
          </div>

          {/* Timeline / Kitap Kartları */}
          <div class="relative ml-0 md:ml-[5.5rem]">
            {/* Sol çizgi */}
            <div class="absolute left-6 top-0 bottom-0 w-px hidden md:block" style={`background: linear-gradient(to bottom, ${g.color}30, ${g.color}10)`}></div>

            <div class="space-y-3">
              {g.mainBooks.map((book, bi) => (
                <div class="group relative bg-white rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-lg transition-all duration-300 overflow-hidden">
                  {/* Sol renk şerit */}
                  <div class="absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl transition-all duration-300 group-hover:w-1.5" style={`background: ${g.color}`}></div>
                  
                  <div class="flex items-start gap-4 p-5 pl-6">
                    {/* Numara */}
                    <div
                      class="w-11 h-11 rounded-xl grid place-items-center text-white font-heading font-bold text-xs flex-shrink-0 shadow-md transition-all duration-300 group-hover:scale-110 group-hover:shadow-lg"
                      style={`background: linear-gradient(135deg, ${g.color}, ${g.color}dd)`}
                    >
                      {book.number}
                    </div>

                    <div class="flex-1 min-w-0">
                      <h3 class="font-heading font-bold text-lacivert text-[1.05rem] md:text-lg leading-tight mb-2 group-hover:text-mavi transition-colors duration-300">
                        {book.title}
                      </h3>
                      <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5">
                        {book.author && (
                          <span class="inline-flex items-center gap-1.5 text-sm text-body/70">
                            <svg class="w-3.5 h-3.5 opacity-40" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                            </svg>
                            {book.author}
                          </span>
                        )}
                        {book.publisher && (
                          <span class="inline-flex items-center gap-1.5 text-xs text-body/50">
                            <svg class="w-3 h-3 opacity-40" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4z" clip-rule="evenodd" />
                            </svg>
                            {book.publisher}
                          </span>
                        )}
                      </div>
                      {book.description && (
                        <div class="mt-2.5 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium italic" style={`background: ${g.color}08; color: ${g.color}`}>
                          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                          </svg>
                          {book.description}
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Referans Kitaplar — Açılır Bölüm */}
          {g.refBooks.length > 0 && (
            <div class="mt-10 ml-0 md:ml-[5.5rem]">
              <details class="group/ref">
                <summary class="flex items-center gap-3 cursor-pointer list-none py-3 px-4 rounded-xl bg-white border border-gray-200 hover:shadow-sm transition-all select-none">
                  <svg class="w-4 h-4 transition-transform duration-300 group-open/ref:rotate-90" style={`color: ${g.color}`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                  </svg>
                  <svg class="w-5 h-5" style={`color: ${g.color}`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V5zm11 1H6v8l4-2 4 2V6z" clip-rule="evenodd" />
                  </svg>
                  <span class="font-heading font-bold text-lacivert text-sm uppercase tracking-wide">Referans Kitaplar ve Sözlükler</span>
                  <span class="ml-auto text-xs font-medium px-2.5 py-1 rounded-full" style={`background: ${g.color}10; color: ${g.color}`}>{g.refBooks.length}</span>
                </summary>
                <div class="mt-3 grid sm:grid-cols-2 gap-2.5 animate-slide-down">
                  {g.refBooks.map((book) => (
                    <div class="bg-white rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all p-4 relative overflow-hidden">
                      <div class="absolute top-0 right-0 w-16 h-16 rounded-bl-[40px] opacity-[0.03]" style={`background: ${g.color}`}></div>
                      <h4 class="font-heading font-bold text-lacivert text-sm leading-tight mb-2">
                        {book.title}
                      </h4>
                      <div class="space-y-1 text-xs text-body/60">
                        {book.author && (
                          <div class="flex items-center gap-1.5">
                            <span class="opacity-60">✍️</span> {book.author}
                          </div>
                        )}
                        {book.publisher && (
                          <div class="flex items-center gap-1.5">
                            <span class="opacity-60">🏢</span> {book.publisher}
                          </div>
                        )}
                        {book.description && (
                          <div class="flex items-center gap-1.5 italic" style={`color: ${g.color}`}>
                            <span class="opacity-60">📌</span> {book.description}
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </details>
            </div>
          )}
        </section>
      ))}
    </div>
  </main>

  <!-- Footer -->
  <section class="relative py-20 px-6 bg-lacivert overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-turkuaz/5 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-mavi/5 rounded-full blur-[120px]"></div>
    </div>
    <div class="relative z-10 max-w-[800px] mx-auto text-center">
      <div class="text-5xl mb-6">📚</div>
      <h2 class="font-heading text-3xl md:text-4xl text-white font-black mb-4 uppercase tracking-tight">Okumak, Diriliştir</h2>
      <p class="text-vizon/70 text-lg leading-relaxed mb-10 max-w-[500px] mx-auto">
        Her kitap, medeniyet tasavvurunun bir tuğlasıdır. Yüz kitapla bir ufuk inşa edin.
      </p>

      <!-- Aşama Progress -->
      <div class="flex items-center justify-center gap-1 mb-10">
        {grouped.map((g, i) => (
          <div class="flex items-center gap-1">
            <div class="w-8 h-8 rounded-lg grid place-items-center text-white text-xs font-bold" style={`background: ${g.color}`}>{i+1}</div>
            {i < grouped.length - 1 && <div class="w-8 h-px bg-vizon/20"></div>}
          </div>
        ))}
      </div>

      <a
        href="/"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-2xl bg-gradient-to-r from-vizon to-vizon/90 text-lacivert font-heading font-bold text-lg hover:-translate-y-1 hover:shadow-2xl transition-all no-underline"
      >
        Ana Sayfaya Dön
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>

  <Footer />
  <ScrollTop />
</BaseLayout>

<style>
  /* Animations */
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slide-down {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes ping-slow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .animate-fade-in { animation: fade-in 0.6s ease-out both; }
  .animate-fade-in-up { animation: fade-in-up 0.7s ease-out both; }
  .animate-slide-down { animation: slide-down 0.3s ease-out both; }
  .animate-ping-slow { animation: ping-slow 2s ease-in-out infinite; }
  .animate-bounce-slow { animation: bounce-slow 2s ease-in-out infinite; }

  /* Details marker hide */
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; content: ''; }

  /* Active nav link */
  .nav-link.active {
    background: var(--active-bg);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
</style>

<script define:vars={{ totalMain, totalRef, totalAuthors }}>
  // Counter animation
  function animateCounter(id, target, duration = 1500) {
    const el = document.getElementById(id);
    if (!el) return;
    const start = performance.now();
    const step = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(target * eased);
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  // IntersectionObserver for counters
  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter('counter-main', totalMain);
        animateCounter('counter-ref', totalRef);
        animateCounter('counter-authors', totalAuthors);
        heroObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const counterEl = document.getElementById('counter-main');
  if (counterEl) heroObserver.observe(counterEl.closest('section') || counterEl);

  // Scroll progress bar
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = (scrollTop / docHeight) * 100;
    const bar = document.getElementById('scroll-progress');
    if (bar) bar.style.width = progress + '%';
  });

  // Active nav link on scroll
  const sections = document.querySelectorAll('section[id^="asama-"]');
  const navLinks = document.querySelectorAll('.nav-link');
  
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        const stage = id.replace('asama-', '');
        navLinks.forEach(link => {
          link.classList.remove('active');
          link.style.removeProperty('--active-bg');
          if (link.dataset.stage === stage) {
            link.classList.add('active');
            link.style.setProperty('--active-bg', link.style.color + '10');
          }
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => navObserver.observe(s));
</script>
