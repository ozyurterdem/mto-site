---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollTop from '../components/ScrollTop.astro';
import { hundredBooks, readingCategories, categoryColors, categorySubtitles, categoryNotes } from '../data/hundred-books';

const grouped = readingCategories.map(cat => {
  const allBooks = hundredBooks.filter(b => b.category === cat);
  const mainBooks = allBooks.filter(b => !b.isReference);
  const refBooks = allBooks.filter(b => b.isReference);
  return {
    category: cat,
    subtitle: categorySubtitles[cat],
    color: categoryColors[cat],
    note: categoryNotes[cat],
    mainBooks,
    refBooks,
    totalCount: allBooks.length,
  };
});

const totalMain = hundredBooks.filter(b => !b.isReference).length;
const totalRef = hundredBooks.filter(b => b.isReference).length;
const totalAuthors = new Set(hundredBooks.map(b => b.author).filter(Boolean)).size;

const stageIcons = ['🔥', '📖', '🏛️', '💡', '🏆'];
const stageQuotes = [
  '',
  '"Bir medeniyet ancak dert sahiplerinin omuzlarında yükselir."',
  '"Bilgisiz dert, düşüncesiz bilgi, köksüz düşünce — hepsi eksiktir."',
  '"Tarihi bilmeyen, geleceği inşa edemez."',
  '"Moderniteyi anlamadan, geleneği savunamazsınız."',
  '',
];
---

<BaseLayout title="100 Kitap Listesi — Yusuf Kaplan · MTO" description="Yusuf Kaplan 100 Kitap okuma programı. Medeniyet Tasavvuru Okulu beş aşamalı okuma rehberi.">
  <Header />

  <!-- Scroll Progress Bar -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-turkuaz via-mavi to-turuncu z-[100] transition-all duration-150" style="width:0%"></div>

  <!-- Hero -->
  <section class="relative py-14 md:py-18 px-6 overflow-hidden bg-lacivert text-center">
    <!-- Animated Background -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-b from-lacivert via-lacivert/95 to-lacivert"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><rect width=%2260%22 height=%2260%22 fill=%22none%22/><path d=%22M0 30h60M30 0v60%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"></div>
      <!-- Floating orbs -->
      <div class="absolute top-20 left-[10%] w-72 h-72 bg-turkuaz/10 rounded-full blur-[100px] animate-pulse"></div>
      <div class="absolute bottom-10 right-[15%] w-96 h-96 bg-mavi/10 rounded-full blur-[120px] animate-pulse" style="animation-delay:1s"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-turuncu/5 rounded-full blur-[150px]"></div>
    </div>

    <div class="relative z-10 max-w-[900px] mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white/[0.07] backdrop-blur-md border border-white/10 mb-4 animate-fade-in">
        <div class="w-2 h-2 rounded-full bg-turkuaz animate-ping-slow"></div>
        <span class="text-sm font-medium text-vizon uppercase tracking-[0.2em]">Yusuf Kaplan · Medeniyet Tasavvuru Okulu</span>
      </div>

      <!-- Title -->
      <h1 class="animate-fade-in-up" style="animation-delay:0.1s">
        <span class="block font-heading text-vizon/60 text-sm md:text-base font-medium uppercase tracking-[0.3em] mb-1">Okuma Programı</span>
        <span class="block font-heading text-white text-[clamp(2rem,6vw,4.5rem)] font-black uppercase tracking-tight leading-[0.85]">100</span>
        <span class="block font-heading text-white text-[clamp(1.5rem,3.5vw,2.5rem)] font-bold uppercase tracking-[0.15em] -mt-1">Kitap</span>
      </h1>

      <p class="text-vizon/80 text-sm md:text-base leading-relaxed max-w-[550px] mx-auto mt-4 mb-6 animate-fade-in-up" style="animation-delay:0.2s">
        Beş aşamalı okuma yolculuğu ile dert sahibi olmaktan klasiklere uzanan bir medeniyet inşası
      </p>

      <!-- Stats Cards -->
      <div class="flex flex-wrap justify-center gap-3 md:gap-4 animate-fade-in-up" style="animation-delay:0.3s">
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5" id="counter-main">0</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Ana Eser</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-turkuaz to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5" id="counter-ref">0</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Referans</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-mavi to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5" id="counter-authors">0</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Yazar</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-turuncu to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5">5</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Aşama</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-vizon to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="mt-6 animate-bounce-slow">
        <svg class="w-6 h-6 mx-auto text-vizon/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Sticky Nav -->
  <section class="sticky top-20 z-40 bg-white/95 backdrop-blur-md border-b border-gray-200/80 shadow-sm py-3 px-6">
    <div class="max-w-[1100px] mx-auto flex flex-wrap justify-center gap-3">
      {grouped.map((g, i) => (
        <a
          href={`#asama-${i + 1}`}
          class="nav-link group flex items-center gap-2.5 px-4 py-2 rounded-xl text-sm font-medium transition-all hover:shadow-md no-underline"
          data-stage={i + 1}
          style={`color: ${g.color};`}
        >
          <div class="w-7 h-7 rounded-lg grid place-items-center text-white text-xs font-bold transition-all group-hover:scale-110 group-hover:shadow-md" style={`background: ${g.color}`}>
            {i + 1}
          </div>
          <div class="hidden md:flex flex-col leading-tight">
            <span class="font-heading font-bold text-lacivert text-[0.8rem]">{g.category}</span>
            <span class="text-[0.6rem] font-medium opacity-60">{g.subtitle}</span>
          </div>
          <span class="text-[0.65rem] opacity-50 font-medium">{g.mainBooks.length}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Kitap Listesi -->
  <main class="py-16 px-6 bg-gray-50/50">
    <div class="max-w-[1000px] mx-auto">
      {grouped.map((g, gi) => (
        <section id={`asama-${gi + 1}`} class="mb-24 last:mb-0 scroll-mt-24">
          
          {/* Aşamalar arası alıntı */}
          {stageQuotes[gi] && (
            <div class="text-center mb-12 py-8">
              <div class="w-12 h-[1px] bg-gray-300 mx-auto mb-6"></div>
              <blockquote class="font-body italic text-lg text-body/60 max-w-[500px] mx-auto leading-relaxed">
                {stageQuotes[gi]}
              </blockquote>
              <div class="w-12 h-[1px] bg-gray-300 mx-auto mt-6"></div>
            </div>
          )}

          {/* Aşama Header */}
          <div class="mb-10">
            <div class="flex items-start gap-5">
              <div class="relative flex-shrink-0">
                <div
                  class="w-16 h-16 md:w-20 md:h-20 rounded-2xl grid place-items-center text-white font-heading font-black text-2xl md:text-3xl shadow-xl"
                  style={`background: linear-gradient(135deg, ${g.color}, ${g.color}cc); box-shadow: 0 8px 32px ${g.color}40;`}
                >
                  {gi + 1}
                </div>
                <div class="absolute -top-1 -right-1 text-lg">{stageIcons[gi]}</div>
              </div>
              <div class="flex-1 pt-1">
                <h2 class="font-heading text-2xl md:text-4xl text-lacivert font-black uppercase tracking-tight mb-1.5">{g.category}</h2>
                <p class="text-base md:text-lg font-semibold" style={`color: ${g.color}`}>{g.subtitle}</p>
                <div class="flex items-center gap-4 mt-3">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-white border border-gray-200 text-body/70">
                    📚 {g.mainBooks.length} kitap
                  </span>
                  {g.refBooks.length > 0 && (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-white border border-gray-200 text-body/70">
                      📖 {g.refBooks.length} referans
                    </span>
                  )}
                </div>
              </div>
            </div>

            {g.note && (
              <div class="mt-6 ml-0 md:ml-[5.5rem] p-5 rounded-2xl border-l-4 bg-white shadow-sm" style={`border-color: ${g.color}`}>
                <div class="flex items-start gap-3">
                  <span class="text-xl flex-shrink-0">📝</span>
                  <p class="text-sm leading-relaxed text-body/80">{g.note}</p>
                </div>
              </div>
            )}
          </div>

          {/* Kitap Listesi — Sade Satır Düzeni */}
          <div class="ml-0 md:ml-[5.5rem] bg-white rounded-xl border border-gray-100 overflow-hidden">
            {g.mainBooks.map((book, bi) => (
              <div class="group flex items-baseline gap-3 px-5 py-2.5 border-b border-gray-100 last:border-b-0 hover:bg-gray-50/60 transition-colors">
                <span class="font-heading font-bold text-sm flex-shrink-0 min-w-[1.75rem] text-right" style={`color: ${g.color}`}>{book.number}-</span>
                <span class="font-body text-[0.9rem] text-lacivert leading-snug flex-1">
                  {book.title}
                  {book.author && <span class="text-body/50"> · {book.author}</span>}
                </span>
                {book.description && (
                  <span class="font-body text-[0.75rem] italic flex-shrink-0 text-right hidden sm:inline" style={`color: ${g.color}`}>{book.description}</span>
                )}
              </div>
            ))}
          </div>

          {/* Referans Kitaplar */}
          {g.refBooks.length > 0 && (
            <div class="mt-6 ml-0 md:ml-[5.5rem]">
              <details class="group/ref">
                <summary class="flex items-center gap-3 cursor-pointer list-none py-2.5 px-5 rounded-lg bg-white border border-gray-200 hover:shadow-sm transition-all select-none">
                  <svg class="w-4 h-4 transition-transform duration-300 group-open/ref:rotate-90" style={`color: ${g.color}`} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="font-heading font-bold text-lacivert text-sm uppercase tracking-wide">Referans Kitaplar</span>
                  <span class="ml-auto text-xs font-medium px-2 py-0.5 rounded-full" style={`background: ${g.color}10; color: ${g.color}`}>{g.refBooks.length}</span>
                </summary>
                <div class="mt-2 bg-white rounded-lg border border-gray-100 overflow-hidden animate-slide-down">
                  {g.refBooks.map((book) => (
                    <div class="flex items-baseline gap-3 px-5 py-2 border-b border-gray-100 last:border-b-0 hover:bg-gray-50/60 transition-colors">
                      <span class="font-heading font-bold text-sm flex-shrink-0 min-w-[1.75rem] text-right" style={`color: ${g.color}80`}>{book.number}-</span>
                      <span class="font-body text-[0.85rem] text-lacivert/80 leading-snug">
                        {book.title}
                        {book.author && <span class="text-body/50"> · {book.author}</span>}
                      </span>
                    </div>
                  ))}
                </div>
              </details>
            </div>
          )}
        </section>
      ))}
    </div>
  </main>

  <Footer />
  <ScrollTop />
</BaseLayout>

<style>
  /* Animations */
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slide-down {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes ping-slow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .animate-fade-in { animation: fade-in 0.6s ease-out both; }
  .animate-fade-in-up { animation: fade-in-up 0.7s ease-out both; }
  .animate-slide-down { animation: slide-down 0.3s ease-out both; }
  .animate-ping-slow { animation: ping-slow 2s ease-in-out infinite; }
  .animate-bounce-slow { animation: bounce-slow 2s ease-in-out infinite; }

  /* Details marker hide */
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; content: ''; }

  /* Active nav link */
  .nav-link.active {
    background: var(--active-bg);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
</style>

<script define:vars={{ totalMain, totalRef, totalAuthors }}>
  // Counter animation
  function animateCounter(id, target, duration = 1500) {
    const el = document.getElementById(id);
    if (!el) return;
    const start = performance.now();
    const step = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(target * eased);
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  // IntersectionObserver for counters
  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter('counter-main', totalMain);
        animateCounter('counter-ref', totalRef);
        animateCounter('counter-authors', totalAuthors);
        heroObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const counterEl = document.getElementById('counter-main');
  if (counterEl) heroObserver.observe(counterEl.closest('section') || counterEl);

  // Scroll progress bar
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = (scrollTop / docHeight) * 100;
    const bar = document.getElementById('scroll-progress');
    if (bar) bar.style.width = progress + '%';
  });

  // Active nav link on scroll
  const sections = document.querySelectorAll('section[id^="asama-"]');
  const navLinks = document.querySelectorAll('.nav-link');
  
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        const stage = id.replace('asama-', '');
        navLinks.forEach(link => {
          link.classList.remove('active');
          link.style.removeProperty('--active-bg');
          if (link.dataset.stage === stage) {
            link.classList.add('active');
            link.style.setProperty('--active-bg', link.style.color + '10');
          }
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => navObserver.observe(s));
</script>
