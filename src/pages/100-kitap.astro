---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollTop from '../components/ScrollTop.astro';
import { hundredBooks, readingCategories, categoryColors, categorySubtitles } from '../data/hundred-books';

const grouped = readingCategories.map(cat => ({
  category: cat,
  subtitle: categorySubtitles[cat],
  color: categoryColors[cat],
  books: hundredBooks.filter(b => b.category === cat),
}));
---

<BaseLayout title="100 Kitap Listesi — MTO" description="Medeniyet Tasavvuru Okulu 100 Kitap okuma programı. 5 aşama, {hundredBooks.length} eser.">
  <Header />

  <!-- Hero -->
  <section class="relative py-24 px-8 overflow-hidden bg-lacivert text-center">
    <div class="absolute inset-0 opacity-20">
      <img src="https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1400&q=80" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-[800px] mx-auto">
      <h1 class="font-heading text-white text-[clamp(2.5rem,5vw,4rem)] font-bold uppercase tracking-wider mb-4">100 Kitap</h1>
      <p class="text-gray-300 text-lg leading-relaxed">
        Medeniyet Tasavvuru Okulu okuma programı — 5 aşama, {hundredBooks.length} temel eser
      </p>
    </div>
  </section>

  <!-- Sticky Nav -->
  <section class="sticky top-20 z-40 bg-white border-b border-gray-200 py-4 px-8">
    <div class="max-w-[900px] mx-auto flex flex-wrap justify-center gap-3">
      {grouped.map((g, i) => (
        <a
          href={`#asama-${i + 1}`}
          class="flex items-center gap-2 px-4 py-2 rounded-full border text-sm font-medium transition-all hover:-translate-y-0.5 no-underline"
          style={`border-color: ${g.color}; color: ${g.color};`}
        >
          <span class="w-2.5 h-2.5 rounded-full" style={`background: ${g.color}`}></span>
          {g.category}
          <span class="text-xs opacity-60">({g.books.length})</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Kitap Listesi -->
  <main class="py-16 px-8 bg-white">
    <div class="max-w-[900px] mx-auto">
      {grouped.map((g, gi) => (
        <section id={`asama-${gi + 1}`} class="mb-16 last:mb-0 scroll-mt-40">
          <!-- Aşama Başlığı -->
          <div class="flex items-center gap-4 mb-6 pb-4 border-b-2" style={`border-color: ${g.color}`}>
            <div
              class="w-10 h-10 rounded-lg grid place-items-center text-white font-heading font-bold text-base flex-shrink-0"
              style={`background: ${g.color}`}
            >
              {gi + 1}
            </div>
            <div>
              <h2 class="font-heading text-xl text-lacivert font-bold uppercase tracking-wider">{g.category}</h2>
              <p class="text-xs text-body">{g.subtitle} · {g.books.length} eser</p>
            </div>
          </div>

          <!-- Liste -->
          <ol class="list-none m-0 p-0">
            {g.books.map((book, bi) => {
              const globalIndex = hundredBooks.indexOf(book) + 1;
              return (
                <li class="flex items-baseline gap-4 py-3 border-b border-gray-100 last:border-0 hover:bg-gray-50 transition-colors px-2 -mx-2 rounded">
                  <span
                    class="text-xs font-bold w-7 text-right flex-shrink-0"
                    style={`color: ${g.color}`}
                  >
                    {globalIndex}.
                  </span>
                  <div class="flex-1 min-w-0">
                    <span class="font-heading font-bold text-lacivert text-[0.95rem]">{book.title}</span>
                    <span class="text-body text-sm"> — {book.author}</span>
                    {book.description && (
                      <span class="text-xs italic opacity-50"> ({book.description})</span>
                    )}
                  </div>
                  <span class="text-xs text-vizon flex-shrink-0 hidden sm:block">{book.publisher}</span>
                </li>
              );
            })}
          </ol>
        </section>
      ))}
    </div>
  </main>

  <!-- Stats -->
  <section class="py-12 px-8 bg-lacivert text-center">
    <div class="max-w-[800px] mx-auto flex flex-wrap justify-center gap-8">
      <div>
        <div class="font-heading text-4xl text-white font-bold">{hundredBooks.length}</div>
        <div class="text-vizon text-sm uppercase tracking-wider">Toplam Eser</div>
      </div>
      <div>
        <div class="font-heading text-4xl text-white font-bold">{readingCategories.length}</div>
        <div class="text-vizon text-sm uppercase tracking-wider">Aşama</div>
      </div>
      <div>
        <div class="font-heading text-4xl text-white font-bold">{new Set(hundredBooks.map(b => b.author)).size}</div>
        <div class="text-vizon text-sm uppercase tracking-wider">Yazar</div>
      </div>
    </div>
  </section>

  <Footer />
  <ScrollTop />
</BaseLayout>
