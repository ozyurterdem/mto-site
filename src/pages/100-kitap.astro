---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollTop from '../components/ScrollTop.astro';
import { hundredBooks, readingCategories, categoryColors, categorySubtitles, categoryNotes } from '../data/hundred-books';

const grouped = readingCategories.map(cat => {
  const allBooks = hundredBooks.filter(b => b.category === cat);
  const mainBooks = allBooks.filter(b => !b.isReference);
  const refBooks = allBooks.filter(b => b.isReference);
  return {
    category: cat,
    subtitle: categorySubtitles[cat],
    color: categoryColors[cat],
    note: categoryNotes[cat],
    mainBooks,
    refBooks,
    totalCount: allBooks.length,
  };
});

const totalMain = 100;
const totalRef = hundredBooks.filter(b => b.isReference).length;
const totalAuthors = new Set(hundredBooks.map(b => b.author).filter(Boolean)).size;

---

<BaseLayout title="100 Kitap Listesi — Yusuf Kaplan · MTO" description="Yusuf Kaplan 100 Kitap okuma programı. Medeniyet Tasavvuru Okulu beş aşamalı okuma rehberi.">
  <Header />

  <!-- Scroll Progress Bar -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-turkuaz via-mavi to-turuncu z-[100] transition-all duration-150" style="width:0%"></div>

  <!-- Hero -->
  <section class="relative py-14 md:py-18 px-6 overflow-hidden bg-lacivert text-center">
    <!-- Animated Background -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-b from-lacivert via-lacivert/95 to-lacivert"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><rect width=%2260%22 height=%2260%22 fill=%22none%22/><path d=%22M0 30h60M30 0v60%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>');"></div>
      <!-- Floating orbs -->
      <div class="absolute top-20 left-[10%] w-72 h-72 bg-turkuaz/10 rounded-full blur-[100px] animate-pulse"></div>
      <div class="absolute bottom-10 right-[15%] w-96 h-96 bg-mavi/10 rounded-full blur-[120px] animate-pulse" style="animation-delay:1s"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-turuncu/5 rounded-full blur-[150px]"></div>
    </div>

    <div class="relative z-10 max-w-[900px] mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white/[0.07] backdrop-blur-md border border-white/10 mb-4 animate-fade-in">
        <div class="w-2 h-2 rounded-full bg-turkuaz animate-ping-slow"></div>
        <span class="text-sm font-medium text-vizon uppercase tracking-[0.2em]">Yusuf Kaplan · Medeniyet Tasavvuru Okulu</span>
      </div>

      <!-- Title -->
      <h1 class="animate-fade-in-up" style="animation-delay:0.1s">
        <span class="block font-heading text-vizon/60 text-sm md:text-base font-medium uppercase tracking-[0.3em] mb-1">Okuma Programı</span>
        <span class="block font-heading text-white text-[clamp(2rem,6vw,4.5rem)] font-black uppercase tracking-tight leading-[0.85]">100</span>
        <span class="block font-heading text-white text-[clamp(1.5rem,3.5vw,2.5rem)] font-bold uppercase tracking-[0.15em] -mt-1">Kitap</span>
      </h1>

      <p class="text-vizon/80 text-sm md:text-base leading-relaxed max-w-[550px] mx-auto mt-4 mb-6 animate-fade-in-up" style="animation-delay:0.2s">
        Beş aşamalı okuma yolculuğu ile dert sahibi olmaktan klasiklere uzanan bir medeniyet inşası
      </p>

      <!-- Stats Cards -->
      <div class="flex flex-wrap justify-center gap-3 md:gap-4 animate-fade-in-up" style="animation-delay:0.3s">
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5" id="counter-main">0</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Ana Eser</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-turkuaz to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5" id="counter-ref">0</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Referans</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-mavi to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5" id="counter-authors">0</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Yazar</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-turuncu to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        <div class="group relative px-4 py-3 rounded-xl bg-white/[0.05] backdrop-blur-sm border border-white/10 hover:bg-white/[0.1] hover:border-white/20 transition-all duration-300 hover:-translate-y-1">
          <div class="font-heading text-2xl font-black text-white mb-0.5">5</div>
          <div class="text-[0.6rem] text-vizon/60 uppercase tracking-[0.2em]">Aşama</div>
          <div class="absolute inset-x-0 bottom-0 h-0.5 rounded-b-2xl bg-gradient-to-r from-transparent via-vizon to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="mt-6 animate-bounce-slow">
        <svg class="w-6 h-6 mx-auto text-vizon/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Sticky Nav -->
  <section class="sticky top-20 z-40 bg-white/95 backdrop-blur-md border-b border-gray-200/80 shadow-sm py-3 px-6">
    <div class="max-w-[1100px] mx-auto flex flex-wrap justify-center gap-3">
      {grouped.map((g, i) => (
        <a
          href={`#asama-${i + 1}`}
          class="nav-link group flex items-center gap-2.5 px-4 py-2 rounded-xl text-sm font-medium transition-all hover:shadow-md no-underline"
          data-stage={i + 1}
          style={`color: ${g.color};`}
        >
          <div class="w-7 h-7 rounded-lg grid place-items-center text-white text-xs font-bold transition-all group-hover:scale-110 group-hover:shadow-md" style={`background: ${g.color}`}>
            {i + 1}
          </div>
          <div class="hidden md:flex flex-col leading-tight">
            <span class="font-heading font-bold text-lacivert text-[0.8rem]">{g.category}</span>
            <span class="text-[0.6rem] font-medium opacity-60">{g.subtitle}</span>
          </div>
          <span class="text-[0.65rem] opacity-50 font-medium">{g.mainBooks.length}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Kitap Listesi -->
  <main class="relative py-20 px-6 overflow-hidden">
    {/* Arka plan dokusu */}
    <div class="absolute inset-0 bg-[#FAFAF8]"></div>
    <div class="absolute inset-0 opacity-[0.015]" style="background-image: url('data:image/svg+xml,<svg width=%2240%22 height=%2240%22 xmlns=%22http://www.w3.org/2000/svg%22><circle cx=%2220%22 cy=%2220%22 r=%221%22 fill=%22%23000%22/></svg>');"></div>

    <div class="relative max-w-[1000px] mx-auto">
      {grouped.map((g, gi) => (
        <section id={`asama-${gi + 1}`} class="mb-32 last:mb-0 scroll-mt-24">

          {/* ══════ Aşama Header — Editorial ══════ */}
          <div class="mb-12 relative">
            <div class="flex items-start gap-6 md:gap-8">
              {/* Aşama numarası — minimal typographic */}
              <div class="relative flex-shrink-0">
                <div class="relative">
                  <span class="block font-heading text-[4.5rem] md:text-[6rem] font-black leading-none tracking-tighter" style={`color: ${g.color}18`}>
                    {gi + 1}
                  </span>
                  <span class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-heading text-2xl md:text-3xl font-black" style={`color: ${g.color}`}>
                    {gi + 1}
                  </span>
                </div>
                {/* Dikey dekoratif çizgi */}
                <div class="hidden md:flex flex-col items-center mt-4 gap-1">
                  <div class="w-px h-12 bg-gradient-to-b" style={`background: linear-gradient(to bottom, ${g.color}40, transparent)`}></div>
                </div>
              </div>

              <div class="flex-1 pt-3 md:pt-5">
                {/* Üst etiket */}
                <div class="flex items-center gap-3 mb-2">
                  <div class="h-px flex-1 max-w-[40px]" style={`background: ${g.color}50`}></div>
                  <span class="text-[0.65rem] font-heading font-bold uppercase tracking-[0.25em]" style={`color: ${g.color}90`}>
                    {gi + 1}. Aşama
                  </span>
                </div>

                <h2 class="font-heading text-2xl md:text-[2.5rem] text-lacivert font-black leading-tight mb-1">{g.category}</h2>
                <p class="text-sm md:text-base font-medium mb-5" style={`color: ${g.color}`}>{g.subtitle}</p>

                {/* İstatistik çipleri — pill style */}
                <div class="flex flex-wrap items-center gap-2">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.7rem] font-bold border" style={`color: ${g.color}; background: ${g.color}08; border-color: ${g.color}18`}>
                    <span class="w-1.5 h-1.5 rounded-full" style={`background: ${g.color}`}></span>
                    {g.mainBooks.length} kitap
                  </span>
                  {g.refBooks.length > 0 && (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[0.7rem] font-bold text-vizon/70 bg-vizon/5 border border-vizon/15">
                      <span class="w-1.5 h-1.5 rounded-full bg-vizon/50"></span>
                      {g.refBooks.length} referans
                    </span>
                  )}
                </div>
              </div>
            </div>

            {g.note && (
              <div class="mt-8 md:ml-[6.5rem] relative pl-5 py-4 pr-5 rounded-xl bg-white/80 backdrop-blur-sm border border-gray-100">
                <div class="absolute left-0 top-3 bottom-3 w-[3px] rounded-full" style={`background: ${g.color}60`}></div>
                <p class="text-[0.82rem] leading-relaxed text-lacivert/60 italic">{g.note}</p>
              </div>
            )}
          </div>

          {/* ══════ Kitap Listesi — Editorial Premium ══════ */}
          <div class="md:ml-[6.5rem]">
            {/* Üst bar */}
            <div class="flex items-center justify-between mb-4 px-1">
              <div class="flex items-center gap-2">
                <div class="w-4 h-[2px] rounded-full" style={`background: ${g.color}`}></div>
                <span class="text-[0.68rem] font-heading font-bold text-lacivert/30 uppercase tracking-[0.2em]">Okuma Listesi</span>
              </div>
              <span class="text-[0.62rem] font-medium text-lacivert/20 tracking-wider">{g.mainBooks.length} ESER</span>
            </div>

            {/* Kitap satırları */}
            <div class="space-y-1.5">
              {g.mainBooks.map((book, bi) => (
                <div class="book-row group relative rounded-xl transition-all duration-300 hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)]">
                  {/* Ana container */}
                  <div class="relative flex items-center gap-4 md:gap-5 px-5 py-4 rounded-xl bg-white border border-gray-100/80 group-hover:border-gray-200 transition-all duration-300">

                    {/* Sol dekoratif accent — her zaman görünür, hover'da genişler */}
                    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-[3px] h-6 group-hover:h-10 rounded-r-full transition-all duration-300 opacity-40 group-hover:opacity-100" style={`background: ${g.color}`}></div>

                    {/* Numara — typographic */}
                    <div class="relative flex-shrink-0 w-10 h-10 flex items-center justify-center">
                      <span class="absolute inset-0 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`background: ${g.color}08`}></span>
                      <span class="relative font-heading text-sm font-black tracking-tight" style={`color: ${g.color}`}>
                        {book.number}
                      </span>
                    </div>

                    {/* Dikey ayırıcı */}
                    <div class="hidden sm:block w-px h-8 bg-gray-100 group-hover:bg-gray-200 transition-colors flex-shrink-0"></div>

                    {/* İçerik */}
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-3">
                        <span class="font-heading text-[0.9rem] md:text-[0.95rem] text-lacivert font-bold leading-snug group-hover:text-lacivert transition-colors duration-200 truncate">
                          {book.title}
                        </span>
                        {book.author && (
                          <span class="text-lacivert/30 text-[0.78rem] font-medium whitespace-nowrap flex-shrink-0">
                            — {book.author}
                          </span>
                        )}
                      </div>
                      {book.publisher && (
                        <span class="text-lacivert/20 text-[0.68rem] hidden lg:block mt-0.5 font-medium">{book.publisher}</span>
                      )}
                    </div>

                    {/* Açıklama — tooltip style */}
                    {book.description && (
                      <div class="hidden md:flex items-center gap-1.5 flex-shrink-0 max-w-[200px]">
                        <div class="flex items-center gap-1.5 text-[0.65rem] font-medium px-3 py-1.5 rounded-lg transition-all duration-200" style={`color: ${g.color}; background: ${g.color}06`}>
                          <svg class="w-3 h-3 flex-shrink-0 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                          </svg>
                          <span class="truncate">{book.description}</span>
                        </div>
                      </div>
                    )}

                    {/* Sağ ok — hover */}
                    <div class="opacity-0 group-hover:opacity-30 transition-opacity duration-200 flex-shrink-0">
                      <svg class="w-4 h-4 text-lacivert" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                      </svg>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* ══════ Referans Kitaplar ══════ */}
          {g.refBooks.length > 0 && (
            <div class="mt-8 md:ml-[6.5rem]">
              <details class="group/ref">
                <summary class="flex items-center gap-3 cursor-pointer list-none py-3 px-5 rounded-xl bg-white/60 backdrop-blur-sm border border-dashed border-gray-200 hover:border-gray-300 hover:bg-white transition-all duration-200 select-none">
                  <svg class="w-3.5 h-3.5 transition-transform duration-300 group-open/ref:rotate-90 text-vizon/60" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                  </svg>
                  <span class="font-heading font-bold text-lacivert/40 text-[0.75rem] uppercase tracking-[0.15em]">Referans Kitaplar</span>
                  <div class="flex-1 h-px bg-gray-100 mx-2"></div>
                  <span class="text-[0.65rem] font-bold px-2.5 py-0.5 rounded-md" style={`color: ${g.color}; background: ${g.color}08`}>{g.refBooks.length}</span>
                </summary>
                <div class="mt-2 space-y-1 animate-slide-down">
                  {g.refBooks.map((book, ri) => (
                    <div class="flex items-center gap-3 px-5 py-3 rounded-lg bg-white/40 border border-gray-100/50 hover:bg-white/80 transition-colors duration-200">
                      <span class="font-heading text-[0.7rem] font-bold w-7 text-center flex-shrink-0" style={`color: ${g.color}60`}>{book.number}</span>
                      <div class="w-px h-5 bg-gray-100 flex-shrink-0"></div>
                      <span class="font-body text-[0.82rem] text-lacivert/60 leading-snug">{book.title}</span>
                      {book.author && <span class="text-lacivert/25 text-[0.72rem] ml-auto whitespace-nowrap flex-shrink-0">— {book.author}</span>}
                    </div>
                  ))}
                </div>
              </details>
            </div>
          )}
        </section>
      ))}
    </div>
  </main>

  <Footer />
  <ScrollTop />
</BaseLayout>

<style>
  /* Animations */
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slide-down {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes ping-slow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  .animate-fade-in { animation: fade-in 0.6s ease-out both; }
  .animate-fade-in-up { animation: fade-in-up 0.7s ease-out both; }
  .animate-slide-down { animation: slide-down 0.3s ease-out both; }
  .animate-ping-slow { animation: ping-slow 2s ease-in-out infinite; }
  .animate-bounce-slow { animation: bounce-slow 2s ease-in-out infinite; }

  /* Details marker hide */
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; content: ''; }

  /* Active nav link */
  .nav-link.active {
    background: var(--active-bg);
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
</style>

<script define:vars={{ totalMain, totalRef, totalAuthors }}>
  // Counter animation
  function animateCounter(id, target, duration = 1500) {
    const el = document.getElementById(id);
    if (!el) return;
    const start = performance.now();
    const step = (now) => {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(target * eased);
      if (progress < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  // IntersectionObserver for counters
  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounter('counter-main', totalMain);
        animateCounter('counter-ref', totalRef);
        animateCounter('counter-authors', totalAuthors);
        heroObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const counterEl = document.getElementById('counter-main');
  if (counterEl) heroObserver.observe(counterEl.closest('section') || counterEl);

  // Scroll progress bar
  window.addEventListener('scroll', () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = (scrollTop / docHeight) * 100;
    const bar = document.getElementById('scroll-progress');
    if (bar) bar.style.width = progress + '%';
  });

  // Active nav link on scroll
  const sections = document.querySelectorAll('section[id^="asama-"]');
  const navLinks = document.querySelectorAll('.nav-link');
  
  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        const stage = id.replace('asama-', '');
        navLinks.forEach(link => {
          link.classList.remove('active');
          link.style.removeProperty('--active-bg');
          if (link.dataset.stage === stage) {
            link.classList.add('active');
            link.style.setProperty('--active-bg', link.style.color + '10');
          }
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(s => navObserver.observe(s));
</script>
