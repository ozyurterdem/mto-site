---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ScrollTop from '../components/ScrollTop.astro'
---

<BaseLayout title="İletişim — MTO" description="Medeniyet Tasavvuru Okulu iletişim bilgileri ve sosyal medya hesapları.">
  <Header />
  <main class="min-h-screen">
    <!-- Hero / Map Placeholder -->
    <div class="w-full bg-lacivert/10" style="height: 250px;">
      <div class="max-w-[1200px] mx-auto h-full flex items-center justify-center">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto text-lacivert/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <p class="mt-2 text-lacivert/40 font-body text-sm">Harita Alanı</p>
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12 py-12 lg:py-16">
      <!-- İletişim Heading -->
      <h1 class="font-heading text-3xl lg:text-4xl font-bold text-lacivert uppercase tracking-wide mb-10">
        İLETİŞİM
      </h1>

      <!-- Email Addresses -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <svg class="w-5 h-5 text-turkuaz flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:medeniyetasavvuruokulu@gmail.com" class="font-body text-lacivert/80 hover:text-turkuaz transition-colors">
            medeniyetasavvuruokulu@gmail.com
          </a>
        </div>
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-turkuaz flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <a href="mailto:mtokurumsal@gmail.com" class="font-body text-lacivert/80 hover:text-turkuaz transition-colors">
            mtokurumsal@gmail.com
          </a>
        </div>
      </div>

      <!-- Sosyal Medya -->
      <h2 class="font-heading text-2xl lg:text-3xl font-bold text-lacivert uppercase tracking-wide mb-8">
        SOSYAL MEDYA HESAPLARIMIZ
      </h2>

      <div class="space-y-4">
        <!-- Twitter / X -->
        <a href="https://x.com/mtokurumsal?s=21" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-4 p-4 rounded-xl bg-lacivert/5 hover:bg-turkuaz/10 transition-colors group">
          <div class="w-10 h-10 rounded-full bg-lacivert/10 flex items-center justify-center group-hover:bg-turkuaz/20 transition-colors">
            <svg class="w-5 h-5 text-lacivert" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </div>
          <div>
            <span class="font-heading font-semibold text-lacivert group-hover:text-turkuaz transition-colors">Twitter (X)</span>
            <p class="text-sm text-lacivert/50 font-body">@mtokurumsal</p>
          </div>
        </a>

        <!-- Instagram -->
        <a href="https://www.instagram.com/mtokurumsal" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-4 p-4 rounded-xl bg-lacivert/5 hover:bg-turkuaz/10 transition-colors group">
          <div class="w-10 h-10 rounded-full bg-lacivert/10 flex items-center justify-center group-hover:bg-turkuaz/20 transition-colors">
            <svg class="w-5 h-5 text-lacivert" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </div>
          <div>
            <span class="font-heading font-semibold text-lacivert group-hover:text-turkuaz transition-colors">Instagram</span>
            <p class="text-sm text-lacivert/50 font-body">@mtokurumsal</p>
          </div>
        </a>

        <!-- Next Sosyal -->
        <a href="#" class="flex items-center gap-4 p-4 rounded-xl bg-lacivert/5 hover:bg-turkuaz/10 transition-colors group">
          <div class="w-10 h-10 rounded-full bg-lacivert/10 flex items-center justify-center group-hover:bg-turkuaz/20 transition-colors">
            <svg class="w-5 h-5 text-lacivert" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
          </div>
          <div>
            <span class="font-heading font-semibold text-lacivert group-hover:text-turkuaz transition-colors">Next Sosyal</span>
            <p class="text-sm text-lacivert/50 font-body">Yakında</p>
          </div>
        </a>

        <!-- YouTube -->
        <a href="https://youtube.com/@mtobilgi" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-4 p-4 rounded-xl bg-lacivert/5 hover:bg-turkuaz/10 transition-colors group">
          <div class="w-10 h-10 rounded-full bg-lacivert/10 flex items-center justify-center group-hover:bg-turkuaz/20 transition-colors">
            <svg class="w-5 h-5 text-lacivert" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
          <div>
            <span class="font-heading font-semibold text-lacivert group-hover:text-turkuaz transition-colors">YouTube</span>
            <p class="text-sm text-lacivert/50 font-body">@mtobilgi</p>
          </div>
        </a>

        <!-- Telegram -->
        <a href="https://t.me/yusufkaplanmedia" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-4 p-4 rounded-xl bg-lacivert/5 hover:bg-turkuaz/10 transition-colors group">
          <div class="w-10 h-10 rounded-full bg-lacivert/10 flex items-center justify-center group-hover:bg-turkuaz/20 transition-colors">
            <svg class="w-5 h-5 text-lacivert" fill="currentColor" viewBox="0 0 24 24">
              <path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
          </div>
          <div>
            <span class="font-heading font-semibold text-lacivert group-hover:text-turkuaz transition-colors">Telegram</span>
            <p class="text-sm text-lacivert/50 font-body">Yusuf Kaplan Media</p>
          </div>
        </a>

        <!-- Telegram Yorum -->
        <a href="https://t.me/yusufkaplanmedyayorum" target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-4 p-4 rounded-xl bg-lacivert/5 hover:bg-turkuaz/10 transition-colors group">
          <div class="w-10 h-10 rounded-full bg-lacivert/10 flex items-center justify-center group-hover:bg-turkuaz/20 transition-colors">
            <svg class="w-5 h-5 text-lacivert" fill="currentColor" viewBox="0 0 24 24">
              <path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
          </div>
          <div>
            <span class="font-heading font-semibold text-lacivert group-hover:text-turkuaz transition-colors">Telegram Yorum</span>
            <p class="text-sm text-lacivert/50 font-body">Yusuf Kaplan Medya Yorum</p>
          </div>
        </a>
      </div>
    </div>
  </main>
  <Footer />
  <ScrollTop />
</BaseLayout>
