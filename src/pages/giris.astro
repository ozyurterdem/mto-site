---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Giriş — MTO" description="MTO hesabınıza giriş yapın veya yeni hesap oluşturun.">
  <Header locale="tr" />

  <main class="min-h-[70vh] flex items-center justify-center px-4 py-16 bg-gray-50">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <img src="/images/mto-logo.png" alt="MTO" class="h-16 mx-auto mb-3" />
        <h1 class="font-heading text-2xl font-bold text-lacivert">Medeniyet Tasavvuru Okulu</h1>
      </div>

      <!-- Tab Switcher -->
      <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden">
        <div class="flex border-b border-gray-100">
          <button id="tab-login" class="flex-1 py-3.5 text-sm font-semibold uppercase tracking-wider text-turkuaz border-b-2 border-turkuaz transition-all" onclick="switchTab('login')">
            Giriş Yap
          </button>
          <button id="tab-register" class="flex-1 py-3.5 text-sm font-semibold uppercase tracking-wider text-body/50 border-b-2 border-transparent transition-all hover:text-body/80" onclick="switchTab('register')">
            Kayıt Ol
          </button>
        </div>

        <!-- LOGIN FORM -->
        <form id="form-login" class="p-6 space-y-4">
          <div>
            <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">E-posta</label>
            <input type="email" id="login-email" required autocomplete="email"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all" 
              placeholder="ornek@mail.com" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Şifre</label>
            <input type="password" id="login-password" required autocomplete="current-password"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
              placeholder="••••••••" />
          </div>
          <div id="login-error" class="hidden text-sm text-red-600 bg-red-50 rounded-xl px-4 py-3"></div>
          <button type="submit" id="login-btn"
            class="w-full py-3.5 bg-turkuaz text-white rounded-xl text-sm font-bold uppercase tracking-wider hover:bg-turkuaz/90 transition-all disabled:opacity-50 disabled:cursor-not-allowed">
            Giriş Yap
          </button>
          <div class="text-center">
            <a href="#" onclick="switchTab('forgot'); return false;" class="text-xs text-turkuaz hover:underline">Şifremi unuttum</a>
          </div>
        </form>

        <!-- REGISTER FORM -->
        <form id="form-register" class="p-6 space-y-4 hidden">
          <!-- Hesap Bilgileri -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Ad</label>
              <input type="text" id="reg-ad" required minlength="2" maxlength="100"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                placeholder="Adınız" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Soyad</label>
              <input type="text" id="reg-soyad" required minlength="2" maxlength="100"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                placeholder="Soyadınız" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">E-posta</label>
            <input type="email" id="reg-email" required autocomplete="email"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
              placeholder="ornek@mail.com" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Şifre</label>
            <input type="password" id="reg-password" required minlength="8" autocomplete="new-password"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
              placeholder="En az 8 karakter, harf + rakam" />
          </div>

          <!-- MTO Öğrenci Toggle -->
          <div class="bg-turkuaz/5 rounded-xl p-4 border border-turkuaz/10">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" id="reg-mto-ogrenci" class="w-5 h-5 rounded border-gray-300 text-turkuaz focus:ring-turkuaz/30 accent-turkuaz" />
              <div>
                <span class="text-sm font-semibold text-lacivert">MTO öğrencisiyim</span>
                <p class="text-xs text-body/60 mt-0.5">Hâlihazırda MTO'da eğitim alıyorsanız işaretleyin</p>
              </div>
            </label>
          </div>

          <!-- Talebe Ek Bilgileri (toggle ile açılır) -->
          <div id="talebe-fields" class="hidden space-y-4 border-t border-gray-100 pt-4">
            <p class="text-xs text-turkuaz font-semibold uppercase tracking-wider">Talebe Bilgileri</p>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Telefon</label>
              <input type="tel" id="reg-telefon" minlength="10" maxlength="20"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                placeholder="05XX XXX XX XX" />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Şehir</label>
                <input type="text" id="reg-sehir"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                  placeholder="İstanbul" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">İlçe</label>
                <input type="text" id="reg-ilce"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                  placeholder="Fatih" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Doğum Tarihi</label>
              <input type="date" id="reg-dogum"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Cinsiyet</label>
              <select id="reg-cinsiyet" class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all">
                <option value="">Seçiniz</option>
                <option value="erkek">Erkek</option>
                <option value="kadin">Kadın</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Eğitim Durumu</label>
              <select id="reg-egitim" class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all">
                <option value="">Seçiniz</option>
                <option value="lise">Lise</option>
                <option value="universite">Üniversite</option>
                <option value="mezun">Mezun</option>
                <option value="lisansustu">Lisansüstü</option>
              </select>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Okul</label>
                <input type="text" id="reg-okul"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                  placeholder="İstanbul Üniversitesi" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Bölüm</label>
                <input type="text" id="reg-bolum"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                  placeholder="İlahiyat" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Meslek</label>
              <input type="text" id="reg-meslek"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                placeholder="Öğretmen, mühendis, vb." />
            </div>

            <p class="text-xs text-turkuaz font-semibold uppercase tracking-wider pt-2">MTO Bilgileri</p>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Kademe / Halka Bilgisi</label>
              <input type="text" id="reg-kademe-bilgi"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                placeholder="Ör: 3. Kademe, İstanbul halkası" />
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Halka Şehri</label>
                <input type="text" id="reg-halka-sehir"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                  placeholder="İstanbul" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Katılım Yılı</label>
                <input type="number" id="reg-katilim-yili" min="2010" max="2030"
                  class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                  placeholder="2023" />
              </div>
            </div>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Referans</label>
              <input type="text" id="reg-referans"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
                placeholder="Sizi yönlendiren kişi" />
            </div>

            <div>
              <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">Ek Not</label>
              <textarea id="reg-not" rows="2" maxlength="2000"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all resize-none"
                placeholder="Eklemek istediğiniz bilgi varsa yazın"></textarea>
            </div>
          </div>

          <div id="reg-error" class="hidden text-sm text-red-600 bg-red-50 rounded-xl px-4 py-3"></div>
          <button type="submit" id="reg-btn"
            class="w-full py-3.5 bg-lacivert text-white rounded-xl text-sm font-bold uppercase tracking-wider hover:bg-lacivert-light transition-all disabled:opacity-50 disabled:cursor-not-allowed">
            Kayıt Ol
          </button>
        </form>

        <!-- FORGOT PASSWORD FORM -->
        <form id="form-forgot" class="p-6 space-y-4 hidden">
          <p class="text-sm text-body/70 leading-relaxed">Kayıtlı e-posta adresinizi girin, şifre sıfırlama bağlantısı gönderelim.</p>
          <div>
            <label class="block text-xs font-semibold text-lacivert uppercase tracking-wider mb-1.5">E-posta</label>
            <input type="email" id="forgot-email" required autocomplete="email"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-turkuaz/30 focus:border-turkuaz transition-all"
              placeholder="ornek@mail.com" />
          </div>
          <div id="forgot-msg" class="hidden text-sm rounded-xl px-4 py-3"></div>
          <button type="submit" id="forgot-btn"
            class="w-full py-3.5 bg-turkuaz text-white rounded-xl text-sm font-bold uppercase tracking-wider hover:bg-turkuaz/90 transition-all disabled:opacity-50">
            Bağlantı Gönder
          </button>
          <div class="text-center">
            <a href="#" onclick="switchTab('login'); return false;" class="text-xs text-turkuaz hover:underline">← Giriş ekranına dön</a>
          </div>
        </form>

        <!-- SUCCESS STATE (after register) -->
        <div id="state-verify" class="p-8 text-center hidden">
          <div class="w-16 h-16 rounded-full bg-green-50 grid place-items-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h2 class="font-heading text-xl font-bold text-lacivert mb-2">E-posta Doğrulama Gerekli</h2>
          <p class="text-sm text-body/70 leading-relaxed mb-4">
            <strong id="verify-email-display" class="text-lacivert"></strong> adresine doğrulama bağlantısı gönderdik.
            Lütfen e-postanızı kontrol edin ve bağlantıya tıklayarak hesabınızı aktifleştirin.
          </p>
          <p class="text-xs text-body/50 mb-4">Gelen kutunuzda bulamıyorsanız spam/gereksiz klasörünü kontrol edin.</p>
          <button onclick="resendEmail()" id="resend-btn"
            class="text-sm text-turkuaz font-semibold hover:underline disabled:opacity-50">
            Tekrar Gönder
          </button>
          <div id="resend-msg" class="mt-2 text-xs text-green-600 hidden"></div>
          <div class="mt-6 pt-4 border-t border-gray-100">
            <a href="#" onclick="switchTab('login'); return false;" class="text-sm text-turkuaz font-semibold hover:underline">
              Doğruladıktan sonra → Giriş Yap
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer locale="tr" />
</BaseLayout>

<script>
  import { register, login, resendVerification, clearAuth, isLoggedIn, createTalebeProfile } from '../lib/auth-client';

  // If already logged in, redirect
  if (isLoggedIn()) {
    window.location.href = '/';
  }

  let registeredEmail = '';

  // ─── MTO Öğrenci toggle ───
  document.getElementById('reg-mto-ogrenci')?.addEventListener('change', (e) => {
    const checked = (e.target as HTMLInputElement).checked;
    document.getElementById('talebe-fields')?.classList.toggle('hidden', !checked);
    // Telefon zorunlu yap
    const tel = document.getElementById('reg-telefon') as HTMLInputElement;
    if (tel) tel.required = checked;
  });

  // ─── Tab switching ───
  (window as any).switchTab = function(tab: string) {
    const forms = ['form-login', 'form-register', 'form-forgot', 'state-verify'];
    forms.forEach(f => document.getElementById(f)?.classList.add('hidden'));

    const tabs = ['tab-login', 'tab-register'];
    tabs.forEach(t => {
      const el = document.getElementById(t);
      if (el) {
        el.classList.remove('text-turkuaz', 'border-turkuaz');
        el.classList.add('text-body/50', 'border-transparent');
      }
    });

    if (tab === 'login') {
      document.getElementById('form-login')?.classList.remove('hidden');
      const el = document.getElementById('tab-login');
      el?.classList.add('text-turkuaz', 'border-turkuaz');
      el?.classList.remove('text-body/50', 'border-transparent');
    } else if (tab === 'register') {
      document.getElementById('form-register')?.classList.remove('hidden');
      const el = document.getElementById('tab-register');
      el?.classList.add('text-turkuaz', 'border-turkuaz');
      el?.classList.remove('text-body/50', 'border-transparent');
    } else if (tab === 'forgot') {
      document.getElementById('form-forgot')?.classList.remove('hidden');
    } else if (tab === 'verify') {
      document.getElementById('state-verify')?.classList.remove('hidden');
    }
  };

  // ─── Helper: input value ───
  function val(id: string): string {
    return (document.getElementById(id) as HTMLInputElement)?.value?.trim() || '';
  }

  // ─── Login ───
  document.getElementById('form-login')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('login-btn') as HTMLButtonElement;
    const errEl = document.getElementById('login-error')!;

    btn.disabled = true;
    btn.textContent = 'Giriş yapılıyor...';
    errEl.classList.add('hidden');

    try {
      await login(val('login-email'), val('login-password'));

      // Check for pending talebe profile (created during registration)
      const pendingTalebe = sessionStorage.getItem('mto_talebe_pending');
      if (pendingTalebe) {
        try {
          await createTalebeProfile(JSON.parse(pendingTalebe));
          sessionStorage.removeItem('mto_talebe_pending');
        } catch {
          // Profile creation failed — user can do it later from profile page
          console.warn('Talebe profili oluşturulamadı, daha sonra tekrar denenecek');
        }
      }

      const redirect = new URLSearchParams(window.location.search).get('redirect') || '/';
      window.location.href = redirect;
    } catch (err: any) {
      errEl.textContent = err.message || 'Giriş başarısız';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Giriş Yap';
    }
  });

  // ─── Register ───
  document.getElementById('form-register')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('reg-btn') as HTMLButtonElement;
    const errEl = document.getElementById('reg-error')!;

    const ad = val('reg-ad');
    const soyad = val('reg-soyad');
    const email = val('reg-email');
    const password = val('reg-password');
    const isTalebe = (document.getElementById('reg-mto-ogrenci') as HTMLInputElement)?.checked;

    btn.disabled = true;
    btn.textContent = isTalebe ? 'Hesap ve profil oluşturuluyor...' : 'Kayıt oluşturuluyor...';
    errEl.classList.add('hidden');

    try {
      // 1. Create user account
      await register(email, password, `${ad} ${soyad}`);
      registeredEmail = email;

      // 2. If talebe, we'll show a note — profile will be created after email verification + login
      // (API requires auth token, which we don't have until verified + logged in)

      document.getElementById('verify-email-display')!.textContent = email;

      // Store talebe data in sessionStorage for after-login profile creation
      if (isTalebe) {
        const talebeData = {
          ad, soyad,
          telefon: val('reg-telefon'),
          sehir: val('reg-sehir') || null,
          ilce: val('reg-ilce') || null,
          dogum_tarihi: val('reg-dogum') || null,
          cinsiyet: val('reg-cinsiyet') || null,
          egitim_durumu: val('reg-egitim') || null,
          okul_adi: val('reg-okul') || null,
          bolum: val('reg-bolum') || null,
          meslek: val('reg-meslek') || null,
          mevcut_ogrenci: true,
          kademe_bilgi: val('reg-kademe-bilgi') || null,
          halka_sehir: val('reg-halka-sehir') || null,
          katilim_yili: val('reg-katilim-yili') ? parseInt(val('reg-katilim-yili')) : null,
          referans: val('reg-referans') || null,
          ogrenci_notu: val('reg-not') || null,
        };
        sessionStorage.setItem('mto_talebe_pending', JSON.stringify(talebeData));
      }

      (window as any).switchTab('verify');
    } catch (err: any) {
      errEl.textContent = err.message || 'Kayıt başarısız';
      errEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Kayıt Ol';
    }
  });

  // ─── Forgot Password ───
  document.getElementById('form-forgot')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('forgot-btn') as HTMLButtonElement;
    const msgEl = document.getElementById('forgot-msg')!;
    const email = (document.getElementById('forgot-email') as HTMLInputElement).value;

    btn.disabled = true;
    try {
      const res = await fetch(`https://enfus.mto2.siberkale.com/api/v1/auth/forgot-password?email=${encodeURIComponent(email)}`, { method: 'POST' });
      msgEl.textContent = 'Şifre sıfırlama bağlantısı gönderildi. E-postanızı kontrol edin.';
      msgEl.className = 'text-sm rounded-xl px-4 py-3 bg-green-50 text-green-700';
    } catch {
      msgEl.textContent = 'Bir hata oluştu. Lütfen tekrar deneyin.';
      msgEl.className = 'text-sm rounded-xl px-4 py-3 bg-red-50 text-red-600';
    }
    btn.disabled = false;
  });

  // ─── Resend Verification ───
  (window as any).resendEmail = async function() {
    if (!registeredEmail) return;
    const btn = document.getElementById('resend-btn') as HTMLButtonElement;
    const msgEl = document.getElementById('resend-msg')!;
    btn.disabled = true;
    try {
      await resendVerification(registeredEmail);
      msgEl.textContent = '✓ Doğrulama e-postası tekrar gönderildi';
      msgEl.classList.remove('hidden');
    } catch {
      msgEl.textContent = 'Gönderilemedi, birkaç dakika sonra tekrar deneyin';
      msgEl.classList.remove('hidden');
    }
    setTimeout(() => { btn.disabled = false; }, 30000); // 30sn cooldown
  };

  // Check URL for tab param
  const urlTab = new URLSearchParams(window.location.search).get('tab');
  if (urlTab === 'register') (window as any).switchTab('register');
</script>
