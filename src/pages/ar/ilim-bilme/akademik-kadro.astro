---
import InnerPageLayout from '../../../layouts/InnerPageLayout.astro'
import { getIlimBilmeNav } from '../../../data/navigation'

import { localePath, t } from '../../../i18n/index';

const locale = 'ar' as const;
const nav = getIlimBilmeNav(locale);

const sidebarItems = nav.items.map(item => {
  if (item.label === nav.items.find(i => i.children)?.label) {
    return { ...item, active: true, children: item.children?.map(c => ({
      ...c, active: c.href === localePath(locale, '/ilim-bilme/akademik-kadro')
    })) }
  }
  return item
})

const breadcrumbs = [
  { label: t(locale, 'nav.ilimBilme'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'nav.sub.akademi'), href: '#' },
  { label: t(locale, 'nav.sub.akademikKadro') }
]

const kadro = [
  { name: 'YUSUF KAPLAN', ders: 'Fütûhât-ı Medeniyye', image: '' },
  { name: 'SAADETTİN ACAR', ders: 'Öncüler', image: '/images/kadro/akademik-kadro-01.jpg' },
  { name: 'KASIM KÜÇÜKALP', ders: 'Klasikten Çağdaşa Batı Düşüncesinin Serüveni', image: '/images/kadro/akademik-kadro-02.jpg' },
  { name: 'TAHSİN GÖRGÜN', ders: 'Düşünce Tarihi', image: '' },
  { name: 'YÜCEL ARZEN', ders: 'Sesin Nefesi: Nefesin Sesi', image: '' },
  { name: 'AHMET DAĞ', ders: 'Yapay Zekâ, İslâm ve Etik', image: '' },
]
---

<InnerPageLayout
  locale={locale}
  title="Akademik Kadro — MTO"
  description="Medeniyet Tasavvuru Okulu akademik kadrosu."
  pageTitle={t(locale, 'nav.sub.akademikKadro')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, '/ilim-bilme/akademik-kadro')}
>
  <div class="space-y-10">
    <div class="space-y-5 text-body leading-relaxed">
      <p>Medeniyet Tasavvuru Okulu'nun akademik kadrosu, sadece bilgi aktaran değil; enfüsi derinlik ile âfaki ufku merkeze alan ve bu birliktelikle hakikatin izini süren öncülerden oluşmaktadır. Klasik medrese geleneği ile modern akademik metodolojiyi harmanlayan; talebeyi ezberci bir sistemin nesnesi değil, fikrî üretim sürecinin öznesi haline getiren bir bakışı benimsemektedirler.</p>

      <p>Disiplinler arası düşünceye açık, tarih, felsefe, edebiyat, sanat, sosyoloji ve ilahiyat gibi farklı alanlarda uzmanlaşmış ilim insanlarından oluşan MTO akademik kadrosu, bilgi aktarmaktan öte, talebelerine ilmî karakter ve düşünme disiplini kazandıran, medeniyet perspektifi inşâ etmeye yönlendiren ve vizyon geliştiren öncülerdir.</p>

      <p>Eğitim felsefemizin en güçlü yanlarından biri, hoca ve talebe arasındaki akıştır. Medeniyet Tasavvuru Okulu'nda eğitim alan birçok talebe, eğitim sürecini yalnızca bir öğrenme aşaması olarak görmemiş; aksine, bu yolculuğu bir yaşam biçimi hâline getirmiştir.</p>

      <p>MTO akademik kadrosu oluşturulurken gayemiz, akademik donanıma sahip, medeniyet bilinciyle hareket eden ve Müslümanca düşünme melekelerini geliştirmiş bir neslin yetişmesine rehberlik edecek bir varış noktası oluşturmaktır.</p>
    </div>

    <!-- Motto -->
    <p class="text-center font-heading text-lg font-bold text-lacivert py-4">
      Medeniyet Tasavvuru Okulu | <span class="text-turkuaz">İlim</span> ile Derinleş, <span class="text-vizon">İrfan</span> ile Keşfet, <span class="text-turuncu">Hikmet</span> ile İnşâ Et!
    </p>

    <!-- Faculty Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {kadro.map(hoca => (
        <div class="group overflow-hidden">
          <div class="aspect-[3/4] bg-gray-300 relative">
            {hoca.image && (
              <img src={hoca.image} alt={hoca.name} class="w-full h-full object-cover" />
            )}
            <div class="absolute bottom-0 left-0 bg-turuncu px-4 py-2">
              <span class="text-white text-xs font-bold tracking-wider">{hoca.name}</span>
            </div>
          </div>
          <div class="bg-white py-3">
            <p class="text-sm text-body">
              <span class="font-semibold">Ders:</span> <strong>{hoca.ders}</strong>
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</InnerPageLayout>
