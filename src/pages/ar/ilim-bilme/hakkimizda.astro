---
import InnerPageLayout from '../../../layouts/InnerPageLayout.astro'
import ShareButtons from '../../../components/ShareButtons.astro'
import { getIlimBilmeNav } from '../../../data/navigation'
import { t, localePath } from '../../../i18n/index'

const locale = 'ar' as const;
const nav = getIlimBilmeNav(locale);

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, '/ilim-bilme/hakkimizda')
}))

const breadcrumbs = [
  { label: t(locale, 'hakkimizda.breadcrumb1'), href: localePath(locale, '/ilim-bilme') },
  { label: t(locale, 'hakkimizda.breadcrumb2') }
]
---

<InnerPageLayout
  locale={locale}
  title={`${t(locale, 'hakkimizda.title')} — MTO`}
  description={t(locale, 'meta.siteDescription')}
  pageTitle={t(locale, 'hakkimizda.breadcrumb2')}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, '/ilim-bilme/hakkimizda')}
>
  <div class="relative">
    <div class="hidden lg:block absolute -left-16 top-0">
      <ShareButtons />
    </div>
    <div class="w-full aspect-video bg-gray-300 rounded mb-10"></div>
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-vizon mb-8">
      {t(locale, 'hakkimizda.heroTitle')}
    </h2>
    <div class="space-y-6 text-body leading-relaxed">
      <p class="text-lg">{t(locale, 'hakkimizda.content.intro')}</p>
      <div class="space-y-6 mt-8">
        <div>
          <h3 class="font-heading text-xl font-bold text-turkuaz mb-2">{t(locale, 'hakkimizda.content.h1')}</h3>
          <p>{t(locale, 'hakkimizda.content.p1')}</p>
        </div>
        <div>
          <h3 class="font-heading text-xl font-bold text-turkuaz mb-2">{t(locale, 'hakkimizda.content.h2')}</h3>
          <p>{t(locale, 'hakkimizda.content.p2')}</p>
        </div>
        <div>
          <h3 class="font-heading text-xl font-bold text-turkuaz mb-2">{t(locale, 'hakkimizda.content.h3')}</h3>
          <p>{t(locale, 'hakkimizda.content.p3')}</p>
        </div>
      </div>
    </div>
  </div>
</InnerPageLayout>
