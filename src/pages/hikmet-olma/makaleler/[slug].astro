---
import InnerPageLayout from '../../../layouts/InnerPageLayout.astro';
import { getHikmetOlmaNav } from '../../../data/navigation';
import { t, localePath, type Locale, defaultLocale } from '../../../i18n/index';
import { getMakaleler, getMakale, getTranslation, getYorumlar } from '../../../lib/panel';

export async function getStaticPaths() {
  const { items } = await getMakaleler(1, 100);
  return items.map(m => ({ params: { slug: m.slug }, props: { makale: m } }));
}

const { slug } = Astro.params;
const { makale } = Astro.props;
const locale: Locale = 'tr';

const nav = getHikmetOlmaNav(locale);
const pagePath = '/hikmet-olma/makaleler';

const sidebarItems = nav.items.map(item => ({
  ...item,
  active: item.href === localePath(locale, pagePath)
}));

const tr = getTranslation(makale.translations, locale);
const yorumlar = await getYorumlar(makale.id);

const breadcrumbs = [
  { label: t(locale, 'nav.hikmetOlma'), href: localePath(locale, '/hikmet-olma') },
  { label: t(locale, 'nav.sub.makaleler'), href: localePath(locale, pagePath) },
  { label: tr?.baslik || 'Makale' }
];
---

<InnerPageLayout
  locale={locale}
  title={`${tr?.baslik || 'Makale'} — MTO`}
  description={tr?.ozet || t(locale, 'meta.siteDescription')}
  pageTitle={tr?.baslik || 'Makale'}
  sidebarTitle={nav.title}
  sidebarItems={sidebarItems}
  breadcrumbs={breadcrumbs}
  currentPath={localePath(locale, pagePath)}
  accentColor="mavi"
>
  <!-- Meta -->
  <div class="flex items-center gap-4 mb-8 text-xs text-body/50 not-prose">
    {makale.yayin_tarihi && (
      <time>{new Date(makale.yayin_tarihi).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    )}
    {makale.goruntulenme > 0 && (
      <span>· {makale.goruntulenme} görüntülenme</span>
    )}
  </div>

  <!-- Özet -->
  {tr?.ozet && (
    <div class="bg-turkuaz/5 border-l-4 border-turkuaz rounded-r-xl px-6 py-4 mb-8 not-prose">
      <p class="text-body text-sm leading-relaxed italic">{tr.ozet}</p>
    </div>
  )}

  <!-- İçerik -->
  <div class="prose prose-lg max-w-none">
    <Fragment set:html={tr?.icerik?.replace(/\n/g, '<br>') || ''} />
  </div>

  <!-- Yorumlar -->
  {makale.yorum_acik && (
    <div class="mt-12 pt-8 border-t border-gray-200 not-prose">
      <h3 class="font-heading text-xl text-lacivert font-bold mb-6">
        Yorumlar {yorumlar.length > 0 && `(${yorumlar.length})`}
      </h3>

      {yorumlar.length > 0 ? (
        <div class="space-y-4">
          {yorumlar.map(y => (
            <div class="bg-gray-50 rounded-xl p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="font-heading text-sm font-semibold text-lacivert">{y.user_display_name || 'Anonim'}</span>
                <span class="text-xs text-body/40">{new Date(y.created_at).toLocaleDateString('tr-TR')}</span>
              </div>
              <p class="text-sm text-body/80 leading-relaxed">{y.icerik}</p>
              {y.replies?.length > 0 && (
                <div class="mt-3 ml-6 space-y-3">
                  {y.replies.map(r => (
                    <div class="bg-white rounded-lg p-4 border border-gray-100">
                      <div class="flex items-center gap-2 mb-1">
                        <span class="font-heading text-xs font-semibold text-turkuaz">{r.user_display_name || 'Anonim'}</span>
                        <span class="text-xs text-body/40">{new Date(r.created_at).toLocaleDateString('tr-TR')}</span>
                      </div>
                      <p class="text-sm text-body/70">{r.icerik}</p>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <p class="text-sm text-body/50 italic">Henüz yorum yapılmamış. Yorum yapmak için panelden giriş yapın.</p>
      )}
    </div>
  )}
</InnerPageLayout>
