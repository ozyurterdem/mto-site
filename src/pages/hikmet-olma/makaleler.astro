---
import InnerPageLayout from '../../layouts/InnerPageLayout.astro';
import { hikmetOlmaNav } from '../../data/navigation';

const breadcrumbs = [
  { label: 'Anasayfa', href: '/' },
  { label: 'HİKMET · OLMA', href: '/hikmet-olma' },
  { label: 'Makaleler' },
];

const years = [2021, 2022, 2023, 2024, 2025];
const activeYear = 2021;

const articles = [
  { title: 'Tarih Felsefesi Üzerine Mülahazalar', author: 'Mehmet Kaya', city: 'Giresun', active: false },
  { title: 'Mutlak Hakikatin Enfüsteki ve Afaktaki İzi: Bir Hakikat Adamı Olarak İbn Haldun', author: 'Mehmet Adıgüzel Kertmen', city: 'İzmir', active: true },
  { title: 'İbn Haldun\'un Umran İlmi ve Modern Sosyoloji', author: 'Ahmet Yılmaz', city: 'Ankara', active: false },
  { title: 'Medeniyetlerin Çöküşünde Asabiyet Faktörü', author: 'Fatma Nur Demir', city: 'İstanbul', active: false },
  { title: 'İslam Düşünce Geleneğinde Tarih Bilinci', author: 'Hasan Özkan', city: 'Konya', active: false },
  { title: 'Mukaddime\'de Eğitim Felsefesi', author: 'Zeynep Kara', city: 'Bursa', active: false },
  { title: 'İbn Haldun ve Batı Tarih Felsefesi: Karşılaştırmalı Bir İnceleme', author: 'Ali Rıza Şahin', city: 'Trabzon', active: false },
  { title: 'Modernite Eleştirisi Bağlamında Tarih Felsefesinin İmkânı', author: 'Büşra Yıldız', city: 'Sakarya', active: false },
  { title: 'Toplumsal Dönüşüm ve Değerler: İbn Haldun Perspektifi', author: 'Mustafa Eren', city: 'Kayseri', active: false },
  { title: 'İslam Medeniyetinde Bilgi Anlayışı ve Hikmet Geleneği', author: 'Ayşe Nur Polat', city: 'Sivas', active: false },
];
---

<InnerPageLayout
  accentColor="mavi"
  pageTitle="Makaleler"
  sidebarTitle={hikmetOlmaNav.title}
  sidebarTitleHref="/hikmet-olma"
  sidebarItems={hikmetOlmaNav.items}
  breadcrumbs={breadcrumbs}
  currentPath="/hikmet-olma/makaleler"
  showBulten={false}
>
  <!-- Yil Alt Navigasyon -->
  <div class="flex flex-wrap gap-2 mb-8 not-prose">
    {years.map((year) => (
      <a
        href={`/hikmet-olma/makaleler?yil=${year}`}
        class:list={[
          'px-5 py-2 rounded-full text-sm font-heading font-bold uppercase tracking-wider transition-all duration-300 no-underline',
          year === activeYear
            ? 'bg-turkuaz text-white shadow-lg shadow-turkuaz/30'
            : 'bg-gray-100 text-body hover:bg-gray-200',
        ]}
      >
        {year}
      </a>
    ))}
  </div>

  <!-- Baslik -->
  <h2 class="font-heading text-2xl md:text-3xl text-lacivert font-black uppercase tracking-wide mb-8 not-prose">
    {activeYear} MTO AKADEMİK MAKALELERİ
  </h2>

  <!-- Makale Listesi -->
  <div class="space-y-0 not-prose">
    {articles.map((article, index) => (
      <div
        class:list={[
          'flex items-start gap-4 px-5 py-4 border-b border-gray-100 transition-all duration-200 rounded-lg',
          article.active
            ? 'bg-turkuaz/5 border-l-4 border-l-turkuaz'
            : 'hover:bg-gray-50',
        ]}
      >
        <span class:list={[
          'font-heading font-bold text-sm mt-0.5 flex-shrink-0 min-w-[1.5rem]',
          article.active ? 'text-turkuaz' : 'text-vizon',
        ]}>
          {index + 1}.
        </span>
        <div class="flex-1">
          <p class:list={[
            'font-body text-[0.95rem] leading-snug mb-1',
            article.active ? 'text-turkuaz font-semibold' : 'text-lacivert',
          ]}>
            {article.title}
          </p>
          <p class="text-body/60 text-xs">
            {article.author} — <span class="text-vizon">{article.city}</span>
          </p>
        </div>
      </div>
    ))}
  </div>

  <!-- Bilgi Notu -->
  <div class="mt-8 px-6 py-4 bg-turkuaz/5 border border-turkuaz/20 rounded-xl not-prose">
    <p class="text-body text-sm leading-relaxed">
      <strong class="text-turkuaz">Not:</strong> Makaleler, MTO akademik yaz kamplarinda talebelerin hazirladigi calismalarin derlenip yayimlanmis halidir. Her yil guncellenen bu arsiv, talebelerin dusunce uretme sureclerinin bir yansimasi olarak degerlendirilmektedir.
    </p>
  </div>
</InnerPageLayout>
