---
import InnerPageLayout from '../../layouts/InnerPageLayout.astro';
import { hikmetOlmaNav } from '../../data/navigation';

const breadcrumbs = [
  { label: 'Anasayfa', href: '/' },
  { label: 'HİKMET · OLMA', href: '/hikmet-olma' },
  { label: 'Kamplar' },
];

const years = [2026, 2025, 2024, 2023, 2022, 2021];
const activeYear = 2026;

const camps = [
  {
    title: '1- TARİH FELSEFESİ VE İBN HALDUN KAMPI • ÇORUM',
    categories: [
      {
        name: 'TARİH BİLİMİ, TARİH FELSEFESİ VE KAYNAKLARI',
        items: [
          'Tarih Bilimi ve Tarih Felsefesine Giriş',
          'İbn Haldun\'un Mukaddime\'si: Umran İlmi',
          'Asabiyet Kavramı ve Toplumsal Dönüşüm',
          'Medeniyetlerin Yükselişi ve Çöküşü',
          'İbn Haldun\'da Devlet Teorisi',
        ],
      },
    ],
  },
  {
    title: '2- MEDENİYET TASAVVURU KAMPI • İSTANBUL',
    categories: [
      {
        name: 'MEDENİYET DÜŞÜNCESİ VE KAYNAKLARI',
        items: [
          'Medeniyet Kavramının Kökenleri',
          'Doğu ve Batı Medeniyetlerinin Karşılaştırılması',
          'İslam Medeniyetinin Temel Dinamikleri',
          'Modernite ve Gelenek Arasında Medeniyet',
        ],
      },
    ],
  },
  {
    title: '3- DÜŞÜNCE TARİHİ KAMPI • BURSA',
    categories: [
      {
        name: 'İSLAM DÜŞÜNCE GELENEĞİ',
        items: [
          'Kelam, Felsefe ve Tasavvuf Geleneği',
          'Gazali ve Felsefeye Yöneltilen Eleştiriler',
          'İbn Arabi Düşüncesine Giriş',
          'Osmanlı Düşünce Geleneği',
          'Modern Dönemde İslam Düşüncesi',
        ],
      },
    ],
  },
  {
    title: '4- SİYASET FELSEFESİ KAMPI • ANKARA',
    categories: [
      {
        name: 'SİYASET FELSEFESİ VE KAYNAKLARI',
        items: [
          'Siyaset Felsefesine Giriş',
          'Farabi\'nin El-Medinetü\'l-Fazıla\'sı',
          'İbn Haldun\'da Siyaset Düşüncesi',
          'Modern Siyaset Teorileri ve Eleştirisi',
        ],
      },
    ],
  },
];
---

<InnerPageLayout
  accentColor="mavi"
  pageTitle="Kamplar"
  sidebarTitle={hikmetOlmaNav.title}
  sidebarTitleHref="/hikmet-olma"
  sidebarItems={hikmetOlmaNav.items}
  breadcrumbs={breadcrumbs}
  currentPath="/hikmet-olma/kamplar"
  showBulten={false}
>
  <!-- Yil Alt Navigasyon -->
  <div class="flex flex-wrap gap-2 mb-8 not-prose">
    {years.map((year) => (
      <a
        href={`/hikmet-olma/kamplar?yil=${year}`}
        class:list={[
          'px-5 py-2 rounded-full text-sm font-heading font-bold uppercase tracking-wider transition-all duration-300 no-underline',
          year === activeYear
            ? 'bg-turkuaz text-white shadow-lg shadow-turkuaz/30'
            : 'bg-gray-100 text-body hover:bg-gray-200',
        ]}
      >
        {year}
      </a>
    ))}
  </div>

  <!-- Baslik -->
  <h2 class="font-heading text-2xl md:text-3xl text-lacivert font-black uppercase tracking-wide mb-8 not-prose">
    {activeYear} MTO AKADEMİK YAZ KAMPLARI
  </h2>

  <!-- Accordion Kamplar -->
  <div class="space-y-4 not-prose">
    {camps.map((camp, index) => (
      <details class="group bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow duration-300" open={index === 0}>
        <summary class="flex items-center gap-4 px-6 py-5 cursor-pointer list-none select-none">
          <div class="w-8 h-8 rounded-lg bg-turkuaz/10 grid place-items-center flex-shrink-0 transition-colors group-open:bg-turkuaz">
            <svg class="w-4 h-4 text-turkuaz transition-all duration-300 group-open:text-white group-open:rotate-90" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
          </div>
          <h3 class="font-heading text-lacivert text-sm md:text-base font-bold uppercase tracking-wide leading-snug flex-1">
            {camp.title}
          </h3>
        </summary>

        <div class="px-6 pb-6 pt-2 border-t border-gray-100">
          {camp.categories.map((cat) => (
            <div class="mb-4 last:mb-0">
              <h4 class="font-heading text-turkuaz text-xs font-bold uppercase tracking-[0.15em] mb-3 pb-2 border-b border-turkuaz/20">
                {cat.name}
              </h4>
              <ul class="space-y-2">
                {cat.items.map((item) => (
                  <li class="flex items-start gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-vizon mt-2 flex-shrink-0"></span>
                    <span class="text-body text-sm leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </details>
    ))}
  </div>
</InnerPageLayout>

<style>
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; content: ''; }
</style>
